@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Giriş Yap | Kartist</title>

    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;500;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

    <style>
        /* --- GENEL AYARLAR --- */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            outline: none;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            height: 100vh;
            width: 100vw;
            background-color: #050505;
            color: white;
            font-family: 'Space Grotesk', sans-serif;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            /* Mobilde klavye açılınca arka plan bozulmasın */
            background-image: radial-gradient(circle at 50% 0%, #1a1a1a 0%, #050505 70%);
        }

        /* --- MODERN PRELOADER (YENİ) --- */
        #preloader {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: #000;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            transition: opacity 0.6s ease-out;
        }

        .loader-brand {
            font-size: 2.5rem;
            font-weight: 800;
            letter-spacing: -2px;
            margin-bottom: 20px;
            background: linear-gradient(to right, #fff, #666);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: breathe 2s infinite ease-in-out;
        }

        .loader-bar-bg {
            width: 150px;
            height: 4px;
            background: rgba(255,255,255,0.1);
            border-radius: 4px;
            overflow: hidden;
        }

        .loader-bar-fill {
            height: 100%;
            width: 0%;
            background: #c6ff00;
            box-shadow: 0 0 10px #c6ff00;
            animation: fillBar 1.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
        }

        @@keyframes fillBar {
            0% {
                width: 0%;
            }

            100% {
                width: 100%;
            }
        }

        @@keyframes breathe {
            0%, 100% {
                opacity: 0.8;
                transform: scale(0.98);
            }

            50% {
                opacity: 1;
                transform: scale(1.02);
            }
        }

        /* --- GERİ BUTONU (MOBİL DOSTU) --- */
        .btn-back {
            position: absolute;
            top: 20px;
            left: 20px;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            transition: 0.3s;
            z-index: 50;
        }

            .btn-back:active {
                transform: scale(0.9);
                background: #c6ff00;
                color: #000;
                border-color: #c6ff00;
            }

        /* --- LOGIN KARTI (MOBİL UYUMLU) --- */
        .login-card {
            width: 100%;
            max-width: 400px;
            padding: 30px;
            /* Mobilde tam ekran hissi, masaüstünde kart */
            display: flex;
            flex-direction: column;
            justify-content: center;
            opacity: 0;
            transform: translateY(20px);
            transition: 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
            z-index: 10;
        }

        /* Masaüstü için Cam Efekti */
        @@media (min-width: 768px) {
            .login-card {
                padding: 50px;
                background: rgba(255,255,255,0.02);
                border: 1px solid rgba(255,255,255,0.08);
                border-radius: 30px;
                box-shadow: 0 20px 50px rgba(0,0,0,0.5);
            }
        }

        .login-card.show {
            opacity: 1;
            transform: translateY(0);
        }

        .logo {
            font-size: 3rem;
            font-weight: 800;
            margin-bottom: 5px;
            letter-spacing: -2px;
            color: #fff;
            text-decoration: none;
            display: block;
            text-align: center;
        }

            .logo span {
                color: #c6ff00;
            }

        .subtitle {
            color: #666;
            font-size: 0.9rem;
            margin-bottom: 40px;
            text-align: center;
            font-weight: 500;
        }

        /* Input Alanları */
        .input-group {
            position: relative;
            margin-bottom: 20px;
        }

        .custom-input {
            width: 100%;
            background: #111;
            border: 1px solid #222;
            padding: 18px 20px;
            border-radius: 16px;
            color: #fff;
            font-size: 1rem;
            transition: 0.3s;
            font-family: inherit;
        }

            .custom-input:focus {
                border-color: #c6ff00;
                background: #000;
                box-shadow: 0 0 0 4px rgba(198, 255, 0, 0.1);
            }

            .custom-input::placeholder {
                color: #444;
            }

        /* Buton */
        .btn-login {
            width: 100%;
            background: #c6ff00;
            color: #000;
            padding: 18px;
            border: none;
            border-radius: 16px;
            font-weight: 800;
            font-size: 1.1rem;
            cursor: pointer;
            transition: 0.3s;
            margin-top: 10px;
            box-shadow: 0 10px 30px rgba(198, 255, 0, 0.15);
        }

            .btn-login:active {
                transform: scale(0.98);
                background: #b3e600;
            }

        /* Linkler */
        .links {
            margin-top: 30px;
            text-align: center;
            font-size: 0.9rem;
            color: #666;
        }

        .register-link {
            color: #fff;
            font-weight: 700;
            text-decoration: none;
            margin-left: 5px;
            position: relative;
        }

            .register-link::after {
                content: '';
                position: absolute;
                bottom: -2px;
                left: 0;
                width: 0%;
                height: 2px;
                background: #c6ff00;
                transition: 0.3s;
            }

            .register-link:hover::after {
                width: 100%;
            }

        /* Hata Kutusu */
        .error-box {
            background: rgba(255, 68, 68, 0.1);
            color: #ff4444;
            border: 1px solid rgba(255, 68, 68, 0.2);
            padding: 12px;
            border-radius: 12px;
            font-size: 0.85rem;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }
        /* Şifremi Unuttum Linki */
        .form-options {
            display: flex;
            justify-content: flex-start; /* Sağa yasla */
            margin-bottom: 20px;
            margin-top: 15px; /* Inputtan biraz yukarı çek */
            margin-left:30%;
        }

        .forgot-link {
            color: #888;
            font-size: 0.85rem;
            text-decoration: none;
            transition: 0.3s;
            font-weight: 500;
        }

            .forgot-link:hover {
                color: #c6ff00; /* Neon renk */
            }
    </style>
</head>
<body>

    <div id="preloader">
        <div class="loader-brand">KART<span>IST</span></div>
        <div class="loader-bar-bg">
            <div class="loader-bar-fill"></div>
        </div>
    </div>

    <a href="javascript:void(0);" onclick="goToHome()" class="btn-back">
        <i class="fa-solid fa-arrow-left"></i>
    </a>

    <div class="login-card" id="loginBox">
        <a href="/" class="logo">KART<span>IST</span></a>
        <p class="subtitle">Tekrar hoş geldin şampiyon.</p>

        @if (ViewBag.Hata != null)
        {
            <div class="error-box"><i class="fa-solid fa-triangle-exclamation"></i> @ViewBag.Hata</div>
        }

        <form action="/Account/Giris" method="post">
            @Html.AntiForgeryToken()
            <div class="input-group">
                <input type="email" name="email" class="custom-input" placeholder="E-Posta Adresin" required>
            </div>
            <div class="input-group">
                <input type="password" name="sifre" class="custom-input" placeholder="Şifren" required>
            </div>
            <button type="submit" class="btn-login">GİRİŞ YAP</button>
        </form>

        <div class="links">
            Hesabın yok mu? <a href="/Account/Kayit" class="register-link">Hemen Oluştur</a>
        </div>
        <div class="form-options">
            <a href="/Account/SifremiUnuttum" class="forgot-link">Şifreni mi unuttun?</a>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        window.addEventListener('load', function () {
            setTimeout(function () {
                var preloader = document.getElementById('preloader');
                var loginBox = document.getElementById('loginBox');
                preloader.style.opacity = '0';
                setTimeout(function () {
                    preloader.style.display = 'none';
                    loginBox.classList.add('show');
                }, 600);
            }, 1000); // 1.5s yerine 1s, mobilde hız önemli
        });

        function goToHome() {
            var preloader = document.getElementById('preloader');
            var loginBox = document.getElementById('loginBox');
            loginBox.classList.remove('show');
            preloader.style.display = 'flex';

            // Barı sıfırla ve tekrar doldur efekti için
            var bar = document.querySelector('.loader-bar-fill');
            bar.style.animation = 'none';
            bar.offsetHeight; /* trigger reflow */
            bar.style.animation = 'fillBar 1s forwards';

            setTimeout(() => { preloader.style.opacity = '1'; }, 50);
            setTimeout(function () { window.location.href = '/'; }, 1000);
        }
        var mesaj = '@Html.Raw(TempData["Mesaj"])';
        var tur = '@Html.Raw(TempData["Tur"])';

        if (mesaj && mesaj.length > 0) {
            Swal.fire({
                title: tur === 'success' ? 'Harika!' : 'Dikkat',
                text: mesaj,
                icon: tur,
                background: '#1e1e1e',
                color: '#fff',
                confirmButtonColor: '#c6ff00',
                confirmButtonText: '<span style="color:black; font-weight:bold;">TAMAM</span>'
            });
        }

        // 2. Sayfa İçi Hatalar (ViewBag)
        // Örn: Şifreyi yanlış girdiğinde aynı sayfada çalışır
        var hata = '@ViewBag.Hata';
        if (hata && hata.length > 0) {
            Swal.fire({
                title: 'Hoppala!',
                text: hata,
                icon: 'error',
                background: '#1e1e1e',
                color: '#fff',
                confirmButtonColor: '#ff4444',
                confirmButtonText: 'Tekrar Dene'
            });
        }
    </script>
</body>
</html>