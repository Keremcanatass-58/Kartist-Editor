@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Yeni Şifre Belirle | Kartist</title>

    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;500;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; outline: none; -webkit-tap-highlight-color: transparent; }

        body {
            height: 100vh; width: 100vw;
            background-color: #050505; color: white;
            font-family: 'Space Grotesk', sans-serif;
            overflow: hidden; display: flex; align-items: center; justify-content: center;
            background-image: radial-gradient(circle at 50% 100%, #1a1a1a 0%, #050505 80%);
        }

        /* Kart Tasarımı */
        .reset-card {
            width: 100%; max-width: 420px; padding: 40px 30px;
            background: rgba(255,255,255,0.02);
            border: 1px solid rgba(255,255,255,0.08); border-radius: 24px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.5);
            text-align: center;
            opacity: 0; transform: translateY(20px);
            animation: slideUp 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
        }

        @@keyframes slideUp { to { opacity: 1; transform: translateY(0); } }

        /* Kilit İkonu */
        .lock-icon {
            width: 70px; height: 70px; margin: 0 auto 25px auto;
            background: rgba(198, 255, 0, 0.1);
            border-radius: 50%; border: 1px solid rgba(198, 255, 0, 0.2);
            display: flex; align-items: center; justify-content: center;
            font-size: 1.8rem; color: #c6ff00;
            box-shadow: 0 0 20px rgba(198, 255, 0, 0.1);
        }

        .title { font-size: 1.8rem; font-weight: 800; margin-bottom: 10px; color: #fff; }
        .subtitle { color: #888; font-size: 0.9rem; margin-bottom: 30px; line-height: 1.5; }

        /* Inputlar */
        .custom-input {
            width: 100%; background: #111; border: 1px solid #222;
            padding: 18px 20px; border-radius: 12px; color: #fff; font-size: 1rem;
            transition: 0.3s; font-family: inherit; margin-bottom: 15px;
        }
        .custom-input:focus { border-color: #c6ff00; background: #000; box-shadow: 0 0 0 4px rgba(198, 255, 0, 0.1); }

        /* Buton */
        .btn-save {
            width: 100%; background: #c6ff00; color: #000;
            padding: 16px; border: none; border-radius: 12px;
            font-weight: 800; font-size: 1rem; cursor: pointer;
            transition: 0.3s; margin-top: 10px;
            display: flex; align-items: center; justify-content: center; gap: 10px;
        }
        .btn-save:hover { transform: translateY(-2px); box-shadow: 0 10px 30px rgba(198, 255, 0, 0.2); }

        .alert-box {
            padding: 12px; border-radius: 10px; font-size: 0.9rem; margin-bottom: 20px; text-align: left; display: flex; gap: 10px; align-items: center;
        }
        .alert-error { background: rgba(255, 68, 68, 0.1); color: #ff4444; border: 1px solid rgba(255, 68, 68, 0.2); }
    </style>
</head>
<body>

    <div class="reset-card">
        <div class="lock-icon">
            <i class="fa-solid fa-lock-open"></i>
        </div>

        <h1 class="title">Yeni Şifre</h1>
        <p class="subtitle">Lütfen hesabın için güçlü ve yeni bir şifre belirle.</p>

        @if (ViewBag.Hata != null)
        {
            <div class="alert-box alert-error">
                <i class="fa-solid fa-circle-exclamation"></i> @ViewBag.Hata
            </div>
        }

        <form action="/Account/SifreSifirla" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" name="token" value="@ViewBag.Token" />

            <input type="password" name="yeniSifre" class="custom-input" placeholder="Yeni Şifreniz" required minlength="6">

            <button type="submit" class="btn-save">
                ŞİFREYİ GÜNCELLE <i class="fa-solid fa-check"></i>
            </button>
        </form>
    </div>

</body>
</html>