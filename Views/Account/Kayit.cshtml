@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Kayıt Ol | Kartist</title>

    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;500;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; outline: none; -webkit-tap-highlight-color: transparent; }

        body {
            height: 100vh; width: 100vw;
            background-color: #050505; color: white;
            font-family: 'Space Grotesk', sans-serif;
            overflow: hidden; display: flex; align-items: center; justify-content: center;
            background-image: radial-gradient(circle at 50% 100%, #1a1a1a 0%, #050505 70%);
        }

        #preloader {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: #000; z-index: 9999;
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            transition: opacity 0.6s ease-out;
        }

        .loader-brand {
            font-size: 2.5rem; font-weight: 800; letter-spacing: -2px; margin-bottom: 20px;
            background: linear-gradient(to right, #fff, #666); -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            animation: breathe 2s infinite ease-in-out;
        }

        .loader-bar-bg { width: 150px; height: 4px; background: rgba(255,255,255,0.1); border-radius: 4px; overflow: hidden; }
        .loader-bar-fill { height: 100%; width: 0%; background: #c6ff00; box-shadow: 0 0 10px #c6ff00; animation: fillBar 1.5s cubic-bezier(0.22, 1, 0.36, 1) forwards; }

        @@keyframes fillBar { 0% { width: 0%; } 100% { width: 100%; } }
        @@keyframes breathe { 0%, 100% { opacity: 0.8; transform: scale(0.98); } 50% { opacity: 1; transform: scale(1.02); } }

        .btn-back {
            position: absolute; top: 20px; left: 20px;
            width: 40px; height: 40px; border-radius: 50%;
            background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
            color: #fff; display: flex; align-items: center; justify-content: center;
            text-decoration: none; transition: 0.3s; z-index: 50;
        }
        .btn-back:active { transform: scale(0.9); background: #c6ff00; color: #000; border-color: #c6ff00; }

        .register-card {
            width: 100%; max-width: 400px; padding: 30px;
            display: flex; flex-direction: column; justify-content: center;
            opacity: 0; transform: translateY(20px); transition: 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
            z-index: 10;
        }

        @@media (min-width: 768px) {
            .register-card {
                padding: 50px; background: rgba(255,255,255,0.02);
                border: 1px solid rgba(255,255,255,0.08); border-radius: 30px;
                box-shadow: 0 20px 50px rgba(0,0,0,0.5);
            }
        }

        .register-card.show { opacity: 1; transform: translateY(0); }

        .logo { font-size: 3rem; font-weight: 800; margin-bottom: 5px; letter-spacing: -2px; color: #fff; text-decoration: none; display: block; text-align: center; }
        .logo span { color: #c6ff00; }
        .subtitle { color: #666; font-size: 0.9rem; margin-bottom: 30px; text-align: center; font-weight: 500; }

        .input-group { position: relative; margin-bottom: 15px; }

        .custom-input {
            width: 100%; background: #111; border: 1px solid #222;
            padding: 18px 20px; border-radius: 16px; color: #fff; font-size: 1rem;
            transition: 0.3s; font-family: inherit;
        }

        .custom-input:focus { border-color: #c6ff00; background: #000; box-shadow: 0 0 0 4px rgba(198, 255, 0, 0.1); }
        .custom-input::placeholder { color: #444; }

        .btn-register {
            width: 100%; background: #fff; color: #000; /* Kayıtta Beyaz Buton */
            padding: 18px; border: none; border-radius: 16px;
            font-weight: 800; font-size: 1.1rem; cursor: pointer;
            transition: 0.3s; margin-top: 15px;
            box-shadow: 0 10px 30px rgba(255, 255, 255, 0.1);
        }
        .btn-register:active { transform: scale(0.98); background: #eee; }

        .links { margin-top: 30px; text-align: center; font-size: 0.9rem; color: #666; }
        .login-link { color: #c6ff00; font-weight: 700; text-decoration: none; margin-left: 5px; }

        .error-box {
            background: rgba(255, 68, 68, 0.1); color: #ff4444;
            border: 1px solid rgba(255, 68, 68, 0.2); padding: 12px;
            border-radius: 12px; font-size: 0.85rem; margin-bottom: 25px;
            display: flex; align-items: center; justify-content: center; gap: 10px;
        }
    </style>
</head>
<body>

    <div id="preloader">
        <div class="loader-brand">KART<span>IST</span></div>
        <div class="loader-bar-bg">
            <div class="loader-bar-fill"></div>
        </div>
    </div>

    <a href="javascript:void(0);" onclick="goToHome()" class="btn-back">
        <i class="fa-solid fa-arrow-left"></i>
    </a>

    <div class="register-card" id="registerBox">
        <a href="/" class="logo">KART<span>IST</span></a>
        <p class="subtitle">Efsaneler arasına katılma vaktin geldi.</p>

        @if (ViewBag.Hata != null)
        {
            <div class="error-box"><i class="fa-solid fa-triangle-exclamation"></i> @ViewBag.Hata</div>
        }

        <form action="/Account/Kayit" method="post">
            @Html.AntiForgeryToken()
            <div class="input-group">
                <input type="text" name="adsoyad" class="custom-input" placeholder="Adın Soyadın" required>
            </div>
            <div class="input-group">
                <input type="email" name="email" class="custom-input" placeholder="E-Posta Adresin" required>
            </div>
            <div class="input-group">
                <input type="password" name="sifre" class="custom-input" placeholder="Güçlü Bir Şifre" required>
            </div>
            <button type="submit" class="btn-register">HESAP OLUŞTUR</button>
        </form>

        <div class="links">
            Zaten bir hesabın var mı? <a href="/Account/Giris" class="login-link">Giriş Yap</a>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        window.addEventListener('load', function () {
            setTimeout(function () {
                var preloader = document.getElementById('preloader');
                var registerBox = document.getElementById('registerBox');
                preloader.style.opacity = '0';
                setTimeout(function () {
                    preloader.style.display = 'none';
                    registerBox.classList.add('show');
                }, 600);
            }, 1000);
        });

        function goToHome() {
            var preloader = document.getElementById('preloader');
            var registerBox = document.getElementById('registerBox');
            registerBox.classList.remove('show');
            preloader.style.display = 'flex';

            var bar = document.querySelector('.loader-bar-fill');
            bar.style.animation = 'none';
            bar.offsetHeight;
            bar.style.animation = 'fillBar 1s forwards';

            setTimeout(() => { preloader.style.opacity = '1'; }, 50);
            setTimeout(function () { window.location.href = '/'; }, 1000);
        }
        var mesaj = '@Html.Raw(TempData["Mesaj"])';
        var tur = '@Html.Raw(TempData["Tur"])';

        if (mesaj && mesaj.length > 0) {
            Swal.fire({
                title: tur === 'success' ? 'Harika!' : 'Dikkat',
                text: mesaj,
                icon: tur,
                background: '#1e1e1e',
                color: '#fff',
                confirmButtonColor: '#c6ff00',
                confirmButtonText: '<span style="color:black; font-weight:bold;">TAMAM</span>'
            });
        }

        // 2. Sayfa İçi Hatalar (ViewBag)
        // Örn: Şifreyi yanlış girdiğinde aynı sayfada çalışır
        var hata = '@ViewBag.Hata';
        if (hata && hata.length > 0) {
            Swal.fire({
                title: 'Hoppala!',
                text: hata,
                icon: 'error',
                background: '#1e1e1e',
                color: '#fff',
                confirmButtonColor: '#ff4444',
                confirmButtonText: 'Tekrar Dene'
            });
        }

    </script>
</body>
</html>