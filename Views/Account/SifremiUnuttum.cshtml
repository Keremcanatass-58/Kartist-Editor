@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Şifremi Unuttum | Kartist</title>

    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;500;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            outline: none;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            height: 100vh;
            width: 100vw;
            background-color: #050505;
            color: white;
            font-family: 'Space Grotesk', sans-serif;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            background-image: radial-gradient(circle at 50% 0%, #1a1a1a 0%, #050505 80%);
        }

        /* --- GERİ BUTONU --- */
        .btn-back {
            position: absolute;
            top: 20px;
            left: 20px;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            transition: 0.3s;
            z-index: 50;
        }

            .btn-back:active, .btn-back:hover {
                background: #c6ff00;
                color: #000;
                border-color: #c6ff00;
            }

        /* --- ANA KART --- */
        .reset-card {
            width: 100%;
            max-width: 420px;
            padding: 30px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            opacity: 0;
            transform: translateY(20px);
            animation: slideUp 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
        }

        /* Masaüstü Cam Efekti */
        @@media (min-width: 768px) {
            .reset-card {
                padding: 50px;
                background: rgba(255,255,255,0.02);
                border: 1px solid rgba(255,255,255,0.08);
                border-radius: 30px;
                box-shadow: 0 20px 50px rgba(0,0,0,0.5);
            }
        }

        @@keyframes slideUp {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* İkon Animasyonu */
        .icon-wrapper {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: rgba(198, 255, 0, 0.1);
            border: 1px solid rgba(198, 255, 0, 0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 25px;
            animation: floatIcon 3s ease-in-out infinite;
        }

            .icon-wrapper i {
                font-size: 2rem;
                color: #c6ff00;
            }

        @@keyframes floatIcon {
            0%, 100% {
                transform: translateY(0);
                box-shadow: 0 0 20px rgba(198, 255, 0, 0.1);
            }

            50% {
                transform: translateY(-10px);
                box-shadow: 0 10px 30px rgba(198, 255, 0, 0.2);
            }
        }

        .title {
            font-size: 1.8rem;
            font-weight: 800;
            margin-bottom: 10px;
            color: #fff;
            text-align: center;
        }

        .desc {
            color: #888;
            font-size: 0.95rem;
            margin-bottom: 30px;
            text-align: center;
            line-height: 1.5;
        }

        /* Form Elemanları */
        .form-wrapper {
            width: 100%;
        }

        .custom-input {
            width: 100%;
            background: #111;
            border: 1px solid #222;
            padding: 18px 20px;
            border-radius: 16px;
            color: #fff;
            font-size: 1rem;
            transition: 0.3s;
            font-family: inherit;
            margin-bottom: 20px;
        }

            .custom-input:focus {
                border-color: #c6ff00;
                background: #000;
                box-shadow: 0 0 0 4px rgba(198, 255, 0, 0.1);
            }

        .btn-reset {
            width: 100%;
            background: #c6ff00;
            color: #000;
            padding: 18px;
            border: none;
            border-radius: 16px;
            font-weight: 800;
            font-size: 1.1rem;
            cursor: pointer;
            transition: 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

            .btn-reset:active {
                transform: scale(0.98);
                background: #b3e600;
            }

            .btn-reset:disabled {
                opacity: 0.7;
                cursor: not-allowed;
                transform: none;
            }

        /* Mesaj Kutuları */
        .alert-box {
            padding: 15px;
            border-radius: 12px;
            font-size: 0.9rem;
            margin-bottom: 20px;
            width: 100%;
            text-align: center;
        }

        .alert-error {
            background: rgba(255, 68, 68, 0.1);
            color: #ff4444;
            border: 1px solid rgba(255, 68, 68, 0.2);
        }

        .alert-success {
            background: rgba(198, 255, 0, 0.1);
            color: #c6ff00;
            border: 1px solid rgba(198, 255, 0, 0.2);
        }
    </style>
</head>
<body>

    <a href="/Account/Giris" class="btn-back">
        <i class="fa-solid fa-arrow-left"></i>
    </a>

    <div class="reset-card">
        <div class="icon-wrapper">
            <i class="fa-solid fa-key"></i>
        </div>

        <h1 class="title">Şifreni mi Unuttun?</h1>
        <p class="desc">Endişelenme, kayıtlı e-posta adresini gir, sana sıfırlama bağlantısı gönderelim.</p>

        @if (ViewBag.Hata != null)
        {
            <div class="alert-box alert-error">
                <i class="fa-solid fa-circle-exclamation"></i> @ViewBag.Hata
            </div>
        }

        @if (ViewBag.Mesaj != null)
        {
            <div class="alert-box alert-success" style="background: rgba(198, 255, 0, 0.15); color: #c6ff00; border: 1px solid rgba(198, 255, 0, 0.3); padding: 15px; border-radius: 12px; margin-bottom: 20px; text-align: left; display: flex; gap: 10px; align-items: center;">
                <i class="fa-solid fa-check-circle" style="font-size: 1.2rem;"></i>
                <span>@ViewBag.Mesaj</span>
            </div>

            <a href="/Account/Giris" class="btn-reset" style="text-decoration:none; background:#333; color:#fff; margin-top:10px;">
                GİRİŞ EKRANINA DÖN
            </a>
        }
        else
        {
            <form action="/Account/SifremiUnuttum" method="post" class="form-wrapper" onsubmit="handleSubmit(this)">
                @Html.AntiForgeryToken()

                <input type="email" name="email" class="custom-input" placeholder="ornek@mail.com" required>

                <button type="submit" class="btn-reset" id="submitBtn">
                    BAĞLANTI GÖNDER <i class="fa-solid fa-paper-plane"></i>
                </button>
            </form>
        }
    </div>

    <script>
        function handleSubmit(form) {
            var btn = document.getElementById('submitBtn');
            var originalText = btn.innerHTML;

            // Butonu pasif yap ve yükleniyor göster
            btn.disabled = true;
            btn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i> GÖNDERİLİYOR...';

            // Formu gönder (Normal submit işleminin devam etmesi için return true gerekmez, form submit olur)
        }
    </script>

</body>
</html>