@using System.Security.Claims
@using Dapper
@using Microsoft.Data.SqlClient
@using Microsoft.Extensions.Configuration
@inject IConfiguration Config
@{
    ViewData["Title"] = "Stüdyom";
    string profilResmi = "https://cdn-icons-png.flaticon.com/512/149/149071.png";
    string email = User.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Email)?.Value;
    string uyelikTipi = "Normal";
    int kalanKredi = 0;
    string bitisTarihiStr = "-";

    List<dynamic> tasarimlar = new List<dynamic>();
    List<dynamic> favoriler = new List<dynamic>();

    using (var db = new SqlConnection(Config.GetConnectionString("DefaultConnection")))
    {
        var user = db.QueryFirstOrDefault("SELECT ProfilResmi, UyelikTipi, KalanKredi, UyelikBitisTarihi FROM Kullanicilar WHERE Email = @e", new { e = email });

        if (user != null)
        {
            if (user.ProfilResmi != null) profilResmi = user.ProfilResmi;
            if (user.UyelikTipi != null) uyelikTipi = user.UyelikTipi;

            if (user.KalanKredi != null) kalanKredi = user.KalanKredi;
            if (user.UyelikBitisTarihi != null) bitisTarihiStr = ((DateTime)user.UyelikBitisTarihi).ToString("dd.MM.yyyy");
        }

        string sql = @"
SELECT k.Id, k.Tarih,
COALESCE(k.ProjeAdi, s.Baslik, 'Adsız Proje') as GosterilecekAd,
COALESCE(k.OnizlemeResmi, s.ResimUrl, 'https://placehold.co/600x400/222/fff?text=Onizleme+Yok') as ResimUrl,
ISNULL(s.Id, 0) as SablonId
FROM KayitliTasarimlar k
LEFT JOIN Sablonlar s ON k.SablonId = s.Id
WHERE k.KullaniciEmail = @e
ORDER BY k.Tarih DESC";

        tasarimlar = db.Query(sql, new { e = email }).ToList();
        string sqlFav = @"SELECT s.Id, s.Baslik, s.ResimUrl, s.Fiyat, s.Kategori
  FROM Favoriler f
  JOIN Sablonlar s ON f.SablonId = s.Id
  WHERE f.KullaniciEmail = @e
  ORDER BY f.Id DESC";
        favoriler = db.Query(sqlFav, new { e = email }).ToList();
    }
}

<style>
    .profile-wrapper {
        max-width: 1100px;
        margin: 40px auto;
    }

    .user-dashboard-card {
        background: #111;
        border: 1px solid #222;
        border-radius: 12px;
        padding: 15px 25px;
        margin-bottom: 30px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .avatar-info-group {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .avatar-box {
        position: relative;
        width: 70px;
        height: 70px;
    }

    .user-avatar {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid var(--accent-neon);
        padding: 2px;
    }

    .avatar-btn {
        position: absolute;
        bottom: 0;
        right: 0;
        background: #fff;
        color: #000;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: 0.7rem;
    }

    .user-text h1 {
        font-weight: 700;
        margin: 0;
        font-size: 1.5rem;
        letter-spacing: -0.5px;
    }

    .user-text p {
        color: #666;
        margin: 0;
        font-size: 0.8rem;
    }

    .pro-badge {
        background: #c6ff00;
        color: black;
        font-size: 0.6rem;
        padding: 3px 8px;
        border-radius: 4px;
        font-weight: 800;
        vertical-align: middle;
    }

    .stats-row {
        display: flex;
        gap: 30px;
    }

    .stat-item {
        text-align: center;
        border-left: 1px solid #222;
        padding-left: 30px;
    }

    .stat-val {
        font-size: 1.2rem;
        font-weight: 800;
        color: white;
        display: block;
    }

    .stat-lbl {
        font-size: 0.7rem;
        color: #555;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .custom-tabs {
        display: flex;
        gap: 30px;
        border-bottom: 1px solid #222;
        margin-bottom: 30px;
    }

    .tab-btn {
        background: none;
        border: none;
        color: #666;
        font-weight: 700;
        padding: 15px 0;
        font-size: 1rem;
        position: relative;
        cursor: pointer;
        transition: 0.3s;
    }

        .tab-btn.active {
            color: var(--accent-neon);
        }

            .tab-btn.active::after {
                content: '';
                position: absolute;
                bottom: -1px;
                left: 0;
                width: 100%;
                height: 2px;
                background: var(--accent-neon);
                box-shadow: 0 0 10px var(--accent-neon);
            }

    .projects-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 20px;
    }

    .design-card {
        background: #111;
        border-radius: 12px;
        overflow: hidden;
        transition: 0.3s;
        border: 1px solid #222;
        position: relative;
    }

        .design-card:hover {
            transform: translateY(-3px);
            border-color: var(--accent-neon);
            box-shadow: 0 5px 20px rgba(0,0,0,0.5);
        }

    .card-thumb {
        height: 160px;
        width: 100%;
        object-fit: cover;
        opacity: 0.8;
        transition: 0.3s;
        background: #1a1a1a;
    }

    .card-info-content {
        padding: 15px;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .card-title {
        font-weight: 600;
        font-size: 0.95rem;
        margin: 0;
        cursor: pointer;
    }

    .project-date {
        font-size: 0.75rem;
        color: #666;
        margin-top: 5px;
    }

    .card-actions {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 5px;
        margin-top: auto;
    }

    .btn-card-action {
        background: #222;
        color: white;
        border: 1px solid #333;
        padding: 8px;
        border-radius: 6px;
        font-size: 0.75rem;
        transition: 0.2s;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
    }

        .btn-card-action.edit {
            background: #c6ff00;
            color: black;
            font-weight: bold;
        }

        .btn-card-action.delete {
            background: #ff4444;
            color: white;
        }

    .card-select {
        position: absolute;
        top: 10px;
        left: 10px;
        width: 20px;
        height: 20px;
        accent-color: var(--accent-neon);
        cursor: pointer;
        z-index: 10;
    }

    .bulk-bar {
        background: #222;
        border-left: 4px solid #ff4444;
        padding: 10px 20px;
        border-radius: 8px;
        display: none;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 20px;
    }

        .bulk-bar.show {
            display: flex;
        }

    .empty-box {
        text-align: center;
        padding: 80px 0;
        border: 1px dashed #333;
        border-radius: 12px;
        color: #666;
        margin-top: 20px;
    }

    .btn-pro-neon {
        background: linear-gradient(135deg, #c6ff00 0%, #b3d900 100%);
        color: #000;
        border: none;
        padding: 12px 28px;
        border-radius: 50px;
        font-weight: 800;
        font-size: 0.9rem;
        cursor: pointer;
        transition: 0.3s;
        display: flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 0 20px rgba(198, 255, 0, 0.3);
        text-decoration: none;
    }

        .btn-pro-neon:hover {
            transform: translateY(-3px) scale(1.02);
            box-shadow: 0 0 30px rgba(198, 255, 0, 0.6);
            color: black;
        }

        .btn-pro-neon:active {
            transform: translateY(0);
        }
    /* ------------------------------------------- */
    .btn-logout {
        width: 45px; /* Pro butonuyla aynı yükseklik */
        height: 45px;
        border-radius: 50%;
        border: 1px solid #333;
        background: #111;
        color: #ff4444;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        transition: 0.2s;
        font-size: 1.2rem;
    }

        .btn-logout:hover {
            background: #ff4444;
            color: white;
            border-color: #ff4444;
        }

    .user-status-info {
        margin-top: 8px;
        font-size: 0.8rem;
        color: #aaa;
        display: flex;
        gap: 15px;
        flex-wrap: wrap;
    }

    /* ============================================
       RESPONSIVE TASARIM - TÜM CİHAZLAR İÇİN
       ============================================ */

    /* Tablet ve küçük ekranlar (992px ve altı) */
    @@media (max-width: 992px) {
        .profile-wrapper {
            margin: 20px auto;
            padding: 0 15px;
        }

        .user-dashboard-card {
            flex-direction: column;
            align-items: flex-start;
            gap: 20px;
        }

        .stats-row {
            width: 100%;
            justify-content: space-around;
            gap: 15px;
        }

        .stat-item {
            border-left: none;
            padding-left: 0;
            flex: 1;
        }

        .d-flex.gap-2 {
            width: 100%;
            justify-content: space-between;
        }
    }

    /* Mobil cihazlar (768px ve altı) */
    @@media (max-width: 768px) {
        .profile-wrapper {
            margin: 15px auto;
            padding: 0 10px;
        }

        .user-dashboard-card {
            padding: 15px;
            margin-bottom: 20px;
        }

        .avatar-info-group {
            width: 100%;
            flex-direction: column;
            align-items: flex-start;
            gap: 15px;
        }

        .avatar-box {
            width: 60px;
            height: 60px;
        }

        .user-text h1 {
            font-size: 1.2rem;
        }

        .user-text p {
            font-size: 0.75rem;
        }

        .user-status-info {
            font-size: 0.7rem;
            gap: 10px;
            flex-direction: column;
            align-items: flex-start;
        }

        .stats-row {
            flex-direction: column;
            gap: 15px;
            width: 100%;
            padding-top: 15px;
            border-top: 1px solid #222;
        }

        .stat-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 0;
            border-bottom: 1px solid #222;
        }

            .stat-item:last-child {
                border-bottom: none;
            }

        .stat-val {
            font-size: 1.1rem;
        }

        .stat-lbl {
            font-size: 0.7rem;
        }

        .custom-tabs {
            flex-wrap: wrap;
            gap: 10px;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
            scrollbar-width: thin;
        }

            .custom-tabs::-webkit-scrollbar {
                height: 4px;
            }

            .custom-tabs::-webkit-scrollbar-thumb {
                background: #c6ff00;
                border-radius: 2px;
            }

        .tab-btn {
            font-size: 0.85rem;
            padding: 12px 15px;
            white-space: nowrap;
        }

        .projects-grid {
            grid-template-columns: 1fr;
            gap: 15px;
        }

        .design-card {
            margin-bottom: 0;
        }

        .card-thumb {
            height: 200px;
        }

        .card-actions {
            grid-template-columns: 1fr 1fr 1fr;
            gap: 8px;
        }

        .btn-card-action {
            padding: 10px;
            font-size: 0.7rem;
        }

        .bulk-bar {
            flex-direction: column;
            gap: 10px;
            padding: 15px;
        }

            .bulk-bar button {
                width: 100%;
            }

        .d-flex.gap-2 {
            flex-direction: column;
            width: 100%;
            gap: 10px;
        }

        .btn-pro-neon {
            width: 100%;
            justify-content: center;
        }

        .btn-logout {
            width: 100%;
            height: 45px;
            border-radius: 8px;
        }

        .empty-box {
            padding: 40px 20px;
        }

            .empty-box h4 {
                font-size: 1.1rem;
            }
    }

    /* Küçük telefonlar (480px ve altı) */
    @@media (max-width: 480px) {
        .profile-wrapper {
            margin: 10px auto;
            padding: 0 8px;
        }

        .user-dashboard-card {
            padding: 12px;
        }

        .avatar-box {
            width: 50px;
            height: 50px;
        }

        .avatar-btn {
            width: 18px;
            height: 18px;
            font-size: 0.6rem;
        }

        .user-text h1 {
            font-size: 1rem;
        }

        .user-text p {
            font-size: 0.7rem;
        }

        .user-status-info {
            font-size: 0.65rem;
            gap: 8px;
        }

        .pro-badge {
            font-size: 0.55rem;
            padding: 2px 6px;
        }

        .stats-row {
            gap: 10px;
        }

        .stat-val {
            font-size: 1rem;
        }

        .stat-lbl {
            font-size: 0.65rem;
        }

        .custom-tabs {
            gap: 8px;
        }

        .tab-btn {
            font-size: 0.75rem;
            padding: 10px 12px;
        }

        .projects-grid {
            gap: 12px;
        }

        .card-thumb {
            height: 180px;
        }

        .card-info-content {
            padding: 12px;
        }

        .card-title {
            font-size: 0.85rem;
        }

        .project-date {
            font-size: 0.7rem;
        }

        .card-actions {
            gap: 5px;
        }

        .btn-card-action {
            padding: 8px;
            font-size: 0.65rem;
        }

        .card-select {
            width: 18px;
            height: 18px;
            top: 8px;
            left: 8px;
        }

        .empty-box {
            padding: 30px 15px;
        }

            .empty-box i {
                font-size: 2rem !important;
            }

            .empty-box h4 {
                font-size: 1rem;
            }

        #settings {
            padding: 0;
        }

            #settings > div {
                max-width: 100%;
                padding: 20px 15px;
            }

            #settings h4 {
                font-size: 1.1rem;
            }

        .form-control {
            font-size: 0.9rem;
            padding: 8px;
        }
    }

    /* Çok küçük telefonlar (360px ve altı) */
    @@media (max-width: 360px) {
        .profile-wrapper {
            padding: 0 5px;
        }

        .user-dashboard-card {
            padding: 10px;
        }

        .avatar-box {
            width: 45px;
            height: 45px;
        }

        .user-text h1 {
            font-size: 0.95rem;
        }

        .tab-btn {
            font-size: 0.7rem;
            padding: 8px 10px;
        }

        .card-thumb {
            height: 160px;
        }

        .btn-card-action {
            font-size: 0.6rem;
            padding: 6px;
        }
    }

    /* Yatay mod (landscape) mobil */
    @@media (max-width: 900px) and (orientation: landscape) {
        .user-dashboard-card {
            flex-direction: row;
            flex-wrap: wrap;
        }

        .avatar-info-group {
            flex-direction: row;
            flex: 1;
        }

        .stats-row {
            flex-direction: row;
            flex: 1;
            justify-content: space-around;
        }

        .d-flex.gap-2 {
            flex-direction: row;
            width: auto;
        }
    }

    /* Favoriler sayfası responsive */
    @@media (max-width: 768px) {
        .project-card {
            position: relative;
        }

        .remove-fav-btn {
            width: 28px !important;
            height: 28px !important;
            font-size: 0.8rem;
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
        }

            .empty-state i {
                font-size: 2.5rem !important;
            }
    }

    /* Tab içerik animasyonu */
    .tab-content {
        animation: fadeIn 0.3s ease;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Scroll bar özelleştirme */
    .custom-tabs {
        scrollbar-width: thin;
        scrollbar-color: #c6ff00 #222;
    }

    /* Touch friendly butonlar mobilde */
    @@media (max-width: 768px) {
        .btn-card-action,
        .btn-pro-neon,
        .btn-logout,
        .tab-btn {
            min-height: 44px; /* iOS touch target */
            touch-action: manipulation;
        }
    }
</style>

<div class="container profile-wrapper">

    <div class="user-dashboard-card">

        <div class="avatar-info-group">
            <form id="avatarForm"
                  asp-controller="Account"
                  asp-action="ProfilResmiGuncelle"
                  method="post"
                  enctype="multipart/form-data"
                  class="avatar-group">
                @Html.AntiForgeryToken()

                <div class="avatar-box">
                    <img src="@profilResmi"
                         class="user-avatar"
                         alt="Profil"
                         onerror="this.src='https://cdn-icons-png.flaticon.com/512/149/149071.png'">

                    <label for="fileInput" class="avatar-btn">
                        <i class="fa-solid fa-camera"></i>
                    </label>

                    <input type="file"
                           id="fileInput"
                           name="profilResmi"
                           accept="image/*"
                           style="display:none;"
                           onchange="document.getElementById('avatarForm').submit()" />
                </div>
            </form>


            <div class="user-text">
                <h1 class="text-white">
                    @User.Identity.Name @if (uyelikTipi == "Pro")
                    {
                        <span class="pro-badge">PRO</span>
                    }
                </h1>
                <p>@email</p>

                <div class="user-status-info">
                    @if (uyelikTipi == "Pro")
                    {
                        <span style="color:#c6ff00"><i class="fa-solid fa-check-circle"></i> PRO Aktif</span>
                        <span>Bitiş: @bitisTarihiStr</span>
                    }
                    else
                    {
                        <span><i class="fa-regular fa-user"></i> Başlangıç Paketi</span>
                        <span style="color:white; font-weight:bold;">Kalan Kredi: <span style="color:#c6ff00">@kalanKredi</span></span>
                    }
                </div>
            </div>
        </div>
        @if (TempData["Hata"] != null)
        {
            <div class="alert alert-danger fw-bold text-center">
                <i class="fa-solid fa-circle-xmark"></i> @TempData["Hata"]
            </div>
        }

        @if (TempData["Basarili"] != null)
        {
            <div class="alert alert-success fw-bold text-center">
                <i class="fa-solid fa-check-circle"></i> @TempData["Basarili"]
            </div>
        }

        <div class="stats-row">
            <div class="stat-item"><span class="stat-val">@tasarimlar.Count</span><span class="stat-lbl">Proje</span></div>
            <div class="stat-item"><span class="stat-val">@favoriler.Count</span><span class="stat-lbl">Favori</span></div>
            <div class="stat-item"><span class="stat-val">0</span><span class="stat-lbl">Satış</span></div>
        </div>

        <div class="d-flex gap-2">
            @if (uyelikTipi != "Pro")
            {
                <button onclick="tryBecomePro()" class="btn-pro-neon">
                    <i class="fa-solid fa-bolt"></i> PRO OL
                </button>
            }
            else
            {

            }
            <a href="/Account/Cikis" class="btn-logout" title="Çıkış Yap">
                <i class="fa-solid fa-power-off"></i>
            </a>
        </div>
    </div>

    <div class="custom-tabs">
        <button class="tab-btn active" onclick="openTab(event, 'projects')">📂 PROJELERİM</button>
        <button class="tab-btn" onclick="openTab(event, 'settings')">⚙️ AYARLAR</button>
        <button class="tab-btn" onclick="openTab(event, 'favorites')">❤️ FAVORİLER</button>
    </div>

    <div id="projects" class="tab-content" style="display:block;">

        <div class="projects-grid">
            @if (tasarimlar != null && tasarimlar.Count > 0)
            {
                @foreach (var t in tasarimlar)
                {
                    // GÜVENLİK KİLİDİ: Veriler null gelse bile varsayılan değer ata
                    var kayitId = t.Id != null ? t.Id : 0;
                    var sablonId = t.SablonId != null ? t.SablonId : 0;
                    var resim = t.ResimUrl != null ? t.ResimUrl : "https://placehold.co/600x400/222/555?text=Resim+Yok";
                    var baslik = t.GosterilecekAd != null ? t.GosterilecekAd : "Adsız Proje";

                    // Tarih hatasını önlemek için try-catch bloğu
                    string tarih = "-";
                    try
                    {
                        if (t.Tarih != null) { tarih = ((DateTime)t.Tarih).ToString("dd MMM"); }
                    }
                    catch { }

                    <div class="design-card">
                        <input type="checkbox" name="secilenIdler" value="@kayitId" class="card-select" onchange="updateBulkActions()">

                        <a href="/Home/Tasarim/@sablonId?kayitliId=@kayitId">
                            <img src="@resim" class="card-thumb" onerror="this.src='https://placehold.co/600x400/222/555?text=Resim+Yok'">
                        </a>

                        <div class="card-info-content">
                            <div class="d-flex align-items-center justify-content-between">
                                <div class="card-title" onclick="renameProject(@kayitId, '@baslik')" title="İsmi Değiştir">@baslik</div>
                                <i class="fa-solid fa-pencil" style="font-size:0.7rem; color:#444;"></i>
                            </div>
                            <div class="project-date">@tarih</div>
                            <div class="card-actions">
                                <a href="/Home/Tasarim/@sablonId?kayitliId=@kayitId" class="btn-card-action edit">DÜZENLE</a>
                                <a href="/Home/ProjeKopyala/@kayitId" class="btn-card-action copy" title="Kopyala"><i class="fa-regular fa-copy"></i></a>
                                <a href="/Home/TasarimiSil/@kayitId" class="btn-card-action delete" onclick="return confirm('Silinsin mi?')"><i class="fa-solid fa-trash"></i></a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="empty-box" style="grid-column: 1 / -1;">
                    <i class="fa-solid fa-folder-open" style="font-size:3rem; margin-bottom:20px; opacity:0.5;"></i>
                    <h4>Henüz projen yok</h4>
                    <a href="/#koleksiyon" class="btn btn-outline-light mt-3 px-4 rounded-pill">Şablon Seç</a>
                </div>
            }
        </div>
    </div>
    <div id="favorites" class="tab-content" style="display:none;">
        @if (favoriler.Count == 0)
        {
            <div class="empty-state">
                <i class="fa-solid fa-heart-crack mb-3" style="font-size:3rem; color:#444;"></i>
                <p>Henüz favori eklemedin.</p>
                <a href="/" class="btn btn-sm btn-outline-light rounded-pill px-4 mt-2">Keşfet</a>
            </div>
        }
        else
        {
            <div class="projects-grid">
                @foreach (var f in favoriler)
                {
                    <div class="project-card" id="fav-card-@f.Id">
                        <button onclick="removeFav(@f.Id)" class="remove-fav-btn" style="position:absolute; top:10px; right:10px; width:30px; height:30px; border-radius:50%; background:rgba(0,0,0,0.7); color:#ff4444; border:1px solid #ff4444; display:flex; align-items:center; justify-content:center; cursor:pointer; z-index:10;"><i class="fa-solid fa-xmark"></i></button>

                        <img src="@f.ResimUrl" class="card-thumb">
                        <div class="card-info-content">
                            <h5 class="card-title text-white">@f.Baslik</h5>
                            <p class="project-date" style="color:#c6ff00">@f.Fiyat ₺</p>
                            <a href="/Home/Tasarim/@f.Id" class="btn btn-sm btn-light w-100 mt-2 fw-bold">TASARLA</a>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <div id="settings" class="tab-content" style="display:none;">
        <div style="max-width:500px; background:#111; padding:30px; border-radius:12px; border:1px solid #222;">
            <h4 style="color:white; margin-bottom:20px;">Şifre Değiştir</h4>
            <input type="password" class="form-control mb-3 bg-black border-secondary text-light" placeholder="Mevcut Şifre" style="background:#222; border:1px solid #333; color:white; padding:10px;">
            <input type="password" class="form-control mb-3 bg-black border-secondary text-light" placeholder="Yeni Şifre" style="background:#222; border:1px solid #333; color:white; padding:10px;">
            <button class="btn-studio btn-primary-studio w-100">GÜNCELLE</button>
        </div>
    </div>
</div>

<script>
    function openTab(evt, tabName) {
        document.querySelectorAll(".tab-content").forEach(x => x.style.display = "none");
        document.querySelectorAll(".tab-btn").forEach(x => x.className = x.className.replace(" active", ""));
        document.getElementById(tabName).style.display = "block";
        evt.currentTarget.className += " active";
        document.getElementById('bulkActions').classList.remove('show');
    }
    function updateBulkActions() {
        var count = document.querySelectorAll('.card-select:checked').length;
        var bar = document.getElementById('bulkActions');
        document.getElementById('selectedCount').innerText = count;
        if (count > 0) bar.classList.add('show'); else bar.classList.remove('show');
    }
    function renameProject(id, eskiAd) {
        var yeniAd = prompt("Yeni isim:", eskiAd);
        if (yeniAd && yeniAd !== eskiAd) {
            var fd = new FormData(); fd.append("id", id); fd.append("yeniAd", yeniAd); fd.append("__RequestVerificationToken", getCSRFToken());
            fetch('/Home/ProjeAdDegistir', { method: 'POST', body: fd }).then(r => r.json()).then(d => { if (d.success) location.reload(); });
        }
    }

</script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.js"></script>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    function getCSRFToken() {
        return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
    }

    function tryBecomePro() {
        Swal.fire({
            title: 'PRO Olmak İstiyor musun?',
            text: "Hesabından 50 Kredi düşülecek.",
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#c6ff00',
            cancelButtonColor: '#333',
            confirmButtonText: '<span style="color:black; font-weight:bold;">Evet, Yükselt!</span>',
            cancelButtonText: 'Vazgeç',
            background: '#1e1e1e', color: '#fff'
        }).then((result) => {
            if (result.isConfirmed) {
                var fd = new FormData();
                fd.append("__RequestVerificationToken", getCSRFToken());
                fetch("/Account/ProOlAjax", { method: "POST", body: fd })
                .then(response => response.json())
                .then(res => {
                    if (res.success) {
                        Swal.fire({
                            title: 'Harika! 🌟',
                            text: res.message,
                            icon: 'success',
                            confirmButtonColor: '#c6ff00',
                            confirmButtonText: '<span style="color:black; font-weight:bold;">Tamam</span>',
                            background: '#1e1e1e', color: '#fff'
                        }).then(() => location.reload());
                    } else {
                        Swal.fire({
                            title: 'Olamadı...',
                            text: res.message,
                            icon: 'error',
                            confirmButtonColor: '#d33',
                            background: '#1e1e1e', color: '#fff'
                        });
                    }
                })
                .catch(error => {
                    console.error('Hata:', error);
                    Swal.fire({ icon: 'error', title: 'Sunucu Hatası', text: 'İşlem yapılamadı.' });
                });
            }
        });
    }

    function openDeleteModal(id) {
        Swal.fire({
            title: 'Emin misin?',
            text: "Bu proje kalıcı olarak silinecek!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#333',
            confirmButtonText: 'Evet, Sil',
            cancelButtonText: 'Vazgeç',
            background: '#1e1e1e', color: '#fff'
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = "/Home/TasarimiSil/" + id;
            }
        });
    }

    var userEmail = "@email";
    if (userEmail) {
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/adminHub")
            .withAutomaticReconnect()
            .build();

        connection.start().then(function () {
            connection.invoke("KullaniciBaglan", userEmail);
        }).catch(err => console.error(err));

        connection.on("SayfayiYenile", function () {
            const Toast = Swal.mixin({
                toast: true, position: 'top-end', showConfirmButton: false, timer: 3000,
                didOpen: (toast) => { toast.addEventListener('mouseenter', Swal.stopTimer); toast.addEventListener('mouseleave', Swal.resumeTimer); }
            });
            Toast.fire({ icon: 'success', title: 'Hesabınız güncellendi! 🔄' });
            setTimeout(() => { location.reload(); }, 1500);
        });
    }
        function removeFav(id) {
        Swal.fire({
            title: 'Favorilerden çıkarılsın mı?',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ff4444',
            cancelButtonColor: '#333',
            confirmButtonText: 'Evet, Çıkar',
            background: '#1e1e1e', color: '#fff'
        }).then((result) => {
            if (result.isConfirmed) {
                $.post('/Home/Favorile/' + id, { __RequestVerificationToken: getCSRFToken() }, function(res) {
                    if(res.success) {
                        $('#fav-card-' + id).fadeOut(300, function() { $(this).remove(); });
                        var countEl = $('.stat-item:nth-child(2) .stat-val');
                        var current = parseInt(countEl.text());
                        if(current > 0) countEl.text(current - 1);
                    }
                });
            }
        });
    }
</script>