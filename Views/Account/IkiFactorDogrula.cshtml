@{
    ViewData["Title"] = "Dogrulama";
    string email = ViewBag.Email as string ?? "";
}

<style>
    .twofa-wrapper {
        max-width: 460px;
        margin: 80px auto;
        text-align: center;
    }
    .twofa-card {
        background: #111;
        border: 1px solid #222;
        border-radius: 16px;
        padding: 40px 30px;
    }
    .twofa-icon {
        font-size: 3rem;
        color: #c6ff00;
        margin-bottom: 20px;
    }
    .twofa-card h2 {
        color: #fff;
        font-size: 1.4rem;
        margin-bottom: 10px;
    }
    .twofa-card p {
        color: #888;
        font-size: 0.9rem;
        margin-bottom: 30px;
    }
    .code-inputs {
        display: flex;
        gap: 10px;
        justify-content: center;
        margin-bottom: 25px;
    }
    .code-inputs input {
        width: 50px;
        height: 60px;
        text-align: center;
        font-size: 1.5rem;
        font-weight: bold;
        background: #000;
        border: 2px solid #333;
        border-radius: 12px;
        color: #c6ff00;
        outline: none;
        transition: 0.2s;
    }
    .code-inputs input:focus {
        border-color: #c6ff00;
        box-shadow: 0 0 10px rgba(198, 255, 0, 0.3);
    }
    .btn-verify {
        background: #c6ff00;
        color: #000;
        border: none;
        padding: 14px 40px;
        border-radius: 50px;
        font-weight: 800;
        font-size: 1rem;
        cursor: pointer;
        width: 100%;
        transition: 0.3s;
    }
    .btn-verify:hover {
        box-shadow: 0 0 20px rgba(198, 255, 0, 0.4);
        transform: translateY(-2px);
    }
    .btn-resend {
        margin-top: 12px;
        background: transparent;
        color: #c6ff00;
        border: 1px solid #3c5a00;
        padding: 11px 18px;
        border-radius: 50px;
        font-weight: 700;
        font-size: 0.9rem;
        cursor: pointer;
        width: 100%;
        transition: 0.2s;
    }
    .btn-resend:hover {
        background: rgba(198, 255, 0, 0.08);
    }
    .btn-resend:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }
    .twofa-info {
        margin-top: 12px;
        font-size: 0.82rem;
        color: #9aa38e;
        min-height: 20px;
    }
    .email-hint {
        color: #c6ff00;
        font-weight: bold;
    }
</style>

<div class="twofa-wrapper">
    <div class="twofa-card">
        <div class="twofa-icon">
            <i class="fa-solid fa-shield-halved"></i>
        </div>
        <h2>Iki Faktorlu Dogrulama</h2>
        <p>
            <span class="email-hint">@email</span> adresine gonderilen
            6 haneli dogrulama kodunu girin.
        </p>

        @if (ViewBag.Hata != null)
        {
            <div class="alert alert-danger" style="background:#2a1010; border-color:#ff4444; color:#ff6666; border-radius:8px; padding:10px; margin-bottom:20px;">
                <i class="fa-solid fa-circle-xmark"></i> @ViewBag.Hata
            </div>
        }

        <form method="post" asp-action="IkiFactorDogrula" id="tfaForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="email" value="@email" />
            <input type="hidden" name="kod" id="kodHidden" />

            <div class="code-inputs">
                <input type="text" maxlength="1" class="code-digit" data-index="0" inputmode="numeric" autofocus />
                <input type="text" maxlength="1" class="code-digit" data-index="1" inputmode="numeric" />
                <input type="text" maxlength="1" class="code-digit" data-index="2" inputmode="numeric" />
                <input type="text" maxlength="1" class="code-digit" data-index="3" inputmode="numeric" />
                <input type="text" maxlength="1" class="code-digit" data-index="4" inputmode="numeric" />
                <input type="text" maxlength="1" class="code-digit" data-index="5" inputmode="numeric" />
            </div>

            <button type="submit" class="btn-verify">DOGRULA</button>
            <button type="button" class="btn-resend" id="resendBtn">KODU TEKRAR GONDER</button>
            <div class="twofa-info" id="resendInfo"></div>
        </form>

        <p style="margin-top:20px; font-size:0.8rem; color:#555;">
            Kodu almadiysan <a href="/Account/Giris" style="color:#c6ff00;">tekrar giris yap</a>.
        </p>
    </div>
</div>

<script>
    const digits = document.querySelectorAll('.code-digit');
    digits.forEach((input, idx) => {
        input.addEventListener('input', function () {
            this.value = this.value.replace(/[^0-9]/g, '');
            if (this.value && idx < 5) digits[idx + 1].focus();
            updateHidden();
        });
        input.addEventListener('keydown', function (e) {
            if (e.key === 'Backspace' && !this.value && idx > 0) {
                digits[idx - 1].focus();
            }
        });
        input.addEventListener('paste', function (e) {
            e.preventDefault();
            var data = (e.clipboardData || window.clipboardData).getData('text').replace(/\D/g, '');
            for (var i = 0; i < 6 && i < data.length; i++) {
                digits[i].value = data[i];
            }
            if (data.length >= 6) digits[5].focus();
            updateHidden();
        });
    });

    function updateHidden() {
        var code = '';
        digits.forEach(d => code += d.value);
        document.getElementById('kodHidden').value = code;
    }

    document.getElementById('tfaForm').addEventListener('submit', function () {
        updateHidden();
    });

    const resendBtn = document.getElementById('resendBtn');
    const resendInfo = document.getElementById('resendInfo');
    let resendCountdown = 0;
    let resendTimer = null;

    function startResendCountdown(sec) {
        resendCountdown = sec;
        resendBtn.disabled = true;

        if (resendTimer) clearInterval(resendTimer);

        resendTimer = setInterval(function () {
            resendBtn.textContent = "TEKRAR GONDER (" + resendCountdown + "s)";
            resendInfo.textContent = "Yeni kod gonderimi icin bekleyin.";
            resendCountdown--;

            if (resendCountdown < 0) {
                clearInterval(resendTimer);
                resendBtn.disabled = false;
                resendBtn.textContent = "KODU TEKRAR GONDER";
                resendInfo.textContent = "";
            }
        }, 1000);
    }

    resendBtn.addEventListener('click', async function () {
        if (resendBtn.disabled) return;

        resendBtn.disabled = true;
        resendBtn.textContent = "GONDERILIYOR...";
        resendInfo.style.color = "#9aa38e";
        resendInfo.textContent = "";

        const fd = new FormData();
        fd.append('email', '@email');
        fd.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);

        try {
            const res = await fetch('/Account/IkiFactorKoduTekrarGonder', {
                method: 'POST',
                body: fd
            });
            const data = await res.json();

            if (data && data.success) {
                resendInfo.style.color = '#a9ff45';
                resendInfo.textContent = data.message || 'Yeni kod gonderildi.';
                startResendCountdown(data.waitSeconds || 60);
            } else {
                resendInfo.style.color = '#ff6b6b';
                resendInfo.textContent = (data && data.message) ? data.message : 'Kod tekrar gonderilemedi.';
                resendBtn.disabled = false;
                resendBtn.textContent = 'KODU TEKRAR GONDER';
            }
        } catch {
            resendInfo.style.color = '#ff6b6b';
            resendInfo.textContent = 'Sunucuya baglanirken hata olustu.';
            resendBtn.disabled = false;
            resendBtn.textContent = 'KODU TEKRAR GONDER';
        }
    });
</script>
