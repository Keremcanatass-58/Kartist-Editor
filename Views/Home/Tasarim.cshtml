        /* --- SPOTIFY PLAYER STİLLERİ --- */
        .music-wrapper {
            position: fixed;
            bottom: 30px;
            right: 250px;
            z-index: 9000;
            display: flex;
            flex-direction: column;
            align-items: flex-end;
