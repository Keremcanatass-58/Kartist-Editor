        async function generateMagicDesign() {
            const promptEl = document.getElementById("aiMagicPrompt");
            const btnEl = document.getElementById("aiMagicBtn");
            const prompt = (promptEl ? promptEl.value : "").trim();

            if (!prompt) {
                Swal.fire("Eksik bilgi", "Lütfen hayalindeki tasarımı kısaca anlat.", "warning");
                return;
            }

            // Düğme ve Input Yönetimi
            if (btnEl) btnEl.disabled = true;
            appendChatMessage("user", prompt);
            if (promptEl) promptEl.value = "";

            appendChatMessage("bot", "Tasarımını analiz ediyorum ve stüdyoyu hazırlıyorum...", true);

            const fd = new FormData();
            fd.append("prompt", prompt);
            fd.append("kategori", "genel");
            fd.append("style", activeAiStyle);
            fd.append("__RequestVerificationToken", getCSRFToken());

            let apiResponse;
            try {
                const res = await fetch("/Home/KartTasarimOner", {
                    method: "POST",
                    body: fd
                });
                apiResponse = await res.json();
            } catch (e) {
                console.error(e);
                removeTypingIndicator();
                appendChatMessage("bot", "Bağlantı hatası oluştu, sunucuya ulaşılamıyor.");
                if (btnEl) btnEl.disabled = false;
                Swal.fire("Bağlantı Hatası", "Sunucuya ulaşılamadı.", "error");
                return;
            }

            if (!apiResponse || !apiResponse.success) {
                console.error("AI Hatası:", apiResponse ? apiResponse.data : "Bilinmiyor");
                removeTypingIndicator();
                appendChatMessage("bot", "Maalesef tasarım hazırlanırken bir hata ile karşılaştım.");
                if (btnEl) btnEl.disabled = false;
                Swal.fire("AI Hatası", apiResponse ? apiResponse.data : "Sunucu hatası.", "error");
                return;
            }

            let aiData;
            try {
                let raw = apiResponse.data;

                if (typeof raw === "string") {
                    raw = raw.trim();

                    if (raw.startsWith("{") && raw.indexOf("\"renkPaleti\"") !== -1) {
                        aiData = JSON.parse(raw);
                    } else {
                        const outer = JSON.parse(raw);
                        const content = outer && outer.choices && outer.choices[0] && outer.choices[0].message && outer.choices[0].message.content;
                        if (!content) throw new Error("choices[0].message.content bulunamadı");
                        aiData = JSON.parse(content);
                    }
                } else if (typeof raw === "object" && raw !== null) {
                    if (raw.renkPaleti || raw.tema || raw.anaMetin) {
                        aiData = raw;
                    } else if (raw.choices && raw.choices[0] && raw.choices[0].message && raw.choices[0].message.content) {
                        aiData = JSON.parse(raw.choices[0].message.content);
                    } else {
                        throw new Error("Geçersiz AI response formatı");
                    }
                } else {
                    throw new Error("Beklenmeyen data.data tipi");
                }
            } catch (e) {
                console.error("AI response parse hatası:", e, apiResponse.data);
                Swal.fire("Veri Hatası", "AI tasarım verisi okunamadı.", "error");
                return;
            }

            function normalizeHex(color, fallback) {
                if (!color || typeof color !== "string") return fallback;
                const c = color.trim();
                if (/^#[0-9a-fA-F]{6}$/.test(c)) return c;
                if (/^#[0-9a-fA-F]{3}$/.test(c)) return "#" + c[1] + c[1] + c[2] + c[2] + c[3] + c[3];
                return fallback;
            }

                        function fitTextboxToHeight(tb, minSize, maxHeight) {
                while (tb.fontSize > minSize && tb.calcTextHeight() > maxHeight) {
                    tb.set("fontSize", tb.fontSize - 1);
                }
            }

            function cleanPromptText(text) {
                return (text || "")
                    .replace(/[“”„"]/g, "")
                    .replace(/\bkart(ı|i)?\s*üret\b/gi, "")
                    .replace(/\bkart(ı|i)?\s*yap\b/gi, "")
                    .replace(/\bkart(ı|i)?\s*tasarla\b/gi, "")
                    .replace(/\bdoğum günü\s*kart(ı|i)?\b/gi, "doğum günü")
                    .replace(/\bkart(ı|i)?\b/gi, "")
                    .replace(/\s{2,}/g, " ")
                    .trim();
            }

            function capitalizeTR(text) {
                if (!text) return "";
                const t = text.toString();
                return t.charAt(0).toLocaleUpperCase('tr-TR') + t.slice(1);
            }

            function buildTitle(kategoriSlug, name) {
                if (kategoriSlug.includes("dogum")) return "İyi ki Doğdun" + (name ? " " + name : "");
                if (kategoriSlug.includes("ask") || kategoriSlug.includes("sevgili")) return "Sana Özel";
                if (kategoriSlug.includes("tesekkur")) return "Teşekkür Ederim";
                if (kategoriSlug.includes("tebrik")) return "Tebrikler";
                if (kategoriSlug.includes("ozur")) return "Özür Dilerim";
                return "Özel Bir Mesaj";
            }

            function buildMessage(kategoriSlug, name, promptText) {
                if (kategoriSlug.includes("dogum")) return (name ? `İyi ki doğdun ${name}! Yeni yaşın sana sağlık, mutluluk ve başarı getirsin.` : "İyi ki doğdun! Yeni yaşın sana sağlık ve mutluluk getirsin.");
                if (kategoriSlug.includes("ask") || kategoriSlug.includes("sevgili")) return (name ? `${name}, iyi ki varsın. Seni çok seviyorum.` : "İyi ki varsın. Seni çok seviyorum.");
                if (kategoriSlug.includes("tesekkur")) return "Her şey için teşekkür ederim. İyi ki varsın.";
                if (kategoriSlug.includes("tebrik")) return "Başarınla gurur duyuyorum. Tebrik ederim!";
                if (kategoriSlug.includes("ozur")) return "Kalbini kırdıysam özür dilerim. Beni affet.";
                return promptText || (name ? `Senin için özel bir mesajım var, ${name}.` : "Sana özel bir kart hazırladım.");
            }
            function pickTheme(palette) {
                const p0 = normalizeHex(palette?.[0], "#0f172a");
                const p1 = normalizeHex(palette?.[1], "#22d3ee");
                const p2 = normalizeHex(palette?.[2], "#c6ff00");

                let theme = {
                    bg1: p0,
                    bg2: "#000000",
                    accent: p1,
                    soft: p2,
                    text: "#ffffff",
                    muted: "rgba(255,255,255,0.6)"
                };

                return theme;
            }
 
            const palette = Array.isArray(aiData.renkPaleti) ? aiData.renkPaleti : [];
            const theme = pickTheme(palette);
            const style = (aiData.layoutStyle || 'modern').toLowerCase();
            const yaziFontu = (aiData.yaziFontu || "Poppins");
            const finalTema = aiData.tema || "Özel Tasarım";
            const finalMetin = aiData.anaMetin || prompt;
            const emojiler = Array.isArray(aiData.emojiler) ? aiData.emojiler : [];

            loadGoogleFont(yaziFontu);
            loadGoogleFont('Inter');
            loadGoogleFont('Montserrat');
            loadGoogleFont('Playfair Display');
            canvas.clear();

            const cw = canvas.getWidth();
            const ch = canvas.getHeight();


            // AI GÖRSEL ARKA PLAN (Her zaman aktif)
            const useAiImage = true;
            let aiImageLoaded = false;

            if (useAiImage) {
                try {
                    removeTypingIndicator();
                    appendChatMessage("bot", "Yapay zeka gorselini senin icin hazirliyorum...", true);

                    const fdTranslate = new FormData();
                    fdTranslate.append("prompt", prompt);
                    fdTranslate.append("style", activeAiStyle);
                    fdTranslate.append("__RequestVerificationToken", getCSRFToken());

                    const translateResp = await fetch("/Home/TranslateImagePrompt", { method: "POST", body: fdTranslate });
                    const translateData = await translateResp.json();
                    let finalEngPrompt = `${prompt}, ${activeAiStyle} background, high quality, no text, no letters`;

                    if (translateData && translateData.success && translateData.prompt) {
                        finalEngPrompt = translateData.prompt;
                    }

                    const fdProxy = new FormData();
                    fdProxy.append("prompt", finalEngPrompt.trim());
                    fdProxy.append("__RequestVerificationToken", getCSRFToken());

                    const imgResp = await fetch("/Home/FetchAiImageBase64", { method: "POST", body: fdProxy });
                    const imgData = await imgResp.json();

                    if (imgData && imgData.success && imgData.dataUrl) {
                        await addImageLayerFromDataUrl(imgData.dataUrl, {
                            left: 0,
                            top: 0,
                            selectable: false,
                            evented: false,
                            fitMode: 'cover',
                            width: cw,
                            height: ch
                        });

                        canvas.add(new fabric.Rect({
                            left: 0, top: 0, width: cw, height: ch,
                            fill: 'rgba(0,0,0,0.3)', selectable: false, evented: false
                        }));

                        aiImageLoaded = true;

                        if (Array.isArray(imgData.warnings) && imgData.warnings.length > 0) {
                            console.warn('AI image warnings:', imgData.warnings);
                        }
                    } else {
                        throw new Error(imgData?.error || "Gorsel backend uzerinden indirilemedi");
                    }
                } catch (e) {
                    console.warn("AI gorsel yuklenemedi:", e);
                }
            }

            if (!aiImageLoaded) {
                const bg = new fabric.Rect({
                    left: 0, top: 0, width: cw, height: ch, selectable: false, evented: false,
                    fill: new fabric.Gradient({
                        type: "linear", coords: { x1: 0, y1: 0, x2: cw * 0.4, y2: ch },
                        colorStops: [
                            { offset: 0, color: theme.bg1 },
                            { offset: 0.5, color: theme.bg2 },
                            { offset: 1, color: theme.bg1 }
                        ]
                    })
                });
                canvas.add(bg);

                // Dekoratif ışık efektleri (Sadece resim yüklenemezse)
