        // --- GELİŞMİŞ ŞEKİL EKLEME SİSTEMİ (addShape) ---
        function addShape(type) {
            let shape;
            // Varsayılan renk siyah (floating bar'da bunu değiştirebilirler)
            const defaultColor = '#000000';

            // Tüm şekiller için ortak ayarlar
            const commonOpts = {
                left: 100,
                top: 100,
                fill: defaultColor,
                stroke: null,
                originX: 'center',
                originY: 'center',
                objectCaching: false // Keskin görünüm için
            };

            switch (type) {
                case 'rect':
                    shape = new fabric.Rect({ ...commonOpts, width: 100, height: 100 });
                    break;

                case 'circle':
                    shape = new fabric.Circle({ ...commonOpts, radius: 50 });
                    break;

                case 'triangle':
                    shape = new fabric.Triangle({ ...commonOpts, width: 100, height: 100 });
                    break;

                case 'line':
                    // Çizgi (İnce, uzun dikdörtgen)
                    shape = new fabric.Rect({
                        ...commonOpts,
                        width: 200, height: 6,
                        rx: 3, ry: 3, // Köşeleri hafif yuvarlak
                        fill: defaultColor
                    });
                    break;

                case 'star':
                    // 5 Köşeli Yıldız (Polygon)
                    shape = new fabric.Polygon([
                        { x: 0, y: -50 }, { x: 14, y: -20 }, { x: 47, y: -15 }, { x: 23, y: 7 },
                        { x: 29, y: 40 }, { x: 0, y: 25 }, { x: -29, y: 40 }, { x: -23, y: 7 },
                        { x: -47, y: -15 }, { x: -14, y: -20 }
                    ], { ...commonOpts, scaleX: 1.2, scaleY: 1.2 });
                    break;

                case 'heart':
                    // Kalp (SVG Path)
                    const heartPath = "M 272 63.1 c -50 0 -93.8 28.3 -118 70 c -24.2 -41.7 -68 -70 -118 -70 C -39.4 63.1 -64 246.7 154 414.9 L 154 414.9 l 0 0 l 0 0 l 0 0 L 154 414.9 L 372 233.1 C 516 134.1 426 63.1 272 63.1 z";
                    shape = new fabric.Path(heartPath, {
                        ...commonOpts, scaleX: 0.25, scaleY: 0.25 // Boyutu küçültüyoruz
                    });
                    break;

                case 'arrow':
                    // Ok (SVG Path)
                    const arrowPath = "M 50 0 L 100 50 L 75 50 L 75 100 L 25 100 L 25 50 L 0 50 Z";
                    shape = new fabric.Path(arrowPath, {
                        ...commonOpts,
                        scaleX: 1, scaleY: 1,
                        angle: 90 // Sağa çeviriyoruz
                    });
                    break;

                case 'bubble':
                    // Konuşma Balonu (SVG Path)
                    const bubblePath = "M 10 10 H 90 A 10 10 0 0 1 100 20 V 70 A 10 10 0 0 1 90 80 H 30 L 10 100 V 80 H 10 A 10 10 0 0 1 0 70 V 20 A 10 10 0 0 1 10 10 Z";
                    shape = new fabric.Path(bubblePath, {
                        ...commonOpts, scaleX: 1.5, scaleY: 1.5
                    });
                    break;

                case 'hexagon':
                    // Altıgen (Polygon)
                    shape = new fabric.Polygon([
                        { x: 25, y: 0 }, { x: 75, y: 0 }, { x: 100, y: 43 },
                        { x: 75, y: 86 }, { x: 25, y: 86 }, { x: 0, y: 43 }
                    ], { ...commonOpts, width: 100, height: 100 });
                    break;

                case 'pentagon':
                    // Beşgen (Polygon)
                    shape = new fabric.Polygon([
                        { x: 50, y: 0 }, { x: 100, y: 38 }, { x: 82, y: 100 },
                        { x: 18, y: 100 }, { x: 0, y: 38 }
                    ], { ...commonOpts, width: 100, height: 100 });
                    break;
            }

            if (shape) {
                canvas.add(shape);
                canvas.centerObject(shape); // Tuvalin ortasına koy
                canvas.setActiveObject(shape); // Seçili hale getir
                shape.setCoords(); // Koordinatları güncelle
                canvas.requestRenderAll();

                // Varsa geçmişe kaydet ve UI'ı güncelle
                if (typeof saveHistory === 'function') saveHistory();
                if (typeof updateUI === 'function') updateUI();
            }
        }



		function setBackgroundFromURL(u) {
			fabric.Image.fromURL(u, function (i) {
				if (!i) return;
				var s = Math.max(canvas.width / i.width, canvas.height / i.height);
				canvas.setBackgroundImage(i, canvas.renderAll.bind(canvas), {
					scaleX: s,
					scaleY: s,
					originX: 'center',
					originY: 'center',
					left: canvas.width / 2,
					top: canvas.height / 2
				});
				saveHistory();
			}, { crossOrigin: 'anonymous' });
		}

		function saveHistory() {
			if (!isHistoryProcessing && canvas) {
				var json = canvas.toJSON();
				historyStack.push(JSON.stringify(json));
