        /* MODALLER */
        #imgLoader, #bgImgLoader, #savedJsonData {
            display: none;
        }

        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            /* Buzlu Cam Efekti */
            background: rgba(0,0,0,0.85);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            z-index: 5000; /* En üstte dursun */
            align-items: center;
            justify-content: center;
            animation: fadeInModal 0.3s ease-out;
        }

        .modal-box {
            background: #1e1e1e;
            border: 1px solid #333; /* Hafif bir çerçeve */
            border-radius: 12px;
            padding: 30px;
            width: 420px;
            max-width: 90vw;
            text-align: center;
            position: relative;
            max-height: 80vh;
            overflow-y: auto;
            /* Neon Aksanlı Gölge */
            box-shadow: 0 15px 50px rgba(0,0,0,0.7), 0 0 25px rgba(198, 255, 0, 0.2);
            animation: slideUpModal 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
        }
            /* Modal Başlıkları */
            .modal-box h3 {
                font-family: 'Poppins', sans-serif;
                color: #c6ff00; /* Neon Başlık */
