                });
                canvas.add(panel);

                // Sol vurgu çizgisi
                canvas.add(new fabric.Rect({
                    left: cw * 0.06 + 18, top: ch * 0.08 + 20,
                    width: 4, height: ch * 0.84 - 40,
                    rx: 2, ry: 2, fill: theme.accent, opacity: 0.7,
                    selectable: false, evented: false
                }));

                const cLeft = cw * 0.06 + 40;
                const cWidth = cw * 0.88 - 60;

                canvas.add(new fabric.Textbox(finalTema, {
                    left: cLeft, top: ch * 0.18, width: cWidth,
                    fontFamily: yaziFontu, fontSize: 40, fontWeight: 800,
