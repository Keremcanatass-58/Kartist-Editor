        function fitCanvasToWorkspace() {
            if (!canvas) {
                setTimeout(fitCanvasToWorkspace, 100);
                return;
            }

            const container = document.querySelector('.canvas-container-shadow');
            const workspace = document.querySelector('.workspace');
            if (!container || !workspace) return;

            const baseWidth = 700;
            const baseHeight = 500;
            const padding = 40;

            const wsWidth = workspace.clientWidth;
            const wsHeight = workspace.clientHeight;
            const availWidth = wsWidth - padding;
            const availHeight = wsHeight - padding;

            let scale = Math.min(availWidth / baseWidth, availHeight / baseHeight);
            if (scale > 1) scale = 1;
            if (scale < 0.2) scale = 0.2;

            container.style.width = baseWidth + 'px';
            container.style.height = baseHeight + 'px';

            // Always center with absolute positioning to avoid drift
            container.style.setProperty('position', 'absolute', 'important');
            container.style.setProperty('left', '50%', 'important');
            container.style.setProperty('top', '50%', 'important');
            container.style.setProperty('margin', '0', 'important');
            container.style.setProperty('transform-origin', 'center center', 'important');
            container.style.setProperty('transform', `translate(-50%, -50%) scale(${scale})`, 'important');

            container.style.display = 'block';
            container.style.visibility = 'visible';

            const canvasEl = document.getElementById('c');
            if (canvasEl) {
                canvasEl.style.width = baseWidth + 'px';
                canvasEl.style.height = baseHeight + 'px';
            }

            if (canvas.setViewportTransform) {
                canvas.setViewportTransform([1, 0, 0, 1, 0, 0]);
            }
            if (canvas.setDimensions) {
                canvas.setDimensions({ width: baseWidth, height: baseHeight });
            }

            canvas.renderAll();
        }

        // Olay Dinleyicileri
        window.addEventListener('load', () => { setTimeout(fitCanvasToWorkspace, 100); });
        window.addEventListener('resize', fitCanvasToWorkspace);

		function applyPreset(type) {
			var obj = canvas.getActiveObject();
			if (!obj || obj.type !== 'image') {
				showToast('Lütfen bir resim seçin');
				return;
			}

			obj.filters = [];

			if (type === 'grayscale') obj.filters.push(new fabric.Image.filters.Grayscale());
			else if (type === 'sepia') obj.filters.push(new fabric.Image.filters.Sepia());
			else if (type === 'vintage') obj.filters.push(new fabric.Image.filters.Sepia(), new fabric.Image.filters.Noise({ noise: 100 }));
			else if (type === 'kodachrome') obj.filters.push(new fabric.Image.filters.Kodachrome());
			else if (type === 'technicolor') obj.filters.push(new fabric.Image.filters.Technicolor());

			obj.applyFilters();
			canvas.requestRenderAll();
			saveHistory();
		}

		function updateFilter(filterType, value) {
			var obj = canvas.getActiveObject();
			if (!obj || obj.type !== 'image') return;

			var filter;

			if (filterType === 'brightness') {
				filter = obj.filters.find(f => f.type === 'Brightness') || new fabric.Image.filters.Brightness();
				filter.brightness = parseFloat(value);
			} else if (filterType === 'contrast') {
				filter = obj.filters.find(f => f.type === 'Contrast') || new fabric.Image.filters.Contrast();
				filter.contrast = parseFloat(value);
			} else if (filterType === 'saturation') {
				filter = obj.filters.find(f => f.type === 'Saturation') || new fabric.Image.filters.Saturation();
				filter.saturation = parseFloat(value);
			}

			if (!obj.filters.includes(filter)) obj.filters.push(filter);

			document.getElementById('val-' + filterType).innerText = value;
			obj.applyFilters();
			canvas.requestRenderAll();
		}

