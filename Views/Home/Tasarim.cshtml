                }));

                // Alt dekoratif çizgi
                canvas.add(new fabric.Line([cw / 2 - 30, ch - 65, cw / 2 + 30, ch - 65], {
                    stroke: theme.accent, strokeWidth: 1, selectable: false, evented: false
                }));
