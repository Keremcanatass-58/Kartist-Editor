		}

		function undo() {
			if (historyStack.length > 0) {
				isHistoryProcessing = true;
				var last = historyStack.pop();
				canvas.loadFromJSON(last, () => {
					canvas.renderAll();
					isHistoryProcessing = false;
					updateLayers();
				});
			}
		}

