                // Üst aksanlı blok
                canvas.add(new fabric.Rect({
                    left: 0, top: 0, width: cw, height: 8,
                    fill: theme.accent, selectable: false, evented: false
                }));

                // Büyük emoji arka planı
                if (emojiler.length > 0) {
                    canvas.add(new fabric.Text(emojiler[0], {
