                }));

                canvas.add(new fabric.Textbox(finalMetin, {
                    left: 40, top: bodyTop + 5, width: cw - 100,
                    fontFamily: 'Montserrat', fontSize: 18, fontWeight: 400,
                    fill: theme.muted, lineHeight: 1.5
                }));
            }
            else if (style === 'elegant') {
                // Dış çerçeve
                canvas.add(new fabric.Rect({
                    left: 15, top: 15, width: cw - 30, height: ch - 30,
                    fill: 'transparent', stroke: theme.soft, strokeWidth: 1,
                    rx: 16, ry: 16, selectable: false, evented: false
                }));
                // İç çerçeve
                canvas.add(new fabric.Rect({
                    left: 25, top: 25, width: cw - 50, height: ch - 50,
                    fill: 'transparent', stroke: theme.soft, strokeWidth: 0.5,
                    rx: 12, ry: 12, selectable: false, evented: false,
                    opacity: 0.4
                }));

                // Üst dekoratif motif
                canvas.add(new fabric.Text("✦", {
                    left: cw / 2, top: 45, fontSize: 20, originX: 'center',
                    fill: theme.accent, selectable: false, evented: false
                }));

                canvas.add(new fabric.Textbox(finalTema, {
                    left: cw / 2, top: ch * 0.2, width: cw - 100, originX: 'center',
                    fontFamily: 'Playfair Display', fontSize: 40, fontStyle: 'italic',
                    fill: theme.soft, textAlign: 'center', lineHeight: 1.1
                }));

                // Ortadaki dekoratif ayraç çizgisi
                canvas.add(new fabric.Line([cw / 2 - 60, ch * 0.42, cw / 2 + 60, ch * 0.42], {
                    stroke: theme.accent, strokeWidth: 1, selectable: false, evented: false
                }));
                canvas.add(new fabric.Text("♦", {
                    left: cw / 2, top: ch * 0.42 - 8, fontSize: 14, originX: 'center',
                    fill: theme.accent, selectable: false, evented: false
                }));

                canvas.add(new fabric.Textbox(finalMetin, {
                    left: cw / 2, top: ch * 0.5, width: cw - 120, originX: 'center',
                    fontFamily: 'Playfair Display', fontSize: 17, fill: theme.text,
                    textAlign: 'center', lineHeight: 1.5
                }));
            }
            else {
                // MODERN - Panel tabanlı
                const panelFill = useAiImage ? 'rgba(8,8,16,0.4)' : 'rgba(8,8,16,0.9)';
                const panel = new fabric.Rect({
                    left: cw * 0.06, top: ch * 0.08, width: cw * 0.88, height: ch * 0.84,
                    fill: panelFill, rx: 24, ry: 24,
