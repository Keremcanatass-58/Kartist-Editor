                    left: -80, top: -60, radius: 200,
                    fill: theme.accent, opacity: 0.08, selectable: false, evented: false
                }));
                canvas.add(new fabric.Circle({
                    left: cw - 150, top: ch - 180, radius: 220,
                    fill: theme.soft, opacity: 0.06, selectable: false, evented: false
                }));
            }

            // LAYOUT STİLLERİ
            if (style === 'minimal') {
                // İnce çerçeve
                canvas.add(new fabric.Rect({
                    left: 40, top: 40, width: cw - 80, height: ch - 80,
                    fill: 'transparent', stroke: theme.accent, strokeWidth: 0.5,
                    rx: 4, ry: 4, selectable: false, evented: false
                }));

                // Üst dekoratif çizgi
                canvas.add(new fabric.Line([cw / 2 - 40, 65, cw / 2 + 40, 65], {
                    stroke: theme.accent, strokeWidth: 2, selectable: false, evented: false
