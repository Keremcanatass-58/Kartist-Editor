		// Mobil Menü Toggle
		function toggleMobileMenu() {
			const overlay = document.getElementById('mobileMenuOverlay');
			if (overlay) {
				overlay.classList.toggle('active');
				document.body.style.overflow = overlay.classList.contains('active') ? 'hidden' : '';
			}
		}

		// Overlay dışına tıklayınca kapat
		document.addEventListener('click', function(e) {
			const overlay = document.getElementById('mobileMenuOverlay');
			if (overlay && overlay.classList.contains('active')) {
				if (e.target === overlay) {
					toggleMobileMenu();
				}
			}
        });
        // --- METİN STİL FONKSİYONLARI ---
        // 1. Hizalama Fonksiyonu (Left, Center, Right)
        function setTextAlign(align) {
            var o = canvas.getActiveObject();
            // Seçili nesne yazı mı diye kontrol et
            if (o && o.type && (o.type === 'i-text' || o.type === 'text' || o.type === 'textbox')) {
                o.set('textAlign', align);
                canvas.requestRenderAll(); // Tuvali güncelle
                updateUI(); // Buton rengini güncelle
            }
        }

        // 2. Font Değiştirme Olayı
        document.getElementById('fontFamily').addEventListener('change', function () {
            var fontName = this.value;
            var o = canvas.getActiveObject();

            if (o && o.type && o.type.includes('text')) {
                // Fontu Google'dan yükle (eğer yüklenmediyse)
                loadGoogleFont(fontName);

                // Nesneye uygula
                o.set('fontFamily', fontName);
                canvas.requestRenderAll();
            }
        });

        // Google Font Yükleyici (Dinamik)
        function loadGoogleFont(fontName) {
            var id = 'font-' + fontName.replace(/\s+/g, '-').toLowerCase();
            if (!document.getElementById(id)) {
                var link = document.createElement('link');
                link.id = id;
                link.href = 'https://fonts.googleapis.com/css2?family=' + fontName.replace(/\s+/g, '+') + '&display=swap';
                link.rel = 'stylesheet';
                document.head.appendChild(link);
            }
        }
        // Altı Çizili Yap/Kaldır
        function toggleUnderline() {
            var o = canvas.getActiveObject();
            if (o && o.type && o.type.includes('text')) {
                // underline özelliği boolean (true/false) çalışır
                o.set('underline', !o.underline);
                canvas.requestRenderAll();
                updateUI(); // Butonun aktifliğini güncellemek için
            }
        }

        // Hizalama (Left, Center, Right)
        function setTextAlign(align) {
            var o = canvas.getActiveObject();
            if (o && o.type && o.type.includes('text')) {
                o.set('textAlign', align);
                canvas.requestRenderAll();
            }
        }

        // Genel Stil Değiştirici (Bold, Italic için)
        function toggleStyle(prop, val1, val2) {
            var o = canvas.getActiveObject();
            if (o && o.type && o.type.includes('text')) {
                o.set(prop, o[prop] === val1 ? val2 : val1);
                canvas.requestRenderAll();
                updateUI();
            }
        }

        // Gölge Aç/Kapa
        function toggleShadow() {
            var o = canvas.getActiveObject();
            if (!o) return;

            if (o.shadow) {
                // Gölge varsa kaldır
                o.set('shadow', null);
            } else {
                // Gölge yoksa siyah, hafif flu bir gölge ekle
                o.set('shadow', new fabric.Shadow({
                    color: 'rgba(0,0,0,0.6)',
                    blur: 10,
                    offsetX: 5,
                    offsetY: 5
                }));
            }
            canvas.requestRenderAll();
        }
        // --- TUVALDE HİZALAMA FONKSİYONU ---
        function alignObject(type) {
            var o = canvas.getActiveObject();
            if (!o) return;

            if (type === 'center') {
                // Hem yatay hem dikey ortalar
                canvas.centerObject(o);
            }
            else if (type === 'h') {
                // Sadece yatay ortalar (centerObjectH)
                canvas.centerObjectH(o);
            }
            else if (type === 'v') {
                // Sadece dikey ortalar (centerObjectV)
                canvas.centerObjectV(o);
            }

            // Koordinatları güncelle ve yeniden çiz
            o.setCoords();
            canvas.requestRenderAll();
            saveHistory(); // Geçmişe kaydet (Geri Al çalışsın diye)
        }
        // --- NESNE KONUMLANDIRMA SİSTEMİ ---
        function alignActiveObject(position) {
            var obj = canvas.getActiveObject();
            if (!obj) return;

            // Tuval Boyutları
            const canvasW = canvas.width;
            const canvasH = canvas.height;

            // Nesne Boyutları (Scale edilmiş haliyle)
            const objW = obj.getScaledWidth();
            const objH = obj.getScaledHeight();

            switch (position) {
                case 'left':
                    // En sola yapıştır
                    obj.set({ left: 0 });
                    break;

                case 'right':
                    // En sağa yapıştır (Tuval Genişliği - Nesne Genişliği)
                    obj.set({ left: canvasW - objW });
                    break;

                case 'center-h':
                    // Yatay Ortala
                    canvas.centerObjectH(obj);
                    break;

                case 'top':
                    // En tepeye yapıştır
                    obj.set({ top: 0 });
                    break;

                case 'bottom':
                    // En alta yapıştır (Tuval Yüksekliği - Nesne Yüksekliği)
                    obj.set({ top: canvasH - objH });
                    break;

                case 'center-v':
                    // Dikey Ortala
                    canvas.centerObjectV(obj);
                    break;
            }

            obj.setCoords(); // Tıklanabilir alanı güncelle
            canvas.requestRenderAll(); // Çizimi yenile
            saveHistory(); // Geri alabilmek için kaydet
        }
        // --- 1. ÇOKLU SİLME FONKSİYONU (GÜNCELLENDİ) ---
        function deleteObject() {
            var activeObjects = canvas.getActiveObjects(); // Seçili olan her şeyi al

            if (activeObjects.length) {
                // Hepsini döngüyle sil
                activeObjects.forEach(function (object) {
                    canvas.remove(object);
                });

                canvas.discardActiveObject(); // Seçimi kaldır
                canvas.requestRenderAll(); // Tuvali yenile
                saveHistory(); // Geçmişe kaydet
                updateUI();
            }
        }

        // --- 2. TUVALİ KOMPLE TEMİZLEME ---
        function clearCanvas() {
            Swal.fire({
                title: 'Emin misin?',
                text: "Tüm çalışman silinecek, bu işlem geri alınamaz!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#c6ff00',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Evet, temizle!',
                cancelButtonText: 'Hayır, vazgeç',
                background: '#1e1e1e',
                color: '#fff'
            }).then((result) => {
                if (result.isConfirmed) {
                    canvas.clear();
                    canvas.setBackgroundColor('#ffffff', canvas.renderAll.bind(canvas));
                    canvas.backgroundImage = null;
                    canvas.requestRenderAll();
                    
                    // Geçmişi temizle (Opsiyonel, ama temiz başlangıç iyidir)
                    historyStack = [];
                    saveHistory();
                    
                    updateLayers();
                    updateUI();
                    showToast("Tuval temizlendi");
                }
            });
        }

        // --- 3. KLAVYE KISAYOLLARI (CTRL+A ve DELETE) ---
        document.addEventListener('keydown', function (e) {

            // SİLME (Delete veya Backspace Tuşu)
            // Eğer bir input alanında yazı yazıyorsak çalışmasın
            if ((e.key === 'Delete' || e.key === 'Backspace') && e.target.tagName !== 'INPUT') {
                deleteObject();
            }

            // HEPSİNİ SEÇ (Ctrl + A)
            if ((e.ctrlKey || e.metaKey) && e.key === 'a' && e.target.tagName !== 'INPUT') {
                e.preventDefault(); // Sayfanın hepsini seçmesini engelle

                // Tuvaldeki tüm objeleri seçili hale getir
                var allObjects = canvas.getObjects();
                if (allObjects.length > 0) {
                    canvas.setActiveObject(new fabric.ActiveSelection(allObjects, {
                        canvas: canvas
                    }));
                    canvas.requestRenderAll();
                    updateUI(); // Barı aç
                }
            }
        });
    </script>
