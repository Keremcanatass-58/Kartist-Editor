    <script>
        // CANVAS FIX: Browser compatibility for Fabric.js
        if (typeof fabric !== 'undefined' || window.fabric) {
            const f = window.fabric || fabric;
            f.Text.prototype.textBaseline = 'middle';
            if (f.IText) f.IText.prototype.textBaseline = 'middle';
            if (f.Textbox) f.Textbox.prototype.textBaseline = 'middle';
            console.log("Kartist Editor v1.2.4 (Canvas Fix) Loaded 🧹");
        }
		function getCSRFToken() {
			return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
		}
        const editorPrefsKey = "kartist.editor.prefs";
        const defaultPrefs = { theme: "dark", toolsSide: "left" };

        function loadEditorPrefs() {
            try {
                const raw = localStorage.getItem(editorPrefsKey);
                if (!raw) return { ...defaultPrefs };
                const parsed = JSON.parse(raw);
                return { ...defaultPrefs, ...parsed };
            } catch {
                return { ...defaultPrefs };
            }
        }

        function saveEditorPrefs(prefs) {
            localStorage.setItem(editorPrefsKey, JSON.stringify(prefs));
        }

        function applyEditorPrefs(prefs) {
            const theme = prefs.theme || defaultPrefs.theme;
            const toolsSide = prefs.toolsSide || defaultPrefs.toolsSide;

            document.body.setAttribute("data-theme", theme);
            const mainBody = document.querySelector('.main-body');
            if (mainBody) {
                mainBody.classList.toggle('layout-tools-right', toolsSide === 'right');
            }

            updatePrefUI({ theme, toolsSide });
        }

        function updatePrefUI(prefs) {
            document.querySelectorAll('[data-theme-option]').forEach(btn => {
                btn.classList.toggle('active', btn.dataset.themeOption === prefs.theme);
            });

            document.querySelectorAll('[data-tools-side]').forEach(btn => {
                btn.classList.toggle('active', btn.dataset.toolsSide === prefs.toolsSide);
            });
        }

        function setPref(key, value) {
            const prefs = loadEditorPrefs();
            prefs[key] = value;
            saveEditorPrefs(prefs);
            applyEditorPrefs(prefs);
        }

        function initEditorPrefs() {
            const prefs = loadEditorPrefs();
            applyEditorPrefs(prefs);

            document.querySelectorAll('[data-theme-option]').forEach(btn => {
                btn.addEventListener('click', () => setPref('theme', btn.dataset.themeOption));
            });

            document.querySelectorAll('[data-tools-side]').forEach(btn => {
                btn.addEventListener('click', () => setPref('toolsSide', btn.dataset.toolsSide));
            });
        }

        function initSupportChat() {
            if (window.__supportChatInited) return;
            window.__supportChatInited = true;

            let lastMsgKey = '';
            let lastMsgAt = 0;
            const email = "@(ViewBag.UserEmail ?? string.Empty)";
            const toggle = document.getElementById('supportToggle');
            const panel = document.getElementById('supportPanel');
            const closeBtn = document.getElementById('supportClose');
            const sendBtn = document.getElementById('supportSend');
            const input = document.getElementById('supportInput');
            const list = document.getElementById('supportMessages');
            const badge = document.getElementById('supportBadge');

            if (!toggle || !panel || !sendBtn || !input || !list) return;

            let unread = 0;

            function setOpen(open) {
                panel.classList.toggle('open', open);
                if (open) {
                    unread = 0;
                    if (badge) badge.style.display = 'none';
                    setTimeout(() => list.scrollTop = list.scrollHeight, 50);
                }
            }

            function addMessage(payload) {
                const key = (payload?.from || "") + "|" + (payload?.email || "") + "|" + (payload?.message || "");
                const now = Date.now();
                if (key === lastMsgKey && (now - lastMsgAt) < 1500) return;
                lastMsgKey = key;
                lastMsgAt = now;
                if (!payload || !payload.message) return;
                const msg = document.createElement('div');
                msg.className = `support-msg ${payload.from === 'admin' ? 'from-admin' : 'from-user'}`;
                msg.textContent = payload.message;
                list.appendChild(msg);
                list.scrollTop = list.scrollHeight;
            }

            toggle.addEventListener('click', () => setOpen(!panel.classList.contains('open')));
            if (closeBtn) closeBtn.addEventListener('click', () => setOpen(false));

            const connection = new signalR.HubConnectionBuilder()
                .withUrl('/adminHub')
                .build();

            connection.on('SupportMessage', data => {
                addMessage(data);
                const isOpen = panel.classList.contains('open');
                if (!isOpen && data?.from === 'admin') {
                    unread += 1;
                    if (badge) {
                        badge.textContent = unread;
                        badge.style.display = 'inline-flex';
                    }
                }
            });

            connection.start().then(() => {
                if (email) connection.invoke('JoinUser', email);
            }).catch(err => console.error(err));

            function sendMessage() {
                const text = input.value.trim();
                if (!text) return;
                if (!email) {
                    Swal.fire({ icon: 'info', title: 'Giriş gerekli', text: 'Destek için giriş yapmalısın.' });
                    return;
                }
                input.value = '';
                connection.invoke('SendUserMessage', email, text).catch(err => console.error(err));
            }

            sendBtn.addEventListener('click', sendMessage);
            input.addEventListener('keydown', (e) => {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    sendMessage();
                }
            });
        }

        document.addEventListener('DOMContentLoaded', () => {
            initEditorPrefs();
            initSupportChat();
        });

        var canvas;
        let isBootstrapping = true;   // ilk load sırasında autosave kapalı
        let autosaveTimer = null;
        let autosaveInFlight = false;
        let autosaveDirty = false;

        function markDirty() {
            if (isBootstrapping) return;
            autosaveDirty = true;
            if (autosaveTimer) clearTimeout(autosaveTimer);
            autosaveTimer = setTimeout(runAutosave, 2500); // 2.5sn sonra kaydet
        }

        async function runAutosave() {
            if (!autosaveDirty) return;
            if (autosaveInFlight) return;

            autosaveDirty = false;
            autosaveInFlight = true;

            // Autosave’da önizlemeyi küçült → request şişmesin
            const d = await saveToCloud({ silent: true, previewMultiplier: 0.3 });

            autosaveInFlight = false;

            // Eğer autosave başarısızsa tekrar denemeyi kullanıcı değişikliğine bırakalım
            if (d?.success) {
                showToast("Otomatik kaydedildi");
            }
        }

		var _clipboard = null;
		var historyStack = [];
		var isHistoryProcessing = false;
		const googleFonts = ["Inter", "Space Grotesk", "Roboto", "Pacifico", "Dancing Script", "Permanent Marker"];

		function toggleMusic() {
			var box = document.getElementById('spotifyBox');
			if (box.style.display === 'block') {
				box.style.display = 'none';
			} else {
				box.style.display = 'block';
				box.classList.add('active');
			}
		}

		function loadSpotifyTrack() {
			var inputVal = document.getElementById('spotifyLinkInput').value.trim();
			var frame = document.getElementById('spotifyFrame');

			if (!inputVal) {
				Swal.fire({
					icon: 'info',
					title: 'Müzik Seç',
					text: 'Bir YouTube veya Spotify linki yapıştır.',
					background: '#1e1e1e',
					color: '#fff',
					confirmButtonColor: '#c6ff00'
				});
				return;
			}

			var ytMatch = inputVal.match(/(?:youtube\.com\/(?:[^\/]+\/.+\/|(?:v|e(?:mbed)?)\/|.*[?&]v=)|youtu\.be\/)([^"&?\/\s]{11})/);

			if (ytMatch && ytMatch[1]) {
				var ytUrl = "https://www.youtube.com/embed/" + ytMatch[1] + "?autoplay=1&playsinline=1&controls=0&modestbranding=1";
				frame.src = ytUrl;
				showMusicBox();
				return;
			}

			if (inputVal.includes("spotify.com")) {
				var embedUrl = inputVal;
				if (!inputVal.includes("/embed")) {
					embedUrl = inputVal.replace("spotify.com/", "spotify.com/embed/");
				}

				frame.src = embedUrl;
				showMusicBox();

				const Toast = Swal.mixin({
					toast: true,
					position: 'top-end',
					showConfirmButton: false,
					timer: 5000,
					background: '#1e1e1e',
					color: '#fff',
					iconColor: '#c6ff00'
				});
				Toast.fire({
					icon: 'info',
					title: 'Spotify Sadece 30sn Çalar',
					text: 'Kesintisiz müzik için YouTube linki kullanabilirsin.'
				});
				return;
			}

			Swal.fire({
				icon: 'error',
				title: 'Hata',
				text: 'Geçerli bir YouTube veya Spotify linki girmelisin.',
				background: '#1e1e1e',
				color: '#fff'
			});
		}

		function showMusicBox() {
			var box = document.getElementById('spotifyBox');
			if (box.style.display !== 'block') {
				box.style.display = 'block';
				box.classList.add('active');
			}
		}

		window.onload = function () {
			// Canvas element'inin yüklendiğinden emin ol
			const canvasEl = document.getElementById('c');
			if (!canvasEl) {
				console.error('Canvas element bulunamadı!');
				setTimeout(window.onload, 100);
				return;
			}

			canvas = new fabric.Canvas('c', {
				backgroundColor: '#fff',
				preserveObjectStacking: true,
				width: 700,
				height: 500
			});

			fabric.Object.prototype.set({
				transparentCorners: false,
				cornerColor: '#c6ff00',
				cornerStrokeColor: '#000',
				borderColor: '#c6ff00',
				cornerSize: 10,
				padding: 8,
				cornerStyle: 'circle'
			});

			var fs = document.getElementById('fontFamily');
			googleFonts.forEach(f => {
				var o = document.createElement('option');
				o.value = f;
				o.text = f;
				o.style.fontFamily = f;
				fs.appendChild(o);
			});

			// Canvas'ı ilk render et
			setTimeout(() => {
				canvas.renderAll();
			}, 100);

			var bgUrl = '@Model.ResimUrl';
			var saved = document.getElementById('savedJsonData').value;

			if (saved && saved.length > 10) {
				setTimeout(() => {
					canvas.loadFromJSON(saved, () => {
						canvas.renderAll();
						updateLayers();
                        fitCanvasToWorkspace();
                        isBootstrapping = false;
                    });

				}, 500);
			} else if (bgUrl) {
				setBackgroundFromURL(bgUrl);
				setTimeout(() => {
					canvas.renderAll();
					fitCanvasToWorkspace();
				}, 300);
			} else {
				// Boş canvas için de render et
				setTimeout(() => {
					canvas.renderAll();
					fitCanvasToWorkspace();
				}, 200);
			}

			canvas.on('selection:created', updateUI);
			canvas.on('selection:updated', updateUI);
			canvas.on('selection:cleared', updateUI);

            canvas.on('object:added', () => { saveHistory(); updateLayers(); markDirty(); });
            canvas.on('object:modified', () => { saveHistory(); updateLayers(); markDirty(); });
            canvas.on('object:removed', () => { saveHistory(); updateLayers(); markDirty(); });

            // Çizim yapan varsa iyi olur
            canvas.on('path:created', () => { saveHistory(); updateLayers(); markDirty(); });


			document.getElementById('bgColorPicker').addEventListener('input', function (e) {
				canvas.backgroundImage = null;
				canvas.setBackgroundColor(e.target.value, canvas.renderAll.bind(canvas));
				saveHistory();
			});

			document.getElementById('bgImgLoader').addEventListener('change', function (e) {
				var r = new FileReader();
				r.onload = function (ev) {
					setBackgroundFromURL(ev.target.result);
				};
				r.readAsDataURL(e.target.files[0]);
			});

			document.getElementById('imgLoader').onchange = function (e) {
				var r = new FileReader();
				r.onload = function (ev) {
					fabric.Image.fromURL(ev.target.result, function (i) {
						i.scaleToWidth(200);
