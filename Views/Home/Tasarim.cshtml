@model Kartist.Models.Sablon
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    @Html.AntiForgeryToken()
    <title>Kartist Editör</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Anton&family=Bangers&family=Cinzel:wght@400;700&family=Dancing+Script:wght@400;700&family=Great+Vibes&family=Inter:wght@300;400;700&family=Lato:wght@300;400;700&family=Lobster&family=Merriweather:ital,wght@0,300;0,700;1,300&family=Montserrat:wght@300;400;700&family=Nunito:wght@300;400;700&family=Open+Sans:wght@300;400;700&family=Oswald:wght@300;400;700&family=Pacifico&family=Permanent+Marker&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Poppins:wght@300;400;700&family=Raleway:wght@300;400;700&family=Righteous&family=Roboto:wght@300;400;700&family=Space+Grotesk:wght@300;400;700&family=Ubuntu:wght@300;400;700&display=swap&subset=latin,latin-ext" rel="stylesheet">

    <style>
        /* --- 1. TEMEL AYARLAR --- */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            outline: none;
        }

        /* ✅ YATAY KAYMAYI KES */
        html, body {
            height: 100%;
            width: 100%;
            overflow: hidden;
        }

        html {
            margin: 0;
            padding: 0;
            overflow-x: hidden;
        }

        body {
            background-color: #181818;
            color: white;
            font-family: 'Poppins', sans-serif;
            min-height: 100vh;
            width: 100%; /* 100vw'yi kaldırdık */
            overflow-x: hidden; /* yatay scroll kilit */
            display: flex;
            flex-direction: column;
        }



        /* HEADER */
        .header {
            height: 60px;
            background: #202020;
            border-bottom: 1px solid #333;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 20px;
            flex-shrink: 0;
            z-index: 20;
        }

        .logo {
            font-weight: 900;
            font-size: 1.2rem;
            color: white;
            text-decoration: none;
            letter-spacing: -0.5px;
        }

            .logo span {
                color: #c6ff00;
            }

        .header-right {
            display: flex;
            gap: 10px;
        }

        .btn-head {
            background: #3a3b3c;
            color: white;
            border: none;
            padding: 8px 15px;
            border-radius: 6px;
            font-weight: 600;
            font-size: 0.85rem;
            cursor: pointer;
            transition: 0.2s;
        }

            .btn-head:hover {
                background: #4e4f50;
            }

            .btn-head.primary {
                background: #c6ff00;
                color: black;
            }

                .btn-head.primary:hover {
                    filter: brightness(1.1);
                }

        /* Hamburger Menü Butonu */
        .hamburger-menu {
            display: none;
            background: transparent;
            border: none;
            color: white;
            font-size: 1.5rem;
            cursor: pointer;
            padding: 8px;
            z-index: 100;
        }

        /* Mobil Menü Overlay */
        .mobile-menu-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.9);
            z-index: 5000;
            align-items: center;
            justify-content: center;
        }

            .mobile-menu-overlay.active {
                display: flex;
            }

        .mobile-menu-content {
            background: #1e1e1e;
            width: 90%;
            max-width: 400px;
            border-radius: 15px;
            border: 1px solid #333;
            overflow: hidden;
        }

        .mobile-menu-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px;
            border-bottom: 1px solid #333;
        }

            .mobile-menu-header h3 {
                margin: 0;
                color: white;
                font-size: 1.2rem;
            }

        .close-mobile-menu {
            background: transparent;
            border: none;
            color: #aaa;
            font-size: 1.5rem;
            cursor: pointer;
            padding: 5px;
        }

            .close-mobile-menu:hover {
                color: white;
            }

        .mobile-menu-items {
            display: flex;
            flex-direction: column;
        }

        .mobile-menu-item {
            display: flex;
            align-items: center;
            gap: 15px;
            padding: 15px 20px;
            background: transparent;
            border: none;
            border-bottom: 1px solid #333;
            color: white;
            text-align: left;
            cursor: pointer;
            font-size: 1rem;
            transition: 0.2s;
            text-decoration: none;
        }

            .mobile-menu-item:hover {
                background: #2a2a2a;
                color: #c6ff00;
            }

            .mobile-menu-item.primary {
                background: #c6ff00;
                color: black;
                font-weight: bold;
            }

                .mobile-menu-item.primary:hover {
                    background: #b3e600;
                }

            .mobile-menu-item.danger {
                color: #ff4444;
            }

                .mobile-menu-item.danger:hover {
                    background: rgba(255, 68, 68, 0.1);
                }

            .mobile-menu-item i {
                width: 20px;
                text-align: center;
            }

        .main-body {
            /* ESKİ flex + absolute mantığını SİLİYORUZ */
            display: grid;
            grid-template-columns: 350px minmax(0, 1fr) 220px;
            grid-template-areas: "sidebar workspace layers";
            height: calc(100vh - 60px); /* header hariç */
            width: 100%;
            max-width: 100%;
            overflow: hidden;
            position: relative;
        }


        .main-body.layout-tools-right {
            grid-template-columns: minmax(0, 1fr) 220px 350px;
            grid-template-areas: "workspace layers sidebar";
        }

        .main-body.layout-tools-right .sidebar-container {
            border-right: none;
            border-left: 1px solid #333;
        }

        .main-body.layout-tools-right .icon-rail {
            border-right: none;
            border-left: 1px solid #333;
        }

        body[data-theme="neon"] {
            background: #0b0f14;
        }

        body[data-theme="neon"] .header {
            background: #121521;
            border-bottom: 1px solid rgba(198, 255, 0, 0.25);
            box-shadow: 0 0 18px rgba(198, 255, 0, 0.1);
        }

        body[data-theme="neon"] .sidebar-container,
        body[data-theme="neon"] .tools-panel {
            background: #141823;
        }

        body[data-theme="neon"] .icon-rail {
            background: #0f121a;
        }

        body[data-theme="neon"] .layers-panel {
            background: #121621;
            border-left: 1px solid rgba(198, 255, 0, 0.2);
        }

        body[data-theme="neon"] .panel-title {
            color: #d7ff5c;
        }

        body[data-theme="neon"] .btn-head.primary {
            box-shadow: 0 0 18px rgba(198, 255, 0, 0.25);
        }

        body[data-theme="neon"] .rail-item.active {
            box-shadow: inset 0 0 12px rgba(198, 255, 0, 0.2);
        }

        .setting-group {
            margin-top: 12px;
        }

        .setting-label {
            font-size: 0.75rem;
            color: #8a8a8a;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 8px;
        }

        .segmented {
            display: flex;
            gap: 8px;
        }

        .seg-btn {
            flex: 1;
            background: #2a2b2f;
            border: 1px solid #333;
            color: #ccc;
            padding: 8px 10px;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
        }

        .seg-btn.active {
            background: #c6ff00;
            color: #111;
            border-color: #c6ff00;
        }

        .seg-btn:hover {
            background: #3a3b40;
        }

        /* SOL MENÜ */
        .sidebar-container {
            grid-area: sidebar;
            display: flex;
            width: 350px;
            background: #242526;
            border-right: 1px solid #333;
            flex-shrink: 0;
            z-index: 10;
        }

        .icon-rail {
            width: 70px;
            background: #18191a;
            border-right: 1px solid #333;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding-top: 15px;
        }

        .rail-item {
            width: 50px;
            height: 50px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: #b0b3b8;
            cursor: pointer;
            border-radius: 8px;
            margin-bottom: 8px;
            transition: 0.2s;
        }

            .rail-item:hover {
                background: rgba(255,255,255,0.1);
                color: white;
            }

            .rail-item.active {
                background: rgba(198, 255, 0, 0.1);
                color: #c6ff00;
            }

            .rail-item i {
                font-size: 1.2rem;
                margin-bottom: 3px;
            }

            .rail-item span {
                font-size: 0.55rem;
                font-weight: 600;
            }

        .tools-panel {
            flex: 1;
            background: #242526;
            padding: 20px;
            max-height: 780px;
            overflow-y: scroll;
        }

        .tool-section {
            display: none;
            animation: fadeIn 0.3s;
        }

            .tool-section.active {
                display: block;
            }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(5px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .panel-title {
            font-size: 0.9rem;
            font-weight: 700;
            margin-bottom: 15px;
            border-bottom: 1px solid #333;
            padding-bottom: 10px;
            color: white;
        }

        /* ARAÇLAR GENEL */
        .tool-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
        }

        .tool-card {
            background: #3a3b3c;
            border-radius: 6px;
            padding: 15px;
            text-align: center;
            cursor: pointer;
            transition: 0.2s;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 5px;
            color: #e4e6eb;
        }

            .tool-card:hover {
                background: #4e4f50;
                transform: scale(1.02);
                color: #c6ff00;
            }

            .tool-card i {
                font-size: 1.4rem;
            }

        .sidebar-input {
            width: 100%;
            background: #121212;
            border: 1px solid #333;
            color: white;
            padding: 10px;
            border-radius: 6px;
            margin-bottom: 10px;
        }

        .sidebar-btn {
            width: 100%;
            background: #c6ff00;
            color: black;
            padding: 10px;
            border: none;
            border-radius: 6px;
            font-weight: bold;
            cursor: pointer;
            margin-bottom: 10px;
        }

        /* AI STUDIO STİLLERİ */
        .ai-style-grid {
            display: flex;
            gap: 10px;
            overflow-x: auto;
            padding-bottom: 10px;
            scrollbar-width: thin;
        }
        .ai-style-grid::-webkit-scrollbar {
            height: 4px;
        }
        .ai-style-grid::-webkit-scrollbar-thumb {
            background: #444;
            border-radius: 4px;
        }
        .ai-style-card {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 5px;
            cursor: pointer;
            min-width: 65px;
            transition: 0.2s;
            opacity: 0.6;
        }
        .ai-style-card:hover {
            opacity: 0.8;
            transform: translateY(-2px);
        }
        .ai-style-card.active {
            opacity: 1;
        }
        .ai-style-card.active .ai-style-icon {
            border: 2px solid #c6ff00;
            box-shadow: 0 0 10px rgba(198, 255, 0, 0.4);
        }
        .ai-style-icon {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            border: 2px solid transparent;
            transition: 0.2s;
        }
        .ai-style-card span {
            font-size: 0.65rem;
            color: #ccc;
            font-weight: 600;
            text-align: center;
        }
        .ai-style-card.active span {
            color: #c6ff00;
        }
        .ai-chat-window {
            background: #1a1a1a;
            border: 1px solid #333;
            border-radius: 8px;
            height: 180px;
            overflow-y: auto;
            padding: 10px;
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-bottom: 10px;
            box-shadow: inset 0 0 10px rgba(0,0,0,0.5);
        }
        .ai-chat-message {
            max-width: 85%;
            padding: 8px 12px;
            border-radius: 12px;
            font-size: 0.8rem;
            line-height: 1.4;
            word-wrap: break-word;
            animation: fadeIn 0.3s ease;
        }
        .ai-chat-message.bot {
            align-self: flex-start;
            background: #2a2a2a;
            color: #e0e0e0;
            border-bottom-left-radius: 2px;
        }
        .ai-chat-message.user {
            align-self: flex-end;
            background: #3b82f6;
            color: white;
            border-bottom-right-radius: 2px;
        }
        .ai-chat-message.typing {
            color: #aaa;
            font-style: italic;
        }
        .ai-input-area {
            display: flex;
            gap: 8px;
            background: #222;
            border: 1px solid #444;
            border-radius: 8px;
            padding: 5px;
            align-items: center;
        }
        .ai-input-area:focus-within {
            border-color: #c6ff00;
            box-shadow: 0 0 8px rgba(198, 255, 0, 0.2);
        }
        .ai-input-area textarea {
            flex: 1;
            background: transparent;
            border: none;
            color: white;
            resize: none;
            height: 45px;
            padding: 5px;
            font-size: 0.8rem;
            outline: none;
            font-family: inherit;
        }
        .ai-input-area textarea::placeholder {
            color: #666;
        }
        .ai-magic-btn {
            background: #c6ff00;
            color: black;
            border: none;
            width: 45px;
            height: 45px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 1.2rem;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: 0.2s;
        }
        .ai-magic-btn:hover {
            transform: scale(1.05);
            background: #b3e600;
        }
        .ai-magic-btn:disabled {
            background: #555;
            color: #888;
            cursor: not-allowed;
            transform: none;
        }

        /* --- YENİ FX (FİLTRE) STİLLERİ --- */
        .filter-grid {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 8px;
            margin-bottom: 20px;
        }

        .filter-item {
            background: #333;
            border-radius: 6px;
            cursor: pointer;
            overflow: hidden;
            position: relative;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.7rem;
            color: #ccc;
            border: 2px solid transparent;
        }

            .filter-item:hover {
                border-color: #c6ff00;
                color: white;
            }

            .filter-item.active {
                border-color: #c6ff00;
                color: #c6ff00;
            }

        .slider-group {
            margin-bottom: 15px;
        }

        .slider-label {
            display: flex;
            justify-content: space-between;
            font-size: 0.75rem;
            color: #aaa;
            margin-bottom: 5px;
            font-weight: 600;
        }

        .styled-slider {
            -webkit-appearance: none;
            width: 100%;
            height: 4px;
            background: #444;
            border-radius: 2px;
            outline: none;
        }

            .styled-slider::-webkit-slider-thumb {
                -webkit-appearance: none;
                width: 14px;
                height: 14px;
                border-radius: 50%;
                background: #c6ff00;
                cursor: pointer;
            }

        /* 1. Kapsayıcı (Workspace) */
        .workspace {
            grid-area: workspace; /* PC Grid sistemine sadık kal */
            position: relative !important;
            width: 100%;
            height: 100%;
            overflow: hidden !important;
            padding: 0 !important;
            margin: 0 !important;
            /* PC İÇİN: Flexbox ile otomatik ortala */
            display: flex !important;
            align-items: center !important;
            justify-content: center !important;
            background-color: #121212;
            background-image: radial-gradient(#333 1px, transparent 1px);
            background-size: 20px 20px;
        }

        /* 2. Tuval Kutusu (Varsayılan / PC Modu) */
        .canvas-container-shadow {
            /* PC'de akışa uysun, Flexbox onu zaten ortalar */
            position: relative !important;
            margin: auto !important;
            left: auto !important;
            top: auto !important;
            /* Dönüşüm merkezi her zaman orta olsun */
            transform-origin: center center !important;
            background: white;
            box-shadow: 0 0 50px rgba(0,0,0,0.5);
            border: 1px solid #333;
            display: block !important;
            visibility: visible !important;
        }

        /* --- YÜZEN BAR (FLOATING BAR) - PC İÇİN KİBAR AYAR --- */
        #floatingBar {
            position: absolute;
            top: 25px; /* Yukarıdan mesafe */
            left: 50%;
            transform: translateX(-50%);
            /* PC'de GENİŞLİK AYARI: İçerik kadar olsun, yayılmasın */
            width: 100%;
            max-width: 100%; /* Ekranın dışına taşmasın */
            /* Modern Görünüm (Glassmorphism) */
            background: rgba(35, 35, 35, 0.95);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 50px; /* Tam yuvarlak kenarlar (Daha kibar durur) */
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            padding: 5px 20px; /* İç boşluğu kıstık */
            display: flex;
            align-items: center;
            gap: 10px;
            z-index: 500;
            opacity: 0;
            pointer-events: none;
            transition: all 0.3s ease;
        }

            #floatingBar.active {
                opacity: 1;
                pointer-events: auto;
                top: 35px; /* Açılınca hafif aşağı kaysın */
            }

        /* Gruplar */
        .tool-group {
            display: flex;
            align-items: center;
            gap: 5px;
        }

        /* Buton Grupları (Hizalama vb.) */
        .btn-group {
            display: flex;
            align-items: center;
            background: rgba(255,255,255,0.05);
            border-radius: 20px; /* İç gruplar da yuvarlak olsun */
            padding: 2px 5px;
            gap: 2px;
        }

        /* Ayıraç Çizgisi */
        .divider {
            width: 1px;
            height: 20px;
            background: rgba(255,255,255,0.2);
            margin: 0 5px;
        }

        /* Buton Standartları */
        .icon-btn {
            width: 30px; /* Biraz küçülttük */
            height: 30px;
            border-radius: 50%; /* Tam yuvarlak buton */
            border: none;
            background: transparent;
            color: #ccc;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.85rem;
            transition: 0.2s;
        }

            .icon-btn:hover {
                background: rgba(255,255,255,0.2);
                color: white;
            }

            .icon-btn.danger:hover {
                background: rgba(255, 68, 68, 0.2);
                color: #ff4444;
            }

        /* Input ve Selectler */
        .bar-select, .bar-input {
            background: transparent;
            border: 1px solid rgba(255,255,255,0.2);
            color: white;
            padding: 0 5px;
            border-radius: 4px;
            font-size: 0.8rem;
            height: 28px;
            outline: none;
        }

            .bar-select option {
                background: #222;
            }

        .bar-input {
            width: 40px;
            text-align: center;
        }

        .color-wrapper {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            overflow: hidden;
            border: 1px solid #555;
            position: relative;
            cursor: pointer;
        }
        /* Kapsayıcı (Ok ikonunu yerleştirmek için) */
        .custom-select-wrapper {
            position: relative;
            display: flex;
            align-items: center;
            width: 140px; /* Genişliği sabitledik */
        }

        /* Select Kutusunun Kendisi */
        .modern-select {
            appearance: none; /* Standart görünümü kapat */
            -webkit-appearance: none;
            -moz-appearance: none;
            width: 100%;
            height: 32px;
            background-color: rgba(255, 255, 255, 0.05); /* Çok hafif şeffaf */
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 8px;
            color: #e0e0e0;
            font-family: 'Inter', sans-serif;
            font-size: 0.85rem;
            padding: 0 30px 0 10px; /* Sağdan boşluk bırak (ok için) */

            cursor: pointer;
            outline: none;
            transition: all 0.3s ease;
        }

            /* Hover ve Focus Durumları */
            .modern-select:hover {
                background-color: rgba(255, 255, 255, 0.1);
                border-color: rgba(255, 255, 255, 0.4);
            }

            .modern-select:focus {
                border-color: #c6ff00; /* Neon Sarı */
                box-shadow: 0 0 10px rgba(198, 255, 0, 0.2);
                color: #fff;
            }

        /* Sağdaki Ok İkonu (FontAwesome) */
        .select-arrow {
            position: absolute;
            right: 10px;
            font-size: 0.7rem;
            color: #aaa;
            pointer-events: none; /* Tıklamayı engelleme, arkadaki select'e geçsin */
            transition: 0.3s;
        }

        /* Menü açılınca ok dönsün (Focus hack) */
        .modern-select:focus + .select-arrow {
            transform: rotate(180deg);
            color: #c6ff00;
        }

        /* --- AÇILAN LİSTE (Dropdown Seçenekleri) --- */
        .modern-select option {
            background-color: #222; /* Koyu arka plan */
            color: #eee;
            padding: 10px;
        }

        .modern-select optgroup {
            color: #888;
            font-style: normal;
            font-weight: bold;
            background-color: #1a1a1a;
        }

        #colorInput {
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            cursor: pointer;
            border: none;
            padding: 0;
            margin: 0;
        }

        .slider-wrapper {
            display: flex;
            align-items: center;
            gap: 5px;
        }

        #opacitySlider {
            width: 50px;
            height: 4px;
            border-radius: 2px;
