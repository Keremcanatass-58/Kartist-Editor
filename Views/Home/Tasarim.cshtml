        function normalizeColorForInput(value, fallback = '#000000') {
            if (!value || typeof value !== 'string') return fallback;
            const color = value.trim().toLowerCase();
            if (/^#[0-9a-f]{6}$/.test(color)) return color;
            if (/^#[0-9a-f]{3}$/.test(color)) {
                return `#${color[1]}${color[1]}${color[2]}${color[2]}${color[3]}${color[3]}`;
            }
            const rgbMatch = color.match(/^rgba?\((\d+),\s*(\d+),\s*(\d+)/);
            if (rgbMatch) {
                const toHex = part => Math.max(0, Math.min(255, Number(part || 0))).toString(16).padStart(2, '0');
                return `#${toHex(rgbMatch[1])}${toHex(rgbMatch[2])}${toHex(rgbMatch[3])}`;
            }
            return fallback;
        }

        function updateUI() {
            var o = canvas.getActiveObject();
            var bar = document.getElementById('floatingBar');

            if (o) {
                bar.classList.add('active');

                // Renk & Opaklık
                if (o.fill && typeof o.fill === 'string') document.getElementById('colorInput').value = normalizeColorForInput(o.fill);
                document.getElementById('opacitySlider').value = o.opacity || 1;

                // Metin Kontrolleri
                var isText = o.type && o.type.includes('text');
                var textTools = document.getElementById('textTools');

                if (isText) {
                    textTools.style.display = 'flex';

                    // Değerleri Oku
                    document.getElementById('fontFamily').value = o.fontFamily || 'Inter';
                    document.getElementById('fontSize').value = o.fontSize || 40;

                    // --- BUTON RENKLERİNİ GÜNCELLE ---
                    const activeColor = '#c6ff00'; // Neon Sarı
                    const passiveColor = '#ccc';   // Gri

                    // Stil Butonları
                    document.getElementById('btnBold').style.color = (o.fontWeight === 'bold') ? activeColor : passiveColor;
                    document.getElementById('btnItalic').style.color = (o.fontStyle === 'italic') ? activeColor : passiveColor;
                    var btnUnderline = document.getElementById('btnUnderline');
                    if (btnUnderline) btnUnderline.style.color = (o.underline) ? activeColor : passiveColor;

                    // HİZALAMA BUTONLARI (Burası Önemli)
                    document.getElementById('alignLeft').style.color = (o.textAlign === 'left') ? activeColor : passiveColor;
                    document.getElementById('alignCenter').style.color = (o.textAlign === 'center') ? activeColor : passiveColor;
                    document.getElementById('alignRight').style.color = (o.textAlign === 'right') ? activeColor : passiveColor;

                    // Gölge
                    var btnShadow = document.getElementById('btnShadow');
                    if (btnShadow) btnShadow.style.color = (o.shadow) ? activeColor : passiveColor;

                }

                // AI Tools (Image Only)
                const isImage = o.type === 'image';
                const btnRemoveBg = document.getElementById('btnRemoveBg');
                if (btnRemoveBg) {
                    btnRemoveBg.style.display = isImage ? 'flex' : 'none';
                    const aiDivider = document.querySelector('.divider.ai-only');
