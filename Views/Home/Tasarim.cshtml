                font-weight: 800;
                margin-bottom: 20px;
                letter-spacing: -0.5px;
            }

        /* Kapatma Butonu (X) */
        .close-modal {
            position: absolute;
            top: 15px;
            right: 15px;
            cursor: pointer;
            color: #888;
            font-size: 1.5rem;
            transition: 0.2s;
        }

            .close-modal:hover {
                color: white;
                transform: rotate(90deg);
            }

        /* Modal İçi Input Alanları */
        .sidebar-input {
            width: 100%;
            background: #282828; /* Koyu input */
            border: 1px solid #444;
            color: white;
            padding: 12px;
            border-radius: 8px;
            margin-bottom: 15px;
            font-size: 1rem;
            transition: 0.2s;
        }

            .sidebar-input:focus {
                border-color: #c6ff00;
                box-shadow: 0 0 5px rgba(198, 255, 0, 0.5);
            }

        /* Modal İçi Birincil Buton */
        .sidebar-btn {
            width: 100%;
            background: #c6ff00; /* Neon Ana Renk */
