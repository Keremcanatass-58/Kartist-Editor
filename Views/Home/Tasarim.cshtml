        async function addImageLayerFromDataUrl(dataUrl, config = {}) {
            return new Promise((resolve, reject) => {
                fabric.Image.fromURL(dataUrl, function(img) {
                    if (!img) {
                        reject(new Error("Gorsel nesnesi olusturulamadi"));
                        return;
                    }

                    const opts = {
                        left: 0,
                        top: 0,
                        selectable: true,
                        evented: true,
                        fitMode: null,
                        width: null,
                        height: null,
                        opacity: 1,
                        ...config
                    };

                    if (opts.fitMode === 'cover' && opts.width && opts.height) {
                        const scale = Math.max(opts.width / img.width, opts.height / img.height);
                        img.set({ scaleX: scale, scaleY: scale });
                    }

                    img.set({
                        left: opts.left,
                        top: opts.top,
                        selectable: opts.selectable,
                        evented: opts.evented,
                        opacity: opts.opacity
                    });

                    canvas.add(img);
                    resolve(img);
                }, { crossOrigin: 'anonymous' });
            });
        }

        async function resizeBlobForBackgroundRemoval(blob, maxDimension = 1600) {
            if (!blob || blob.size <= 2 * 1024 * 1024) {
                return blob;
            }

            const bitmap = await createImageBitmap(blob);
            const ratio = Math.min(1, maxDimension / Math.max(bitmap.width, bitmap.height));
            if (ratio >= 1) {
                return blob;
            }

            const resizeCanvas = document.createElement('canvas');
            resizeCanvas.width = Math.round(bitmap.width * ratio);
            resizeCanvas.height = Math.round(bitmap.height * ratio);
            const ctx = resizeCanvas.getContext('2d', { alpha: true });
            ctx.drawImage(bitmap, 0, 0, resizeCanvas.width, resizeCanvas.height);

            return await new Promise(resolve => resizeCanvas.toBlob(result => resolve(result || blob), 'image/png', 0.92));
        }

        const backgroundRemovalService = {
            async getClientRemover() {
                let removeFn = window.imglyRemoveBackground ||
                    (window.imglyBackgroundRemoval ? (window.imglyBackgroundRemoval.removeBackground || window.imglyBackgroundRemoval) : null) ||
                    (window.imgly && window.imgly.backgroundRemoval ? window.imgly.backgroundRemoval.removeBackground : null);

                if (!removeFn) {
                    try {
                        await import('https://cdn.jsdelivr.net/npm/@@imgly/background-removal@1.5.5/+esm');
                    } catch (importError) {
                        console.warn('IMG.LY module import failed:', importError);
                    }

                    await new Promise(r => setTimeout(r, 1500));
                    removeFn = window.imglyRemoveBackground ||
                        (window.imglyBackgroundRemoval ? (window.imglyBackgroundRemoval.removeBackground || window.imglyBackgroundRemoval) : null) ||
                        (window.imgly && window.imgly.backgroundRemoval ? window.imgly.backgroundRemoval.removeBackground : null);
                }

                return removeFn;
            },
            async tryServerFallback(blob) {
                const fd = new FormData();
                fd.append('image', blob, 'selection.png');
                const csrf = getCSRFToken();
                if (csrf) fd.append('__RequestVerificationToken', csrf);

                const resp = await fetch('/Home/RemoveImageBackground', { method: 'POST', body: fd });
                return await resp.json();
            }
        };

        async function removeBackground() {
            const obj = canvas.getActiveObject();
            if (!obj || obj.type !== 'image') {
                showToast('Lutfen bir resim secin');
                return;
            }

            Swal.fire({
                title: 'Yapay Zeka Calisiyor...',
                text: 'Arka plan dekupe ediliyor. Buyuk gorseller otomatik optimize edilir.',
                allowOutsideClick: false,
                background: '#1e1e1e',
                color: '#fff',
                didOpen: () => { Swal.showLoading(); }
            });

            try {
                const removeFn = await backgroundRemovalService.getClientRemover();
                if (!removeFn) {
                    throw new Error('AI modulu henuz hazir degil. Lutfen birkac saniye sonra tekrar deneyin.');
                }

                const dataUrl = obj.toDataURL({ format: 'png' });
                const originalBlob = await fetch(dataUrl).then(res => res.blob());
                const optimizedBlob = await resizeBlobForBackgroundRemoval(originalBlob);
                const resultBlob = await removeFn(optimizedBlob, {
                    debug: false,
                    model: 'medium',
                    progress: (step, percent) => {
                        console.log(`BG Removal: ${step} ${Math.round(percent * 100)}%`);
                    }
                });

                const resultUrl = URL.createObjectURL(resultBlob);
                const newImg = await addImageLayerFromDataUrl(resultUrl, {
                    left: obj.left,
                    top: obj.top,
                    selectable: true,
                    evented: true,
                    opacity: obj.opacity ?? 1
                });

                newImg.set({
                    scaleX: obj.scaleX,
                    scaleY: obj.scaleY,
                    angle: obj.angle,
                    flipX: obj.flipX,
                    flipY: obj.flipY,
                    originX: obj.originX,
                    originY: obj.originY
                });

                canvas.remove(obj);
                canvas.setActiveObject(newImg);
                canvas.renderAll();
                saveHistory();
                markDirty();
                updateLayers();
                Swal.close();
                showToast('Arka plan basariyla silindi');
            } catch (error) {
                console.error('AI BG Removal Error:', error);

                let fallbackMessage = error.message || 'Arka plan silinirken bir teknik sorun olustu.';
                try {
                    const dataUrl = obj.toDataURL({ format: 'png' });
                    const originalBlob = await fetch(dataUrl).then(res => res.blob());
                    const fallbackResult = await backgroundRemovalService.tryServerFallback(originalBlob);
                    if (fallbackResult && fallbackResult.message) {
                        fallbackMessage = `${fallbackMessage} ${fallbackResult.message}`;
                    }
                } catch (fallbackError) {
                    console.warn('Server fallback unavailable:', fallbackError);
                }

                Swal.fire({
                    icon: 'error',
                    title: 'Hata',
                    text: fallbackMessage,
                    background: '#1e1e1e',
                    color: '#fff',
                    confirmButtonColor: '#ff4444'
                });
            }
        }
		async function saveToCloud(options = {}) {
            const opts = {
                silent: false,          // true ise toast daha az
                previewMultiplier: 0.5, // önizleme boyutu
                keepalive: false,       // beforeunload için
                ...options
            };

            try {
                const json = JSON.stringify(canvas.toJSON());

                const formData = new FormData();
                formData.append("sablonId", "@Model.Id");
                formData.append("jsonVerisi", json);

                const k = document.getElementById("designId")?.value;
                if (k && k !== "0") formData.append("kayitliId", k);

                canvas.discardActiveObject();
                canvas.renderAll();

                // Önizleme üret (manuelde 0.5, autosave’da 0.3 gibi düşüreceğiz)
                const preview = canvas.toDataURL({ format: 'png', multiplier: opts.previewMultiplier });
                formData.append("resimDataUrl", preview);

                // Token gerekiyorsa desteklesin (gerekmese de zararı yok)
                const csrf = getCSRFToken();
                if (csrf) formData.append("__RequestVerificationToken", csrf);

                const r = await fetch('/Home/TasarimiKaydet', {
                    method: 'POST',
                    body: formData,
                    keepalive: !!opts.keepalive
                });

                // JSON değilse bile kullanıcıya hata gösterelim
                const ct = (r.headers.get("content-type") || "").toLowerCase();
                let payload;

                if (ct.includes("application/json")) {
                    payload = await r.json();
                } else {
                    const txt = await r.text();
                    throw new Error(`Kaydetme hatası (HTTP ${r.status}). Sunucu JSON dönmedi.\n${txt?.slice(0, 200) || ""}`);
                }

                if (!r.ok || payload?.success === false) {
                    throw new Error(payload?.message || `Kaydedilemedi (HTTP ${r.status})`);
                }

                if (payload?.id) document.getElementById("designId").value = payload.id;

                if (!opts.silent) showToast(payload.message || "Kaydedildi");
                return payload;
            } catch (err) {
                console.error("saveToCloud error:", err);
                showToast("Kaydetme başarısız!");
                return { success: false, message: err?.message || "Kaydetme başarısız" };
            }
        }

