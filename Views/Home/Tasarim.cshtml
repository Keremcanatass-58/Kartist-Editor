        // --- PAYLAŞ BUTONU ---
        async function shareDesign() {
            // 1) Önce kaydet ve sonucu kontrol et
            const saved = await saveToCloud({ silent: true, previewMultiplier: 0.4 });
            if (!saved || saved.success === false) {
                const msg = saved?.message || "Kaydetme başarısız. Link oluşturulamıyor.";
                showToast(msg);
                if (window.Swal) Swal.fire("Kaydetme Başarısız", msg, "error");
                return;
            }

            // designId'yi DOM’dan değil, mümkünse response’tan al (en sağlamı)
            let kid = saved.id || document.getElementById("designId")?.value;
            if (!kid || kid === "0") {
                showToast("Önce kaydedilmeli.");
                return;
            }

            const { value: formValues, isConfirmed } = await Swal.fire({
                title: 'Kartı Özelleştir ✨',
                html: `
                  <div style="text-align:left; margin-bottom:10px; color:#aaa; font-size:0.9rem;">1. Tema Seç</div>
                  <select id="swal-category" class="swal2-input" style="margin:0 0 20px 0; background:#222; color:white; border:1px solid #444;">
                    <option value="Standart">Standart (Zarf)</option>
                    <option value="DogumGunu">🎂 Doğum Günü</option>
                    <option value="Dugun">💍 Düğün / Davet</option>
                    <option value="Ask">❤️ Aşk / Sevgili</option>
                    <option value="Parti">🎉 Parti / Eğlence</option>
                  </select>

                  <div style="text-align:left; margin-bottom:10px; color:#aaa; font-size:0.9rem;">2. Müzik Ekle (İsteğe Bağlı)</div>
                  <div style="display:flex; gap:10px;">
                    <input type="file" id="swal-music" class="swal2-file" accept="audio/*" style="background:#222; color:#ccc; border:1px solid #444;">
                  </div>
                  <div id="upload-status" style="font-size:0.8rem; color:#c6ff00; margin-top:5px; height:20px;"></div>
                `,
                background: '#1e1e1e',
                color: '#fff',
                showCancelButton: true,
                confirmButtonText: 'LİNKİ OLUŞTUR 🔗',
                confirmButtonColor: '#c6ff00',
                cancelButtonText: 'Vazgeç',
                cancelButtonColor: '#333',
                preConfirm: async () => {
                    const cat = document.getElementById('swal-category')?.value || "Standart";
                    const fileInput = document.getElementById('swal-music');
                    let musicUrl = "";

                    if (fileInput?.files?.length > 0) {
                        document.getElementById('upload-status').innerText = "Müzik yükleniyor...";
                        const fd = new FormData();
                        fd.append("muzikDosyasi", fileInput.files[0]);

                        const csrf = getCSRFToken();
                        if (csrf) fd.append("__RequestVerificationToken", csrf);

                        try {
                            const resp = await fetch('/Home/MuzikYukle', { method: 'POST', body: fd });
                            const ct = (resp.headers.get("content-type") || "").toLowerCase();

                            if (!ct.includes("application/json")) {
                                const t = await resp.text();
                                Swal.showValidationMessage(`Müzik yükleme hatası (HTTP ${resp.status}). ${t?.slice(0, 150) || ""}`);
                                return false;
                            }

                            const resJson = await resp.json();
                            if (resp.ok && resJson.success) musicUrl = resJson.url;
                            else {
                                Swal.showValidationMessage(resJson.message || "Yükleme hatası");
                                return false;
                            }
                        } catch (e) {
                            Swal.showValidationMessage("Yükleme hatası!");
                            return false;
                        }
                    }

                    return { category: cat, music: musicUrl };
                }
            });

            if (!isConfirmed || !formValues) return;

            // 2) Link oluştur
            try {
                const fd = new FormData();
                fd.append("kayitId", kid);
                fd.append("kategori", formValues.category);
                fd.append("muzikUrl", formValues.music || "");

                const csrf = getCSRFToken();
                if (csrf) fd.append("__RequestVerificationToken", csrf);

                const resp = await fetch('/Home/LinkOlustur', { method: 'POST', body: fd });
                const ct = (resp.headers.get("content-type") || "").toLowerCase();

                if (!ct.includes("application/json")) {
                    const t = await resp.text();
                    throw new Error(`Link oluşturma hatası (HTTP ${resp.status}). Sunucu JSON dönmedi. ${t?.slice(0, 200) || ""}`);
                }

                const d = await resp.json();

                if (!resp.ok || !d.success) {
                    throw new Error(d.message || `Link oluşturulamadı (HTTP ${resp.status})`);
                }

                if (typeof confetti === "function") {
                    confetti({ particleCount: 180, spread: 70, origin: { y: 0.6 } });
                }

                // Clipboard bazı ortamlarda engellenebilir; başarısızsa yine de linki gösteriyoruz
                try { await navigator.clipboard.writeText(d.link); } catch { }

                Swal.fire({
                    title: 'HAZIR! 🚀',
                    html: `<input value="${d.link}" style="width:100%; padding:10px; background:#222; color:#c6ff00; border:1px solid #444; border-radius:5px; text-align:center;" readonly>`,
                    icon: 'success',
                    background: '#1e1e1e',
                    color: '#fff',
                    confirmButtonColor: '#c6ff00',
                    confirmButtonText: 'Tamam'
                });

            } catch (err) {
                console.error("LinkOlustur error:", err);
                showToast(err.message || "Link oluşturma başarısız!");
                Swal.fire("Hata", err.message || "Link oluşturma başarısız!", "error");
            }
        }


		function copyLinkManually() {
			var copyText = document.getElementById("shareLinkInput");
			if (!copyText) return;
			copyText.select();
			navigator.clipboard.writeText(copyText.value);
			event.target.innerText = "OK!";
			setTimeout(() => { event.target.innerText = "KOPYALA"; }, 2000);
		}

