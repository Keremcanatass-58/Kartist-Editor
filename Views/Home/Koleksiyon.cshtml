@{
    ViewData["Title"] = "Koleksiyon";
    var varsayilanlar = ViewBag.Varsayilanlar as List<Kartist.Models.Sablon>;
    var kullaniciTasarimlari = ViewBag.KullaniciTasarimlari as List<Kartist.Models.Sablon>;
    var pageSize = ViewBag.PageSize == null ? 24 : (int)ViewBag.PageSize;
}
@functions {
    public string SafeResim(string url)
    {
        if (string.IsNullOrEmpty(url)) return "/img/default-design.svg";
        if (url.StartsWith("http")) return url;
        if (url.StartsWith("data:")) return url;
        if (url.StartsWith("blob:")) return url;
        if (url.StartsWith("/")) return url;
        if (!url.Contains("/")) return "/uploads/market/" + url;
        return "/" + url;
    }
}

<style>
    /* --- KOLEKSİYON ÖZEL STİLİ --- */
    .collection-header { text-align: center; padding: 50px 0; background: radial-gradient(circle, #222 0%, #0a0a0f 100%); margin-bottom: 30px; border-bottom: 1px solid #333; }
    .collection-title { font-family: 'Space Grotesk', sans-serif; font-size: 3rem; font-weight: 800; color: white; }
    .collection-title span { color: #c6ff00; }

    /* SEKMELER */
    .tab-container { display: flex; justify-content: center; gap: 20px; margin-bottom: 40px; }
    .tab-btn {
        background: transparent; border: 2px solid #333; color: #888;
        padding: 15px 40px; font-size: 1.1rem; font-weight: bold; border-radius: 50px;
        cursor: pointer; transition: 0.3s;
    }
    .tab-btn:hover { border-color: #c6ff00; color: white; }
    .tab-btn.active { background: #c6ff00; color: black; border-color: #c6ff00; box-shadow: 0 0 20px rgba(198, 255, 0, 0.4); }

    /* GRID & KARTLAR (Ana sayfayla uyumlu) */
    .art-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 30px; padding: 0 20px; }
    .art-card { background: #161616; border-radius: 16px; overflow: hidden; position: relative; transition: 0.3s; border: 1px solid #222; }
    .art-card:hover { transform: translateY(-10px); border-color: #c6ff00; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
    .art-img { width: 100%; height: 350px; object-fit: cover; }
    .price-badge { position: absolute; top: 15px; right: 15px; background: #c6ff00; color: black; padding: 5px 12px; border-radius: 20px; font-weight: 800; font-size: 0.9rem; z-index: 10; }

    .fav-btn {
        position: absolute; top: 15px; left: 15px; width: 35px; height: 35px; border-radius: 50%;
        background: rgba(0,0,0,0.5); border: 1px solid rgba(255,255,255,0.2); color: #ccc;
        display: flex; align-items: center; justify-content: center; cursor: pointer; z-index: 20; transition: 0.3s;
    }
    .fav-btn.active { color: #ff0055; border-color: #ff0055; background: rgba(255,0,85,0.1); }

    .card-overlay { position: absolute; bottom: 0; left: 0; width: 100%; background: linear-gradient(to top, #000 10%, transparent); padding: 20px; }
    .card-title { font-size: 1.2rem; font-weight: 700; color: white; margin-bottom: 5px; }
    .card-cat { font-size: 0.8rem; color: #aaa; text-transform: uppercase; letter-spacing: 1px; }
    .btn-edit-card { background: rgba(255,255,255,0.1); color: white; padding: 10px; border-radius: 8px; margin-top: 10px; display: block; text-align: center; text-decoration: none; font-weight: bold; backdrop-filter: blur(5px); border: 1px solid rgba(255,255,255,0.1); transition: 0.2s; }
    .btn-edit-card:hover { background: #c6ff00; color: black; border-color: #c6ff00; }

    .hidden-section { display: none; animation: fadeIn 0.5s; }
    .load-more-wrap { text-align:center; margin: 30px 0 10px 0; }
    .load-more-btn {
        background: #111; color:#c6ff00; border:1px solid #2a2a2a; padding:12px 26px; border-radius: 999px;
        font-weight:700; letter-spacing:0.5px; cursor:pointer; transition: 0.2s;
    }
    .load-more-btn:hover { border-color:#c6ff00; box-shadow: 0 0 18px rgba(198,255,0,0.2); }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
</style>

<div class="collection-header">
    <h1 class="collection-title">TÜM <span>KOLEKSİYON</span></h1>
    <p style="color:#888; margin-top:10px;">İster bizden seç, ister topluluktan keşfet.</p>
</div>

<div class="container mb-5">

    <div class="tab-container">
        <button class="tab-btn active" onclick="switchSection('default')">👑 Varsayılan Tasarımlar</button>
        <button class="tab-btn" onclick="switchSection('user')">👤 Kullanıcı Tasarımları</button>
    </div>

    <div id="sec-default" class="art-grid">
        @foreach (var kart in varsayilanlar)
        {
                <div class="art-card">
                    <img src="@SafeResim(kart.ResimUrl)" class="art-img" loading="lazy" onerror="this.onerror=null;this.src='/img/default-design.svg';">
                    <div class="price-badge">@kart.Fiyat.ToString("0.##") ₺</div>
                    <button onclick="toggleFav(this, @kart.Id)" class="fav-btn @(kart.IsFavori ? "active" : "")"><i class="fa-solid fa-heart"></i></button>
                    <div class="card-overlay">
                        <h4 class="card-title">@kart.Baslik</h4>
                        <span class="card-cat">@kart.Kategori</span>
                    @if (User.Identity.IsAuthenticated)
                    {
                        <a href="/Home/Tasarim/@kart.Id" class="btn-edit-card">TASARLA <i class="fa-solid fa-pen-nib"></i></a>
                    }
                    else
                    {
                        <button onclick="uyariVer()" class="btn-edit-card" style="width:100%; border:none;">TASARLA <i class="fa-solid fa-lock"></i></button>
                    }
                    </div>
                </div>
        }
    </div>
    <div class="load-more-wrap" id="load-more-default-wrap">
        <button class="load-more-btn" id="load-more-default" onclick="loadMore('default')">DAHA FAZLA</button>
    </div>

    <div id="sec-user" class="art-grid hidden-section">
        @if (kullaniciTasarimlari.Count == 0)
        {
                <div style="grid-column: 1/-1; text-align:center; padding:50px; color:#666;">
                    <i class="fa-solid fa-ghost" style="font-size:3rem; margin-bottom:20px;"></i>
                    <p>Henüz kullanıcılar tarafından yüklenen bir tasarım yok.</p>
                    <a href="/Account/Profil" class="btn btn-outline-light btn-sm mt-3">İlk Sen Yükle!</a>
                </div>
        }
        else
        {
            @foreach (var kart in kullaniciTasarimlari)
            {
                        <div class="art-card" style="border-color:#333;">
                            <img src="@SafeResim(kart.ResimUrl)" class="art-img" loading="lazy" onerror="this.onerror=null;this.src='/img/default-design.svg';">
                            <div class="price-badge" style="background:#ff4081; color:white;">@kart.Fiyat.ToString("0.##") ₺</div>
                            <button onclick="toggleFav(this, @kart.Id)" class="fav-btn @(kart.IsFavori ? "active" : "")"><i class="fa-solid fa-heart"></i></button>
                            <div class="card-overlay">
                                <h4 class="card-title">@kart.Baslik</h4>
                                <span class="card-cat text-warning">⭐ Kullanıcı Tasarımı</span>
                                <a href="/Home/Tasarim/@kart.Id" class="btn-edit-card">SATIN AL & DÜZENLE</a>
                            </div>
                        </div>
            }
        }
    </div>
    <div class="load-more-wrap" id="load-more-user-wrap" style="display:none;">
        <button class="load-more-btn" id="load-more-user" onclick="loadMore('user')">DAHA FAZLA</button>
    </div>

</div>

<script>
    const pageSize = @pageSize;
    const isAuth = @User.Identity.IsAuthenticated.ToString().ToLower();
    let defaultOffset = @pageSize;
    let userOffset = @pageSize;

    function switchSection(sec) {
        // Butonları ayarla
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        event.target.classList.add('active');

        // İçerikleri gizle/göster
        document.getElementById('sec-default').style.display = 'none';
        document.getElementById('sec-user').style.display = 'none';

        document.getElementById('sec-' + sec).style.display = 'grid';
        document.getElementById('sec-' + sec).classList.remove('hidden-section'); // Animasyonu tetikle

        // load more butonlarını göster/gizle
        document.getElementById('load-more-default-wrap').style.display = (sec === 'default') ? 'block' : 'none';
        document.getElementById('load-more-user-wrap').style.display = (sec === 'user') ? 'block' : 'none';
    }

    // Favori Fonksiyonu (Index'tekiyle aynı mantık)
    function toggleFav(btn, id) {
        btn.style.transform = "scale(0.8)"; setTimeout(() => btn.style.transform = "scale(1)", 150);
        var fd = new FormData();
        fd.append("__RequestVerificationToken", document.querySelector('input[name="__RequestVerificationToken"]')?.value || '');
        fetch('/Home/Favorile/' + id, { method: 'POST', body: fd }).then(r => r.json()).then(d => {
            if (d.success) { d.isFav ? btn.classList.add('active') : btn.classList.remove('active'); }
            else { Swal.fire({ icon: 'info', title: 'Giriş Yap', text: 'Favorilemek için giriş yapmalısın.', background: '#1e1e1e', color: '#fff', confirmButtonColor: '#c6ff00' }); }
        });
    }
    function uyariVer() {
        Swal.fire({
            title: 'Giriş Yapmalısın',
            text: "Tasarım yapmak için lütfen önce hesabına giriş yap.",
            icon: 'warning',
            confirmButtonText: 'Giriş Yap',
            confirmButtonColor: '#c6ff00',
            background: '#1e1e1e',
            color: '#fff'
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = "/Account/Giris"; // Giriş linkin neyse onu yaz
            }
        });
    }
    function buildCard(item, type) {
        const id = item.id || item.Id;
        const baslik = item.baslik || item.Baslik || "Kart";
        const resim = (item.resimUrl || item.ResimUrl || "/img/default-design.svg");
        const fiyat = item.fiyat || item.Fiyat || 0;
        const isFav = (item.isFavori || item.IsFavori) ? "active" : "";
        const actionHtml = isAuth
            ? "<a href=\"/Home/Tasarim/" + id + "\" class=\"btn-edit-card\">TASARLA <i class=\"fa-solid fa-pen-nib\"></i></a>"
            : "<button onclick=\"uyariVer()\" class=\"btn-edit-card\" style=\"width:100%; border:none;\">TASARLA <i class=\"fa-solid fa-lock\"></i></button>";

        if (type === "user") {
            return `
                <div class="art-card" style="border-color:#333;">
                    <img src="${resim}" class="art-img" loading="lazy" onerror="this.onerror=null;this.src='/img/default-design.svg';">
                    <div class="price-badge" style="background:#ff4081; color:white;">${Number(fiyat).toFixed(2).replace(/\.00$/, '')} ₺</div>
                    <button onclick="toggleFav(this, ${id})" class="fav-btn ${isFav}"><i class="fa-solid fa-heart"></i></button>
                    <div class="card-overlay">
                        <h4 class="card-title">${baslik}</h4>
                        <span class="card-cat text-warning">⭐ Kullanıcı Tasarımı</span>
                        <a href="/Home/Tasarim/${id}" class="btn-edit-card">SATIN AL & DÜZENLE</a>
                    </div>
                </div>`;
        }

        return `
            <div class="art-card">
                <img src="${resim}" class="art-img" loading="lazy" onerror="this.onerror=null;this.src='/img/default-design.svg';">
                <div class="price-badge">${Number(fiyat).toFixed(2).replace(/\.00$/, '')} ₺</div>
                <button onclick="toggleFav(this, ${id})" class="fav-btn ${isFav}"><i class="fa-solid fa-heart"></i></button>
                <div class="card-overlay">
                    <h4 class="card-title">${baslik}</h4>
                    <span class="card-cat">${item.kategori || item.Kategori || ""}</span>
                    ${actionHtml}
                </div>
            </div>`;
    }

    function loadMore(type) {
        const offset = type === "user" ? userOffset : defaultOffset;
        const btn = document.getElementById(type === "user" ? "load-more-user" : "load-more-default");
        btn.disabled = true;
        btn.textContent = "YÜKLENİYOR...";

        fetch(`/Home/KoleksiyonListe?type=${type}&offset=${offset}&take=${pageSize}`)
            .then(r => r.json())
            .then(d => {
                if (!d || !d.success) return;
                const items = d.items || [];
                if (items.length === 0) {
                    btn.textContent = "BİTTİ";
                    btn.disabled = true;
                    return;
                }
                const grid = document.getElementById(type === "user" ? "sec-user" : "sec-default");
                items.forEach(it => grid.insertAdjacentHTML("beforeend", buildCard(it, type)));

                if (type === "user") userOffset += items.length;
                else defaultOffset += items.length;

                if (items.length < pageSize) {
                    btn.textContent = "BİTTİ";
                    btn.disabled = true;
                } else {
                    btn.textContent = "DAHA FAZLA";
                    btn.disabled = false;
                }
            })
            .catch(() => {
                btn.textContent = "DAHA FAZLA";
                btn.disabled = false;
            });
    }
</script>









