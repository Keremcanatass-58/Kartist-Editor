@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sana Özel Bir Sürpriz! | Kartist</title>

    <script src="https://unpkg.com/fabric@5.3.0/dist/fabric.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;800&family=Great+Vibes&family=Cinzel:wght@700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

    <style>
        /* --- CSS KODLARI (AYNEN KORUNDU) --- */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            user-select: none;
        }

        body {
            background-color: #050505;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            overflow: hidden;
            font-family: 'Montserrat', sans-serif;
            perspective: 1200px;
        }

        .stage {
            position: relative;
            width: 100%;
            height: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 10;
        }

        .hidden {
            display: none !important;
        }

        /* --- 1. DOĞUM GÜNÜ (SİHİRLİ MUM) --- */
        .candle-container {
            position: relative;
            cursor: pointer;
            filter: drop-shadow(0 0 30px rgba(255, 165, 0, 0.4));
        }

        .candle-body {
            width: 40px;
            height: 120px;
            background: linear-gradient(to right, #eee, #ccc, #eee);
            border-radius: 5px;
            margin: 0 auto;
            position: relative;
        }

        .wick {
            width: 4px;
            height: 15px;
            background: #333;
            margin: 0 auto;
            position: relative;
            top: -15px;
        }

        .flame {
            width: 30px;
            height: 50px;
            background: linear-gradient(to bottom, #ffeb3b, #ff9800, #ff5722);
            border-radius: 50% 50% 20% 20%;
            position: absolute;
            top: -60px;
            left: 50%;
            transform: translateX(-50%);
            box-shadow: 0 0 40px #ff9800, 0 0 80px #ff5722;
            animation: flicker 0.1s infinite alternate;
        }

        .wish-text {
            color: #fff;
            font-family: 'Cinzel', serif;
            font-size: 1.5rem;
            margin-top: 40px;
            text-align: center;
            opacity: 0.8;
            letter-spacing: 3px;
        }

        @@keyframes flicker {
            0% {
                transform: translateX(-50%) scale(1);
                opacity: 1;
            }

            100% {
                transform: translateX(-50%) scale(1.1);
                opacity: 0.9;
            }
        }

        /* --- 2. AŞK (KRİSTAL KALP) --- */
        .crystal-heart-wrapper {
            cursor: pointer;
            position: relative;
            perspective: 1000px;
        }

        .crystal-heart {
            font-size: 8rem;
            color: rgba(255, 0, 80, 0.8);
            filter: drop-shadow(0 0 20px rgba(255, 0, 80, 0.6));
            animation: crystalPulse 2s infinite ease-in-out;
            position: relative;
            z-index: 2;
            background: linear-gradient(135deg, #ff0055, #ff99cc);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

            .crystal-heart::after {
                content: '❤';
                position: absolute;
                top: 0;
                left: 0;
                color: transparent;
                -webkit-text-stroke: 2px rgba(255,255,255,0.5);
                width: 100%;
                height: 100%;
                z-index: 3;
            }

        .love-text {
            color: #ff99cc;
            font-family: 'Great Vibes', cursive;
            font-size: 2.5rem;
            margin-top: 20px;
            text-align: center;
        }

        @@keyframes crystalPulse {
            0% {
                transform: scale(1);
                filter: drop-shadow(0 0 20px rgba(255,0,80,0.6));
            }

            50% {
                transform: scale(1.1);
                filter: drop-shadow(0 0 50px rgba(255,0,80,0.9));
            }

            100% {
                transform: scale(1);
                filter: drop-shadow(0 0 20px rgba(255,0,80,0.6));
            }
        }

        /* --- 3. PARTİ (VINYL RECORD) --- */
        .vinyl-container {
            cursor: pointer;
            position: relative;
        }

        .vinyl {
            width: 250px;
            height: 250px;
            background: #111;
            border-radius: 50%;
            background: repeating-radial-gradient(#111 0, #111 2px, #222 3px, #222 4px);
            box-shadow: 0 0 50px rgba(0, 210, 255, 0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            animation: spinVinyl 2s linear infinite;
            border: 5px solid #111;
        }

        .vinyl-label {
            width: 90px;
            height: 90px;
            background: radial-gradient(circle, #c6ff00, #00d2ff);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .vinyl-label i {
                font-size: 2rem;
                color: #000;
            }

        .party-text {
            color: #00d2ff;
            font-weight: 900;
            font-size: 1.2rem;
            margin-top: 30px;
            text-align: center;
            letter-spacing: 5px;
            text-transform: uppercase;
        }

        @@keyframes spinVinyl {
            from {
                transform: rotate(0deg);
            }

            to {
                transform: rotate(360deg);
            }
        }

        /* --- 4. DÜĞÜN (ZARF) --- */
        .envelope-wrapper {
            cursor: pointer;
            z-index: 50;
            perspective: 1000px;
        }

        .envelope {
            width: 320px;
            height: 220px;
            background: #1a1a1a;
            border: 2px solid #d4af37;
            display: flex;
            justify-content: center;
            align-items: center;
            border-radius: 10px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.8);
            position: relative;
        }

        .wax-seal {
            width: 70px;
            height: 70px;
            background: #d4af37;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 2rem;
            color: #333;
            box-shadow: 0 5px 15px rgba(0,0,0,0.5);
            transition: 0.3s;
        }

            .wax-seal:hover {
                transform: scale(1.1);
                box-shadow: 0 0 20px #d4af37;
            }

        .invite-text {
            color: #d4af37;
            margin-top: 20px;
            text-align: center;
            font-family: 'Cinzel', serif;
            font-size: 1.5rem;
            letter-spacing: 2px;
        }

        /* --- KART KUTUSU --- */
        .card-container {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) scale(0);
            width: 800px;
            height: 550px;
            max-width: 95vw;
            max-height: 90vh;
            background: white;
            border-radius: 16px;
            box-shadow: 0 0 150px rgba(255,255,255,0.15);
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
            z-index: 100;
            opacity: 0;
            pointer-events: none;
        }

            .card-container.show {
                opacity: 1;
                pointer-events: auto;
            }

        /* ORTAK EFEKTLER */
        .flash-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: white;
            opacity: 0;
            pointer-events: none;
            z-index: 200;
        }

        canvas {
            width: 100% !important;
            height: 100% !important;
        }
        /* --- MOBİL UYUMLULUK (max-width: 768px) --- */
        @@media (max-width: 768px) {
            /* 1. ANA GÖVDE VE SAHNE */
            body {
                height: 100vh;
                align-items: flex-start; /* Objeler ekranın üst kısmına toplanmasın */
                padding-top: 15vh;
            }

            .stage {
                transform: scale(0.75); /* Tüm objeleri %75 küçült */
            }
            /* 2. KART KUTUSU */
            .card-container {
                /* Mobil cihazlarda maksimum alanı kapla */
                width: 95vw;
                height: 80vh;
                max-width: 95vw;
                max-height: 95vh;
                /* Sabit boyutları kaldır, JS ölçeklesin */
                transform: translate(-50%, -50%) scale(0);
            }
            /* Mum Objesi Küçültme */
            .candle-body {
                width: 30px;
                height: 90px;
            }

            .wick {
                height: 12px;
                top: -12px;
            }

            .flame {
                width: 20px;
                height: 40px;
                top: -50px;
            }

            .wish-text {
                font-size: 1.2rem;
                margin-top: 30px;
            }
            /* Kalp Objesi Küçültme */
            .crystal-heart {
                font-size: 6rem;
            }

            .love-text {
                font-size: 1.8rem;
            }
            /* Plak Objesi Küçültme */
            .vinyl {
                width: 200px;
                height: 200px;
            }

            .vinyl-label {
                width: 70px;
                height: 70px;
            }

                .vinyl-label i {
                    font-size: 1.5rem;
                }

            .party-text {
                font-size: 1rem;
            }
            /* Zarf Objesi Küçültme */
            .envelope {
                width: 280px;
                height: 180px;
            }

            .wax-seal {
                width: 60px;
                height: 60px;
                font-size: 1.5rem;
            }

            .invite-text {
                font-size: 1.2rem;
            }
        }
    </style>
</head>
<body class="theme-@ViewBag.Kategori">

    <div class="stage" id="stage">

        @if (ViewBag.Kategori == "DogumGunu")
        {
            <div class="candle-container" onclick="playBirthday()">
                <div class="flame"></div><div class="wick"></div><div class="candle-body"></div><div class="wish-text">BİR DİLEK TUT...</div>
            </div>
        }

        else if (ViewBag.Kategori == "Ask")
        {
            <div class="crystal-heart-wrapper" onclick="playLove()">
                <i class="fa-solid fa-heart crystal-heart"></i><div class="love-text">Sana Özel...</div>
            </div>
        }

        else if (ViewBag.Kategori == "Parti")
        {
            <div class="vinyl-container" onclick="playParty()">
                <div class="vinyl"><div class="vinyl-label"><i class="fa-solid fa-music"></i></div></div><div class="party-text">BAŞLAT</div>
            </div>
        }

        else
        {
            <div class="envelope-wrapper" onclick="playWedding()">
                <div class="envelope"><div class="wax-seal"><i class="fa-solid fa-envelope"></i></div></div><div class="invite-text">DAVETİYE</div>
            </div>
        }
    </div>

    <div class="flash-overlay" id="flash"></div>

    <div class="card-container" id="cardBox">
        <canvas id="c" width="800" height="550"></canvas>
    </div>

    <input type="hidden" id="jsonData" value="@ViewBag.Json" />
    <input type="hidden" id="bgUrl" value="@ViewBag.Bg" />

    <audio id="bgMusic" src="@ViewBag.Muzik" preload="auto"></audio>

    <script>
        // --- MÜZİK BAŞLATMA (GARANTİLİ) ---
        function startMusic() {
            var audio = document.getElementById("bgMusic");
            if (audio && audio.getAttribute('src')) {
                audio.volume = 0.7;
                // Kullanıcı tıkladığı AN başlatıyoruz, böylece tarayıcı engellemez.
                var playPromise = audio.play();
                if (playPromise !== undefined) {
                    playPromise.catch(error => {
                        console.log("Otomatik oynatma engellendi, ancak kullanıcı etkileşimi olduğu için çalışması gerekirdi.");
                    });
                }
            }
        }

        // --- ANİMASYONLAR ---

        function playBirthday() {
            startMusic(); // Müziği hemen başlat
            const tl = gsap.timeline();
            tl.to(".flame", { scale: 0, duration: 0.2, ease: "power1.in" })
                .to(".wick", { scaleY: 0, duration: 0.1 })
                .to(".candle-body", { height: 0, duration: 0.5, ease: "power2.in" })
                .to(".wish-text", { opacity: 0, duration: 0.3 }, "<")
                .add(() => { confetti({ particleCount: 150, spread: 100, origin: { y: 0.7 }, colors: ['#ffffff', '#ccc'], scalar: 0.8 }); confetti({ particleCount: 100, spread: 60, origin: { y: 0.6 }, colors: ['#ffeb3b', '#ff9800'] }); })
                .call(showCard);
        }

        function playLove() {
            startMusic();
            const tl = gsap.timeline();
            tl.to(".crystal-heart", { scale: 1.5, duration: 0.4, ease: "back.out(1.7)" })
                .to(".crystal-heart", { scale: 0, opacity: 0, duration: 0.3, ease: "power4.in" })
                .to(".love-text", { opacity: 0, duration: 0.2 }, "<")
                .add(() => {
                    var duration = 2 * 1000; var end = Date.now() + duration;
                    (function frame() { confetti({ particleCount: 5, angle: 60, spread: 55, origin: { x: 0 }, shapes: ['heart'], colors: ['#ff0055', '#ff99cc'] }); confetti({ particleCount: 5, angle: 120, spread: 55, origin: { x: 1 }, shapes: ['heart'], colors: ['#ff0055', '#ff99cc'] }); if (Date.now() < end) requestAnimationFrame(frame); }());
                })
                .call(showCard);
        }

        function playParty() {
            startMusic();
            const tl = gsap.timeline();
            tl.to(".vinyl", { rotation: 720, duration: 1, ease: "power2.in" })
                .to(".vinyl-container", { scale: 0, opacity: 0, duration: 0.3 })
                .to("#flash", { opacity: 1, duration: 0.1, yoyo: true, repeat: 3 })
                .add(() => { confetti({ particleCount: 200, spread: 150, origin: { y: 0.6 }, colors: ['#00d2ff', '#c6ff00', '#ff0055'] }); })
                .call(showCard);
        }

        function playWedding() {
            startMusic();
            const tl = gsap.timeline();
            tl.to(".wax-seal", { scale: 1.3, duration: 0.3 })
                .to(".envelope", { rotationX: 180, opacity: 0, duration: 0.6 })
                .to(".invite-text", { opacity: 0, duration: 0.2 }, "<")
                .add(() => { confetti({ colors: ['#d4af37', '#ffffff'], particleCount: 150, gravity: 0.5 }); })
                .call(showCard);
        }

        function showCard() {
            const card = document.getElementById('cardBox');
            const stage = document.getElementById('stage');
            stage.style.display = 'none';

            // Kartı elastik bir şekilde aç (Mobil dahil)
            gsap.to(card, {
                scale: 1,
                opacity: 1,
                duration: 1.2,
                ease: "elastic.out(1, 0.75)",
                onStart: () => {
                    card.style.pointerEvents = "auto";
                    handleResize(); // Kart açılırken hemen boyutlandır
                }
            });
        }

        // --- YENİ & GELİŞMİŞ RESIZE FONKSİYONU ---
        function handleResize() {
            var cardContainer = document.getElementById('cardBox');
            var canvasEl = document.getElementById('c');

            // Eğer kart açılmamışsa veya element yoksa çık
            if (!cardContainer || !canvasEl || getComputedStyle(cardContainer).opacity === "0") {
                return;
            }

            // Sabit (tasarım) boyutları
            const BASE_W = 800;
            const BASE_H = 550;

            // Kapsayıcı (ekran) boyutları
            const containerW = cardContainer.clientWidth;
            const containerH = cardContainer.clientHeight;

            // En boy oranı (800 / 550 = 1.45)
            const scaleW = containerW / BASE_W;
            const scaleH = containerH / BASE_H;

            // Daha küçük olan ölçeği al (Kartonun dışarı taşmamasını sağlar)
            const scale = Math.min(scaleW, scaleH);

            // Canvas elementini ölçekle ve ortala
            gsap.set(canvasEl, {
                scale: scale,
                xPercent: -50, // x/y ile ortalama
                yPercent: -50,
                x: '50%',
                y: '50%',
                position: 'absolute'
            });

            // Canvas'ın sabit boyutları korunmalı, sadece kapsayıcı ölçeklenmeli
            canvasEl.style.width = BASE_W + 'px';
            canvasEl.style.height = BASE_H + 'px';
        }

        window.onload = function () {
            var canvas = new fabric.StaticCanvas('c');
            var json = document.getElementById('jsonData').value;
            var bg = document.getElementById('bgUrl').value;

            // Load Fontları Yükle (Emin olmak için)
            loadFonts();

            // Canvas Yükleme Mantığı (Aynen Kalıyor)
            if (json && json.length > 10) {
                canvas.loadFromJSON(json, function () {
                    canvas.renderAll();
                    if (!canvas.backgroundColor) canvas.setBackgroundColor('white', canvas.renderAll.bind(canvas));
                });
            } else if (bg) {
                fabric.Image.fromURL(bg, function (img) {
                    var s = Math.max(800 / img.width, 550 / img.height);
                    canvas.setBackgroundImage(img, canvas.renderAll.bind(canvas), {
                        scaleX: s, scaleY: s, originX: 'center', originY: 'center', left: 400, top: 275
                    });
                });
            }

            // Tüm resize olaylarında yeni fonksiyonu çağır
            window.addEventListener('resize', handleResize);

            // Sayfa yüklenince de boyutlandır
            handleResize();
        };

        // Yüklü fontları canvas için zorla yükleme fonksiyonu
        function loadFonts() {
            const fonts = ["Montserrat", "Great Vibes", "Cinzel"];
            fonts.forEach(f => {
                var id = 'font-' + f.replace(/\s+/g, '-');
                if (!document.getElementById(id)) {
                    var l = document.createElement('link');
                    l.id = id;
                    l.href = 'https://fonts.googleapis.com/css2?family=' + f.replace(/\s+/g, '+') + ':wght@400;700&display=swap';
                    l.rel = 'stylesheet';
                    document.head.appendChild(l);
                }
            });
        }
    </script>
</body>
</html>