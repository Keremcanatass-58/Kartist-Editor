                                <div style="padding:10px 12px;font-weight:800;color:#fff;font-size:0.9rem;border-bottom:1px solid #1a1a1a;">Bildirimler</div>
                                <div id="notifList" style="padding:4px 0;"></div>
                            </div>
                        </div>

                        <!-- DM ICON -->
                        <a href="/Social/Mesajlar" style="color:#ccc;font-size:1.1rem;padding:8px;margin-left:4px;text-decoration:none;position:relative;">
                            <i class="fa-regular fa-paper-plane"></i>
                        </a>

                        <div class="user-menu-container" onclick="toggleMenu(event)">
                            <div class="user-btn">
                                <span class="user-name-text">@User.Identity.Name</span>
                                <div class="user-avatar-circle">
                                    @User.Identity.Name?.Substring(0, 1).ToUpper()
                                </div>
                            </div>

                            <div class="custom-dropdown" id="userDropdown">
                                <div class="dropdown-header-info">
                                    <div class="balance-label">MEVCUT BAKİYE</div>
                                    <div class="balance-amount">50.00 <span style="font-size:12px">KR</span></div>
                                </div>

                                <a href="/Account/Profil" class="dropdown-link"><i class="fa-solid fa-user"></i> Profilim</a>
                                <a href="/Social/Feed" class="dropdown-link"><i class="fa-solid fa-users-line" style="color:#c6ff00"></i> Topluluğa Katıl</a>
                                <a href="/Social/Mesajlar" class="dropdown-link"><i class="fa-solid fa-paper-plane"></i> Mesajlar</a>
                                <a href="/Home/Koleksiyon" class="dropdown-link"><i class="fa-solid fa-layer-group"></i> Koleksiyonum</a>
                                <div style="height:1px; background:#222; margin:5px 0;"></div>
                                <a href="/Account/Cikis" class="dropdown-link logout"><i class="fa-solid fa-power-off"></i> Çıkış Yap</a>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex justify-content-center align-items-center gap-3 mt-3 mt-lg-0">
                            <!-- Sosyal Medya Giriş Butonları -->
                            <a href="/Social/Feed" class="nav-link" style="color:#c6ff00 !important; margin:0 8px; display:flex; align-items:center; gap:6px; font-weight:700; transition:0.3s;">
                                <i class="fa-solid fa-users-line"></i> Topluluğa Katıl
                            </a>
                            <div style="width:1px; height:20px; background:rgba(255,255,255,0.1);"></div>
                            <a href="/Account/Giris" class="btn-login" style="white-space: nowrap;">Giriş Yap</a>
