                </ul>
            </div>
        </div>
    </nav>

    <div class="page-loader" id="pageLoader"></div>

    <div class="main-content">
        @RenderBody()
    </div>

    <div class="modal-overlay" id="contactModal">
        <div class="modal-box">
            <button class="btn-close-modal" onclick="toggleContact()"><i class="fa-solid fa-xmark"></i></button>
            <h2 class="modal-title">Bize <span>Ulaşın</span> ⚡</h2>
            <p class="modal-desc">Sorunlarını anında çözmek için buradayız.</p>
            <form>
                <div class="input-group-modal">
                    <input type="email" class="modal-input" placeholder="E-Posta Adresin" required>
                    <i class="fa-solid fa-envelope input-icon"></i>
                </div>
                <div class="input-group-modal">
                    <input type="text" class="modal-input" placeholder="Konu Başlığı">
                    <i class="fa-solid fa-tag input-icon"></i>
                </div>
                <div class="input-group-modal">
                    <textarea class="modal-input" rows="4" placeholder="Mesajınız..." style="resize: none;"></textarea>
                    <i class="fa-solid fa-comment-dots input-icon"></i>
                </div>
                <button type="button" class="btn-submit" onclick="mailGonder()">GÖNDER <i class="fa-solid fa-paper-plane"></i></button>
            </form>
        </div>
    </div>

    <div class="music-wrapper">
        <div class="music-toggle-btn" onclick="toggleMusic()"><i class="fa-brands fa-spotify"></i></div>
        <div class="spotify-container" id="spotifyBox"></div>
    </div>

    <footer class="footer">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <span class="footer-logo">KARTIST</span>
                    <p class="mb-0" style="opacity:0.7;">Geleceğin tasarım platformu.</p>
                </div>
                <div class="col-md-6 text-md-end mt-3 mt-md-0">
                    <a href="https://www.instagram.com/x.keremcan6z/" class="social-icon" target="_blank"><i class="fa-brands fa-instagram"></i></a>
                    <a href="https://www.linkedin.com/in/keremcan-ataş" class="social-icon" target="_blank"><i class="fa-brands fa-linkedin-in"></i></a>
                    <a href="https://github.com/Keremcanatass-58" class="social-icon" target="_blank"><i class="fa-brands fa-github"></i></a>
                </div>
            </div>
            <div class="creator-signature">
                Code & Design by <span class="creator-name">Keremcan Ataş</span> © 2025 <br>
                <span style="font-size: 0.75rem; color: #555;">v1.2.5 (AI Runtime Fix)</span>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function getCSRFToken() { return document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''; }

        function toggleContact() {
            const modal = document.getElementById('contactModal');
            if (!modal) return;
            const isActive = modal.classList.contains('active');
            if (isActive) {
                modal.classList.remove('active');
                setTimeout(() => { modal.style.display = 'none'; document.body.style.overflow = ''; }, 300);
            } else {
                modal.style.display = 'flex';
                requestAnimationFrame(() => { modal.classList.add('active'); document.body.style.overflow = 'hidden'; });
            }
        }

        document.addEventListener('click', function (e) {
            const modal = document.getElementById('contactModal');
            if (modal && modal.classList.contains('active') && e.target === modal) toggleContact();
        });

        function toggleMusic() {
            var box = document.getElementById('spotifyBox');
            box.classList.toggle('active');
            if (box.classList.contains('active') && !box.querySelector('iframe')) {
                box.innerHTML = '<iframe style="border-radius:12px" src="https://open.spotify.com/embed/playlist/37i9dQZEVXbIVYVBNw9D5K?utm_source=generator&theme=0" width="100%" height="100%" frameBorder="0" allowfullscreen="" allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"></iframe>';
            }
        }

        function toggleMenu(event) {
            var dropdown = document.getElementById("userDropdown");
            dropdown.classList.toggle("show-mobile");
            event.stopPropagation();
        }

        window.onclick = function (event) {
            var dropdown = document.getElementById("userDropdown");
            if (dropdown && dropdown.classList.contains('show-mobile')) {
                dropdown.classList.remove('show-mobile');
            }
        }

        function mailGonder() {
            var btn = document.querySelector('.btn-submit');
            var email = document.querySelector('input[type=email]').value;
            var mesaj = document.querySelector('textarea').value;

            if (!email || !mesaj) {
                Swal.fire({ title: 'Eksik Bilgi', text: 'Lütfen alanları doldurun.', icon: 'warning', background: '#1e1e1e', color: '#fff', confirmButtonColor: '#c6ff00' });
                return;
            }

            var originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Gönderiliyor...';
            btn.disabled = true;

            var fd = new FormData();
            fd.append("email", email);
            fd.append("mesaj", mesaj);
            fd.append("__RequestVerificationToken", getCSRFToken());

            fetch('/Home/Iletisim', { method: 'POST', body: fd })
                .then(r => r.json())
                .then(d => {
                    if (d.success) {
                        Swal.fire({
                            title: 'Mesajın Ulaştı! 🚀', text: 'En kısa sürede döneceğiz.', icon: 'success',
                            background: '#1e1e1e', color: '#fff', iconColor: '#c6ff00', confirmButtonColor: '#c6ff00', confirmButtonText: '<span style="color:black; font-weight:bold;">Süper!</span>'
                        }).then(() => {
                            toggleContact();
                            document.querySelector('input[type=email]').value = "";
                            document.querySelector('textarea').value = "";
                        });
                    } else {
                        Swal.fire({ title: 'Hata!', text: d.message, icon: 'error', background: '#1e1e1e', color: '#fff', confirmButtonColor: '#ff4444' });
                    }
                })
                .catch(err => Swal.fire({ icon: 'error', title: 'Hata', text: 'Bir şeyler ters gitti.', background: '#1e1e1e', color: '#fff' }))
                .finally(() => { btn.innerHTML = originalText; btn.disabled = false; });
        }

        // SWAL Bildirimleri (Giriş/Çıkış)
        var layoutMesaj = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["Mesaj"]));
        var layoutTur = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["Tur"]));
        if (layoutMesaj && layoutMesaj.length > 0) {
            Swal.fire({
                title: 'KARTIST',
                text: layoutMesaj,
                icon: layoutTur,
                background: '#1e1e1e', color: '#fff', iconColor: '#c6ff00', confirmButtonColor: '#c6ff00',
                confirmButtonText: '<span style="color:black; font-weight:bold;">DEVAM ET</span>',
                timer: 3000, timerProgressBar: true
            });
        }
    </script>

    <script>
        // Notification system
        function toggleNotifs(e) {
            e.stopPropagation();
            var dd = document.getElementById('notifDropdown');
            if (!dd) return;
            var isOpen = dd.style.display === 'block';
            dd.style.display = isOpen ? 'none' : 'block';
            if (!isOpen) { loadNotifs(); markNotifsRead(); }
        }
        document.addEventListener('click', function(e) {
            var dd = document.getElementById('notifDropdown');
            if (dd && !e.target.closest('#notifContainer')) dd.style.display = 'none';
        });

        async function loadNotifs() {
            try {
                var res = await fetch('/Social/GetBildirimler');
                var data = await res.json();
                if (!data.success) return;

                var badge = document.getElementById('notifBadge');
                if (data.okunmamis > 0) {
                    badge.textContent = data.okunmamis;
                    badge.style.display = 'flex';
                } else {
                    badge.style.display = 'none';
                }

                var list = document.getElementById('notifList');
                if (!list) return;
                list.innerHTML = '';
                if (data.bildirimler.length === 0) {
                    list.innerHTML = '<div style="padding:20px;text-align:center;color:#444;font-size:0.8rem;">Bildirim yok</div>';
                    return;
                }
                data.bildirimler.forEach(function(n) {
                    var avatar = n.GonderenResim || 'https://cdn-icons-png.flaticon.com/512/149/149071.png';
                    var bg = n.OkunduMu ? 'transparent' : 'rgba(198,255,0,0.02)';
                    var ago = notifTimeAgo(n.Tarih);
                    var icon = n.Tip === 'begeni' ? '❤️' : n.Tip === 'yorum' ? '💬' : n.Tip === 'takip' ? '🔔' : '💌';
                    list.innerHTML += '<div style="display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:10px;background:' + bg + ';cursor:pointer;transition:0.15s;" onmouseover="this.style.background=\'rgba(255,255,255,0.02)\'" onmouseout="this.style.background=\'' + bg + '\'">'
                        + '<img src="' + avatar + '" style="width:34px;height:34px;border-radius:50%;object-fit:cover;">'
                        + '<div style="flex:1;min-width:0;"><div style="font-size:0.8rem;color:#ccc;line-height:1.4;">' + icon + ' ' + n.Mesaj + '</div><div style="font-size:0.65rem;color:#444;margin-top:2px;">' + ago + '</div></div></div>';
                });
            } catch(e) {}
        }

        function notifTimeAgo(dateStr) {
            var now = new Date(); var d = new Date(dateStr); var diff = Math.floor((now - d) / 1000);
            if (diff < 60) return 'Az önce'; if (diff < 3600) return Math.floor(diff / 60) + ' dk';
            if (diff < 86400) return Math.floor(diff / 3600) + ' sa'; return Math.floor(diff / 86400) + ' gün';
        }

        async function markNotifsRead() {
            try {
                var fd = new FormData(); fd.append('__RequestVerificationToken', getCSRFToken());
                await fetch('/Social/BildirimleriOku', { method: 'POST', body: fd });
                setTimeout(function() {
                    var badge = document.getElementById('notifBadge');
                    if (badge) badge.style.display = 'none';
                }, 1000);
            } catch(e){}
        }

        // Poll notifications every 30s
        if (document.getElementById('notifContainer')) {
            loadNotifs();
            setInterval(loadNotifs, 30000);
        }
    </script>

    <script>
        // Page transition system
        (function() {
            var loader = document.getElementById('pageLoader');

            // Fade in on page load
            window.addEventListener('pageshow', function(e) {
                document.body.classList.remove('page-leaving');
                if (loader) {
                    loader.className = 'page-loader done';
                    setTimeout(function() { loader.className = 'page-loader hide'; }, 250);
                    setTimeout(function() { loader.className = 'page-loader'; }, 600);
                }
            });

            // Intercept link clicks for smooth transition
            document.addEventListener('click', function(e) {
                var link = e.target.closest('a');
                if (!link) return;
                var href = link.getAttribute('href');
                if (!href || href.startsWith('#') || href.startsWith('javascript:') || href.startsWith('http') || link.target === '_blank') return;
                if (link.hasAttribute('download')) return;
                if (e.ctrlKey || e.metaKey || e.shiftKey) return;
                if (link.closest('.modal-overlay') || link.closest('.custom-dropdown')) return;
                if (link.getAttribute('onclick') && link.getAttribute('onclick').indexOf('confirm') > -1) return;

                e.preventDefault();
                document.body.classList.add('page-leaving');
                if (loader) { loader.className = 'page-loader loading'; }
                setTimeout(function() { window.location.href = href; }, 120);
            });
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>



