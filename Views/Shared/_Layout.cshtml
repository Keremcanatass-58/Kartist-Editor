<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @Html.AntiForgeryToken()
    <title>KARTIST - Tasarımın Geleceği</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>⚡</text></svg>">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;500;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        :root {
            --bg-deep: #0a0a0f;
            --accent-neon: #c6ff00;
            --text-light: #ffffff;
            --glass-nav: rgba(20, 20, 25, 0.6);
            --glass-border: rgba(255, 255, 255, 0.1);
        }

        body {
            background-color: var(--bg-deep);
            color: var(--text-light);
            font-family: 'Space Grotesk', sans-serif;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            margin: 0;
        }

        /* --- NAVBAR --- */
        .navbar {
            background: var(--glass-nav);
            backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            padding: 15px 20px;
            position: fixed;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
            width: 90%;
            max-width: 1200px;
            border-radius: 100px;
            z-index: 1000;
            transition: 0.3s;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        .brand-logo {
            font-size: 1.5rem;
            font-weight: 800;
            letter-spacing: -1px;
            color: white;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .logo-icon {
            color: var(--accent-neon);
            font-size: 1.2rem;
            animation: spinSlow 10s infinite linear;
        }

        @@keyframes spinSlow { 100% { transform: rotate(360deg); } }

        .nav-link {
            color: #ccc !important;
            font-weight: 600;
            font-size: 0.9rem;
            margin: 0 15px;
            position: relative;
            transition: 0.3s;
        }

        .nav-link:hover { color: white !important; }

        .nav-link::after {
            content: '';
            position: absolute; width: 0; height: 2px; bottom: 0; left: 50%;
            background-color: var(--accent-neon);
            transition: all 0.3s ease-in-out;
            transform: translateX(-50%);
        }

        .nav-link:hover::after { width: 100%; }

        /* GİRİŞ BUTONU */
        .btn-login {
            background: rgba(255,255,255,0.1);
            border: 1px solid transparent;
            color: white;
            border-radius: 50px;
            padding: 8px 25px;
            font-size: 0.9rem;
            transition: 0.3s;
            text-decoration: none;
        }

        .btn-login:hover {
            background: var(--accent-neon);
            color: black;
            box-shadow: 0 0 15px var(--accent-neon);
        }
        .btn-register {
            background: var(--accent-neon); /* İçi Dolu Neon */
            border: 1px solid var(--accent-neon);
            color: #000; /* Yazı Siyah (Okunabilirlik için) */
            border-radius: 50px;
            padding: 8px 25px;
            font-size: 0.9rem;
            transition: 0.3s;
            text-decoration: none;
            font-weight: 800; /* Daha kalın font */
            box-shadow: 0 0 10px rgba(198, 255, 0, 0.2); /* Hafif parlama */
        }

            .btn-register:hover {
                background: transparent; /* Hoverda içi boşalır */
                color: var(--accent-neon); /* Yazı Neon olur */
                box-shadow: 0 0 25px rgba(198, 255, 0, 0.6); /* Parlama artar */
                transform: scale(1.05); /* Hafif büyür */
            }

        /* İÇERİK & FOOTER */
        .main-content { flex: 1; margin-top: 120px; }

        .footer {
            background: #050508;
            border-top: 1px solid var(--glass-border);
            padding: 50px 0 20px 0;
            margin-top: 80px;
            font-size: 0.9rem;
            color: #666;
        }

        .footer-logo { font-weight: 800; color: white; font-size: 1.2rem; margin-bottom: 10px; display: block; }
        .creator-signature { margin-top: 30px; padding-top: 20px; border-top: 1px solid #1a1a1a; text-align: center; font-size: 0.85rem; letter-spacing: 1px; color: #555; }
        .creator-name { color: var(--accent-neon); font-weight: 700; text-transform: uppercase; transition: 0.3s; }
        .creator-name:hover { text-shadow: 0 0 20px var(--accent-neon); cursor: default; }

        .social-icon {
            width: 40px; height: 40px; border-radius: 50%; background: rgba(255,255,255,0.05);
            display: inline-flex; align-items: center; justify-content: center; color: white;
            margin-left: 10px; transition: 0.3s; text-decoration: none;
        }
        .social-icon:hover { background: var(--accent-neon); color: black; transform: translateY(-3px); }

        /* --- KULLANICI MENÜSÜ TASARIMI --- */
        .user-menu-container { position: relative; display: inline-block; margin-left: 20px; }

        .user-btn {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 6px 6px 6px 16px;
            border-radius: 50px;
            display: flex; align-items: center; gap: 12px;
            cursor: pointer; transition: 0.3s; text-decoration: none;
        }
        .user-btn:hover, .user-btn.active {
            background: rgba(198, 255, 0, 0.1); border-color: #c6ff00;
            box-shadow: 0 0 15px rgba(198, 255, 0, 0.2);
        }

        .user-name-text { color: #fff; font-weight: 600; font-size: 0.9rem; }

        .user-avatar-circle {
            width: 38px; height: 38px; background: #c6ff00; color: #000;
            border-radius: 50%; display: flex; align-items: center; justify-content: center;
            font-weight: 800; font-size: 1.1rem; box-shadow: 0 0 10px rgba(198, 255, 0, 0.4);
        }

        .custom-dropdown {
            position: absolute; top: 120%; right: 0; width: 240px;
            background: #111; border: 1px solid #333; border-radius: 16px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.6); padding: 10px;
            opacity: 0; visibility: hidden; transform: translateY(-10px);
            transition: 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); z-index: 1000;
        }
        .user-menu-container:hover .custom-dropdown { opacity: 1; visibility: visible; transform: translateY(0); }

        .dropdown-header-info { padding: 10px 15px; background: rgba(255,255,255,0.03); border-radius: 10px; margin-bottom: 10px; text-align: center; }
        .balance-label { font-size: 11px; color: #888; text-transform: uppercase; letter-spacing: 1px; }
        .balance-amount { font-size: 18px; color: #c6ff00; font-weight: bold; }

        .dropdown-link { display: flex; align-items: center; padding: 12px 15px; color: #ccc; text-decoration: none; font-size: 14px; border-radius: 8px; transition: 0.2s; }
        .dropdown-link i { width: 25px; color: #666; transition: 0.2s; }
        .dropdown-link:hover { background: #1a1a1a; color: #fff; }
        .dropdown-link:hover i { color: #c6ff00; }
        .dropdown-link.logout:hover { background: rgba(255, 68, 68, 0.1); color: #ff4444; }
        .dropdown-link.logout:hover i { color: #ff4444; }

        /* --- CONTACT MODAL --- */
        .modal-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0, 0, 0, 0.7); backdrop-filter: blur(8px);
            z-index: 1000; display: none; align-items: center; justify-content: center;
            opacity: 0; transition: opacity 0.3s ease;
        }
        .modal-overlay.active { display: flex; opacity: 1; }

        .modal-box {
            width: 100%; max-width: 450px; background: rgba(20, 20, 20, 0.85);
            border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 24px; padding: 40px;
            position: relative; box-shadow: 0 20px 50px rgba(0,0,0,0.5), 0 0 0 1px rgba(198, 255, 0, 0.1);
            transform: scale(0.8) translateY(20px); transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .modal-overlay.active .modal-box { transform: scale(1) translateY(0); }

        .btn-close-modal { position: absolute; top: 20px; right: 20px; background: transparent; border: none; color: #666; font-size: 1.5rem; cursor: pointer; transition: 0.2s; }
        .btn-close-modal:hover { color: #fff; transform: rotate(90deg); }
        .modal-title { font-size: 1.8rem; font-weight: 800; color: #fff; margin-bottom: 5px; text-align: center; }
        .modal-title span { color: var(--accent-neon); }
        .modal-desc { text-align: center; color: #888; font-size: 0.9rem; margin-bottom: 30px; }

        .input-group-modal { position: relative; margin-bottom: 20px; }
        .input-icon { position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: #555; transition: 0.3s; }
        .input-group-modal textarea ~ .input-icon { top: 20px; transform: none; }

        .modal-input { width: 100%; background: #111; border: 1px solid #333; border-radius: 12px; padding: 14px 14px 14px 45px; color: #fff; font-size: 0.95rem; transition: 0.3s; font-family: inherit; }
        .modal-input:focus { background: #000; border-color: var(--accent-neon); box-shadow: 0 0 15px rgba(198, 255, 0, 0.15); outline: none; }
        .modal-input:focus ~ .input-icon { color: var(--accent-neon); }

        .btn-submit { width: 100%; background: var(--accent-neon); color: #000; font-weight: 800; padding: 16px; border-radius: 12px; border: none; font-size: 1rem; cursor: pointer; transition: 0.3s; display: flex; align-items: center; justify-content: center; gap: 10px; }
        .btn-submit:hover { transform: translateY(-3px); box-shadow: 0 10px 30px rgba(198, 255, 0, 0.3); }

        /* --- SPOTIFY & RESPONSIVE --- */
        .music-toggle-btn { position: fixed; bottom: 30px; right: 30px; width: 60px; height: 60px; background: #000; border: 2px solid #1db954; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; z-index: 9999; box-shadow: 0 0 20px rgba(29, 185, 84, 0.4); transition: 0.3s; animation: pulseMusic 2s infinite; }
        .music-toggle-btn:hover { transform: scale(1.1) rotate(10deg); box-shadow: 0 0 40px rgba(29, 185, 84, 0.8); }
        .music-toggle-btn i { font-size: 1.8rem; color: #1db954; }
        .spotify-container { position: fixed; bottom: 100px; right: 30px; width: 320px; height: 400px; background: rgba(0,0,0,0.9); border: 1px solid #333; border-radius: 15px; overflow: hidden; z-index: 9998; box-shadow: 0 10px 40px rgba(0,0,0,0.8); opacity: 0; pointer-events: none; transform: translateY(20px) scale(0.9); transition: 0.4s; }
        .spotify-container.active { opacity: 1; pointer-events: auto; transform: translateY(0) scale(1); }
        @@keyframes pulseMusic { 0% { box-shadow: 0 0 0 0 rgba(29, 185, 84, 0.7); } 70% { box-shadow: 0 0 0 15px rgba(29, 185, 84, 0); } 100% { box-shadow: 0 0 0 0 rgba(29, 185, 84, 0); } }

        /* MOBIL RESPONSIVE AYARLARI */
        @@media (max-width: 992px) {
            .navbar { top: 0; width: 100%; border-radius: 0; left: 0; transform: none; padding: 12px 15px; }
            .main-content { margin-top: 70px; }
            .navbar-toggler { display: block; background: rgba(255, 255, 255, 0.1); border: 1px solid rgba(255, 255, 255, 0.2); }
            .navbar-collapse { animation: slideDown 0.3s ease; }
            .navbar-nav { text-align: center; }
            .dropdown-menu { width: 100%; text-align: center; }
        }

        @@media (max-width: 768px) {
            .user-name-text { display: none; }
            .user-btn { padding: 0; border: none; background: transparent; }
            .user-avatar-circle { width: 45px; height: 45px; font-size: 1.5rem; box-shadow: 0 0 20px rgba(198, 255, 0, 0.2); }

            /* MOBİL MENÜ ORTALAMA */
            .custom-dropdown {
                right: auto;
                left: 50%;
                transform: translate(-50%, -20px);
                width: 260px;
                top: 140%;
                text-align: center;
            }
            .dropdown-link { justify-content: center; }
            .custom-dropdown.show-mobile {
                opacity: 1; visibility: visible;
                transform: translate(-50%, 0) !important;
            }

            .navbar { padding: 10px 15px; }
            .brand-logo { font-size: 1.2rem; }
            .nav-link { margin: 0 10px; }
            .footer .row { flex-direction: column; text-align: center; }
            .footer .col-md-6 { width: 100%; margin-bottom: 20px; }
            .footer .text-md-end { text-align: center !important; }
            .spotify-container { width: calc(100vw - 20px); max-width: 350px; right: 10px; bottom: 90px; }
            .music-toggle-btn { bottom: 20px; right: 15px; width: 50px; height: 50px; }
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg">
        <div class="container-fluid px-4">
            <a class="brand-logo" href="/">
                <i class="fa-solid fa-bolt logo-icon"></i> KARTIST
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                <span class="navbar-toggler-icon" style="filter: invert(1);"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 justify-content-center flex-grow-1">
                    <li class="nav-item"><a class="nav-link" href="/">Ana Sayfa</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Home/Koleksiyon">Koleksiyon</a></li>
                    <li class="nav-item"><a class="nav-link" href="javascript:void(0)" onclick="toggleContact()">İletişim</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Home/Kurumsal">Hakkımızda</a></li>
                </ul>

                <ul class="navbar-nav align-items-center justify-content-center">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <div class="user-menu-container" onclick="toggleMenu(event)">
                            <div class="user-btn">
                                <span class="user-name-text">@User.Identity.Name</span>
                                <div class="user-avatar-circle">
                                    @User.Identity.Name?.Substring(0, 1).ToUpper()
                                </div>
                            </div>

                            <div class="custom-dropdown" id="userDropdown">
                                <div class="dropdown-header-info">
                                    <div class="balance-label">MEVCUT BAKİYE</div>
                                    <div class="balance-amount">50.00 <span style="font-size:12px">KR</span></div>
                                </div>

                                <a href="/Account/Profil" class="dropdown-link"><i class="fa-solid fa-user"></i> Profilim</a>
                                <a href="/Home/Koleksiyon" class="dropdown-link"><i class="fa-solid fa-layer-group"></i> Koleksiyonum</a>
                                <div style="height:1px; background:#222; margin:5px 0;"></div>
                                <a href="/Account/Cikis" class="dropdown-link logout"><i class="fa-solid fa-power-off"></i> Çıkış Yap</a>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex justify-content-center align-items-center gap-2 mt-3 mt-lg-0">
                            <a href="/Account/Giris" class="btn-login" style="white-space: nowrap;">Giriş Yap</a>
                            <a href="/Account/Kayit" class="btn-register" style="white-space: nowrap;">Kayıt Ol</a>
                        </div>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="main-content">
        @RenderBody()
    </div>

    <div class="modal-overlay" id="contactModal">
        <div class="modal-box">
            <button class="btn-close-modal" onclick="toggleContact()"><i class="fa-solid fa-xmark"></i></button>
            <h2 class="modal-title">Bize <span>Ulaşın</span> ⚡</h2>
            <p class="modal-desc">Sorunlarını anında çözmek için buradayız.</p>
            <form>
                <div class="input-group-modal">
                    <input type="email" class="modal-input" placeholder="E-Posta Adresin" required>
                    <i class="fa-solid fa-envelope input-icon"></i>
                </div>
                <div class="input-group-modal">
                    <input type="text" class="modal-input" placeholder="Konu Başlığı">
                    <i class="fa-solid fa-tag input-icon"></i>
                </div>
                <div class="input-group-modal">
                    <textarea class="modal-input" rows="4" placeholder="Mesajınız..." style="resize: none;"></textarea>
                    <i class="fa-solid fa-comment-dots input-icon"></i>
                </div>
                <button type="button" class="btn-submit" onclick="mailGonder()">GÖNDER <i class="fa-solid fa-paper-plane"></i></button>
            </form>
        </div>
    </div>

    <div class="music-wrapper">
        <div class="music-toggle-btn" onclick="toggleMusic()"><i class="fa-brands fa-spotify"></i></div>
        <div class="spotify-container" id="spotifyBox">
            <iframe style="border-radius:12px" src="https://open.spotify.com/embed/playlist/37i9dQZEVXbIVYVBNw9D5K?utm_source=generator&theme=0" width="100%" height="100%" frameBorder="0" allowfullscreen="" allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" loading="lazy"></iframe>
        </div>
    </div>

    <footer class="footer">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <span class="footer-logo">KARTIST</span>
                    <p class="mb-0" style="opacity:0.7;">Geleceğin tasarım platformu.</p>
                </div>
                <div class="col-md-6 text-md-end mt-3 mt-md-0">
                    <a href="https://www.instagram.com/x.keremcan6z/" class="social-icon" target="_blank"><i class="fa-brands fa-instagram"></i></a>
                    <a href="https://www.linkedin.com/in/keremcan-ataş" class="social-icon" target="_blank"><i class="fa-brands fa-linkedin-in"></i></a>
                    <a href="https://github.com/Keremcanatass-58" class="social-icon" target="_blank"><i class="fa-brands fa-github"></i></a>
                </div>
            </div>
            <div class="creator-signature">
                Code & Design by <span class="creator-name">Keremcan Ataş</span> © 2025
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function getCSRFToken() { return document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''; }

        function toggleContact() {
            const modal = document.getElementById('contactModal');
            if (!modal) return;
            const isActive = modal.classList.contains('active');
            if (isActive) {
                modal.classList.remove('active');
                setTimeout(() => { modal.style.display = 'none'; document.body.style.overflow = ''; }, 300);
            } else {
                modal.style.display = 'flex';
                requestAnimationFrame(() => { modal.classList.add('active'); document.body.style.overflow = 'hidden'; });
            }
        }

        document.addEventListener('click', function (e) {
            const modal = document.getElementById('contactModal');
            if (modal && modal.classList.contains('active') && e.target === modal) toggleContact();
        });

        function toggleMusic() { document.getElementById('spotifyBox').classList.toggle('active'); }

        function toggleMenu(event) {
            var dropdown = document.getElementById("userDropdown");
            dropdown.classList.toggle("show-mobile");
            event.stopPropagation();
        }

        window.onclick = function (event) {
            var dropdown = document.getElementById("userDropdown");
            if (dropdown && dropdown.classList.contains('show-mobile')) {
                dropdown.classList.remove('show-mobile');
            }
        }

        function mailGonder() {
            var btn = document.querySelector('.btn-submit');
            var email = document.querySelector('input[type=email]').value;
            var mesaj = document.querySelector('textarea').value;

            if (!email || !mesaj) {
                Swal.fire({ title: 'Eksik Bilgi', text: 'Lütfen alanları doldurun.', icon: 'warning', background: '#1e1e1e', color: '#fff', confirmButtonColor: '#c6ff00' });
                return;
            }

            var originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Gönderiliyor...';
            btn.disabled = true;

            var fd = new FormData();
            fd.append("email", email);
            fd.append("mesaj", mesaj);
            fd.append("__RequestVerificationToken", getCSRFToken());

            fetch('/Home/Iletisim', { method: 'POST', body: fd })
                .then(r => r.json())
                .then(d => {
                    if (d.success) {
                        Swal.fire({
                            title: 'Mesajın Ulaştı! 🚀', text: 'En kısa sürede döneceğiz.', icon: 'success',
                            background: '#1e1e1e', color: '#fff', iconColor: '#c6ff00', confirmButtonColor: '#c6ff00', confirmButtonText: '<span style="color:black; font-weight:bold;">Süper!</span>'
                        }).then(() => {
                            toggleContact();
                            document.querySelector('input[type=email]').value = "";
                            document.querySelector('textarea').value = "";
                        });
                    } else {
                        Swal.fire({ title: 'Hata!', text: d.message, icon: 'error', background: '#1e1e1e', color: '#fff', confirmButtonColor: '#ff4444' });
                    }
                })
                .catch(err => Swal.fire({ icon: 'error', title: 'Hata', text: 'Bir şeyler ters gitti.', background: '#1e1e1e', color: '#fff' }))
                .finally(() => { btn.innerHTML = originalText; btn.disabled = false; });
        }

        // SWAL Bildirimleri (Giriş/Çıkış)
        var layoutMesaj = '@Html.Raw(TempData["Mesaj"])';
        var layoutTur = '@Html.Raw(TempData["Tur"])';
        if (layoutMesaj && layoutMesaj.length > 0) {
            Swal.fire({
                title: 'KARTIST',
                text: layoutMesaj,
                icon: layoutTur,
                background: '#1e1e1e', color: '#fff', iconColor: '#c6ff00', confirmButtonColor: '#c6ff00',
                confirmButtonText: '<span style="color:black; font-weight:bold;">DEVAM ET</span>',
                timer: 3000, timerProgressBar: true
            });
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>