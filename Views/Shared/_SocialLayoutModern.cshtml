    <!-- Create Post Modal -->
    <div id="createModal" class="fixed inset-0 z-50 items-center justify-center hidden">
        <!-- Backdrop -->
        <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="closeCreateModal()"></div>

        <!-- Modal -->
        <div class="relative z-10 max-h-[90vh] w-full max-w-2xl overflow-y-auto rounded-2xl bg-card shadow-2xl">
            <!-- Header -->
            <div class="sticky top-0 z-10 flex items-center justify-between border-b border-border bg-card px-6 py-4">
                <h2 class="text-xl font-bold">Yeni Tasarim Paylas</h2>
                <button type="button" onclick="closeCreateModal()" class="flex h-10 w-10 items-center justify-center rounded-full text-muted-foreground transition-colors hover:bg-secondary hover:text-foreground">
                    <i data-lucide="x" class="h-5 w-5"></i>
                </button>
            </div>

            <!-- Content -->
            <form id="createPostForm" action="/Social/CreatePost" method="post" enctype="multipart/form-data" class="p-6">
                @Html.AntiForgeryToken()
                <!-- Image Upload -->
                <div class="relative rounded-2xl border-2 border-dashed border-border transition-all hover:border-primary/50 text-center py-16 cursor-pointer" onclick="document.getElementById('fileUpload').click()">
                    <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-primary/10">
                        <i data-lucide="upload" class="h-8 w-8 text-primary"></i>
                    </div>
                    <p class="mt-4 font-semibold">Tasarimini yukle</p>
                    <p class="mt-1 text-sm text-muted-foreground">PNG, JPG, GIF - Max 10MB</p>
                    <input type="file" id="fileUpload" name="image" accept="image/*" class="hidden" onchange="previewImage(this)" required />
                    <img id="imagePreview" class="absolute inset-0 w-full h-full object-cover rounded-xl hidden" />
                </div>

                <!-- Title -->
                <div class="mt-6">
                    <label class="text-sm font-medium">Baslik</label>
                    <input type="text" name="title" placeholder="Tasarimina bir isim ver" class="mt-2 w-full rounded-xl border border-border bg-background px-4 py-3 text-sm focus:border-primary focus:outline-none" required />
                </div>

                <!-- Description -->
                <div class="mt-4">
                    <label class="text-sm font-medium">Aciklama</label>
                    <textarea name="description" placeholder="Tasarimin hakkinda biraz bilgi ver..." rows="3" class="mt-2 w-full resize-none rounded-xl border border-border bg-background px-4 py-3 text-sm focus:border-primary focus:outline-none"></textarea>
                </div>

                <!-- Footer Actions -->
                <div class="mt-8 flex items-center justify-end gap-4">
                    <button type="button" onclick="closeCreateModal()" class="rounded-xl px-6 py-3 font-semibold text-muted-foreground transition-colors hover:bg-secondary hover:text-foreground">Iptal</button>
                    <button type="submit" class="flex items-center gap-2 rounded-xl bg-primary px-6 py-3 font-semibold text-primary-foreground transition-opacity hover:opacity-90 neon-glow">
                        <i data-lucide="sparkles" class="h-4 w-4"></i>
                        Paylas
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Global Scripts -->
    <script>
        // Initialize Icon set
        lucide.createIcons();

        function previewImage(input) {
            const preview = document.getElementById('imagePreview');
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    preview.src = e.target.result;
                    preview.classList.remove('hidden');
                }
                reader.readAsDataURL(input.files[0]);
            } else {
                preview.src = '';
                preview.classList.add('hidden');
            }
        }

        // Global Modals
        window.openCreateModal = function() {
            var modal = document.getElementById('createModal');
            if (modal) {
                modal.classList.remove('hidden');
                modal.classList.add('flex');
            }
        };

        window.closeCreateModal = function() {
            var modal = document.getElementById('createModal');
            if (modal) {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
                // Reset form preview
                document.getElementById('imagePreview').classList.add('hidden');
                document.getElementById('imagePreview').src = '';
                if(modal.querySelector('form')) modal.querySelector('form').reset();
            }
        };

        // Likes & Follows Global Functions
        window.likePost = function (id) {
            fetch('/Social/LikePost/' + id, { method: 'POST' })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        const btns = document.querySelectorAll('.like-btn-' + id);
                        btns.forEach(btn => {
                            // Fix Tailwind override: Remove text-white, add text-accent
                            if (data.liked) {
                                btn.classList.remove('text-white');
                                btn.classList.add('text-accent', 'fill-accent', 'bg-accent/20');
                            } else {
                                btn.classList.add('text-white');
                                btn.classList.remove('text-accent', 'fill-accent', 'bg-accent/20');
                            }
                            const icon = btn.querySelector('svg'); // Lucide replaces <i> with <svg>
                            if(icon) {
                                if(data.liked) icon.setAttribute('fill', 'currentColor');
                                else icon.setAttribute('fill', 'none');
                            }
                        });
                        
                        // Like count is in a different div, fetch it globally!
                        const countEls = document.querySelectorAll('.like-count-' + id);
                        countEls.forEach(countEl => {
                            let count = parseInt(countEl.textContent.replace(/,/g, '')) || 0;
                            countEl.textContent = data.liked ? (count + 1) : (Math.max(0, count - 1));
                            // Optional scaling animation
                            countEl.parentElement.classList.add('scale-125');
                            setTimeout(() => countEl.parentElement.classList.remove('scale-125'), 200);
                        });
                    }
                })
                .catch(err => console.error('Like error:', err));
        };

        window.savePost = function (id) {
            fetch('/Social/SavePost/' + id, { method: 'POST' })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        const btns = document.querySelectorAll('.save-btn-' + id);
                        btns.forEach(btn => {
                            if (data.saved) {
                                btn.classList.remove('text-white');
                                btn.classList.add('text-primary', 'fill-primary', 'bg-primary/20');
                            } else {
                                btn.classList.add('text-white');
                                btn.classList.remove('text-primary', 'fill-primary', 'bg-primary/20');
                            }
                            const icon = btn.querySelector('svg');
                            if(icon) {
                                if(data.saved) icon.setAttribute('fill', 'currentColor');
                                else icon.setAttribute('fill', 'none');
                            }
                        });
                    }
                })
                .catch(err => console.error('Save error:', err));
        };

        window.followDesigner = function (id) {
            if (!id || id === 0) { alert('Geçersiz kullanıcı'); return; }

            fetch('/Social/FollowDesigner/' + id, { method: 'POST' })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        const btns = document.querySelectorAll('.follow-btn-' + id);
                        btns.forEach(btn => {
                            if (data.following) {
                                btn.textContent = 'Takip Ediliyor';
                                btn.classList.remove('bg-primary', 'text-primary-foreground');
                                btn.classList.add('bg-secondary', 'text-secondary-foreground');
                            } else {
                                btn.textContent = 'Takip Et';
                                btn.classList.add('bg-primary', 'text-primary-foreground');
                                btn.classList.remove('bg-secondary', 'text-secondary-foreground');
                            }
                        });
                    } else {
                        alert(data.message || 'İşlem başarısız');
                    }
                })
                .catch(err => console.error('Follow error:', err));
        };
        
        // Header Dropdowns
        window.toggleDropdown = function(id) {
            const dropdown = document.getElementById(id);
            if(dropdown) {
                dropdown.classList.toggle('hidden');
            }
        };

        document.addEventListener('click', function(event) {
            const notifDropdown = document.getElementById('notifDropdown');
            const msgDropdown = document.getElementById('msgDropdown');
            const notifBtn = document.getElementById('notifBtn');
            const msgBtn = document.getElementById('msgBtn');

            if (notifDropdown && notifBtn && !notifDropdown.contains(event.target) && !notifBtn.contains(event.target)) {
                notifDropdown.classList.add('hidden');
            }
            if (msgDropdown && msgBtn && !msgDropdown.contains(event.target) && !msgBtn.contains(event.target)) {
                msgDropdown.classList.add('hidden');
            }
        });

    </script>
    
    <!-- Create Stream Modal -->
    <div id="createStreamModal" class="fixed inset-0 z-[60] hidden items-center justify-center">
        <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="closeCreateStreamModal()"></div>
        <div class="relative z-10 w-full max-w-lg mx-4">
            <div class="rounded-3xl border border-border bg-card p-6 shadow-2xl relative overflow-hidden">
                <div class="absolute -right-20 -top-20 h-40 w-40 rounded-full bg-destructive/20 blur-3xl"></div>
                <div class="relative z-10">
                    <div class="flex items-center justify-between mb-6">
                        <h2 class="text-2xl font-bold flex items-center gap-2">
                            <i data-lucide="video" class="h-6 w-6 text-destructive"></i> 
                            Yayın Başlat
                        </h2>
                        <button onclick="closeCreateStreamModal()" class="flex h-8 w-8 items-center justify-center rounded-full hover:bg-secondary transition-colors">
                            <i data-lucide="x" class="h-4 w-4"></i>
                        </button>
                    </div>

                    <form onsubmit="submitStreamRequest(event)" class="space-y-4">
                        <div>
                            <label class="text-sm font-medium mb-1.5 block">Yayın Başlığı</label>
                            <input type="text" id="streamTitleInput" required placeholder="Örn: Figma ile Sıfırdan Dashboard..." class="w-full rounded-xl border border-border bg-background px-4 py-3 text-sm focus:border-destructive focus:outline-none focus:ring-1 focus:ring-destructive" />
                        </div>
                        
                        <div>
                            <label class="text-sm font-medium mb-1.5 block">Kategori / Etiketler</label>
                            <input type="text" placeholder="#ui #figma" class="w-full rounded-xl border border-border bg-background px-4 py-3 text-sm focus:border-destructive focus:outline-none focus:ring-1 focus:ring-destructive" />
                        </div>

                        <div>
                            <label class="text-sm font-medium mb-1.5 block">Kamera ve Mikrofon Önizlemesi</label>
                            <div class="rounded-2xl bg-black aspect-video flex items-center justify-center text-muted-foreground border border-border relative overflow-hidden" id="cameraPreviewContainer" onclick="forcePlayVideo()">
                                <i id="cameraOffIcon" data-lucide="camera-off" class="h-8 w-8"></i>
                                <video id="previewVideo" class="absolute inset-0 w-full h-full object-cover" autoplay muted playsinline style="z-index: 5; transform: scaleX(-1); display: none;"></video>
                                
                                <div id="forcePlayOverlay" class="absolute inset-0 z-20 bg-black/40 backdrop-blur-sm flex flex-col items-center justify-center gap-3 cursor-pointer hidden">
                                    <div class="h-12 w-12 rounded-full bg-primary flex items-center justify-center text-white animate-pulse">
                                        <i data-lucide="play" class="h-6 w-6"></i>
                                    </div>
                                    <p class="text-xs font-bold text-white">Görüntüyü Başlatmak İçin Tıklayın</p>
                                </div>

                                <div id="cameraStatusText" class="absolute top-2 left-2 z-30 bg-black/60 text-[10px] text-white px-2 py-0.5 rounded-full hidden">
                                    Bağlı: <span id="cameraName">...</span>
                                </div>

                                <div class="absolute bottom-4 flex gap-2 z-10">
                                    <button type="button" onclick="startStream(); event.stopPropagation();" class="h-8 px-3 rounded-full bg-primary/80 hover:bg-primary flex items-center justify-center backdrop-blur text-white text-xs font-bold transition-all">
                                        <i data-lucide="refresh-cw" class="h-3 w-3 mr-1"></i> Kamerayı Yenile
                                    </button>
                                </div>
                            </div>
                        </div>

                        <button type="submit" class="mt-4 w-full rounded-xl bg-destructive py-3.5 text-sm font-bold text-destructive-foreground transition-all hover:bg-destructive/90 flex items-center justify-center gap-2 shadow-lg shadow-destructive/20">
                            <i data-lucide="radio" class="h-4 w-4"></i> Canlı Yayına Geç
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
