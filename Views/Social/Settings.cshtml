@{
    Layout = "_SocialLayoutModern";
    ViewData["Title"] = "Ayarlar";
}

<!-- Header -->
<header class="sticky top-0 z-30 flex h-14 md:h-16 items-center justify-between border-b border-border bg-background/95 px-3 md:px-6 backdrop-blur">
    <div class="flex items-center gap-3 md:gap-4">
        <h1 class="text-lg md:text-xl font-bold">Ayarlar</h1>
    </div>
</header>

<div class="mx-auto max-w-4xl p-3 md:p-6 pb-20 md:pb-6">
    <!-- Profile Card (Quick Settings) -->
    <div class="rounded-2xl md:rounded-3xl glass-card p-4 sm:p-6 md:p-8 flex flex-col sm:flex-row items-center gap-4 md:gap-6 relative overflow-hidden border-border/50">
        <!-- Glow -->
        <div class="absolute -right-20 -top-20 h-64 w-64 rounded-full bg-primary/10 blur-3xl"></div>
        
        <div class="relative group">
            <img src="https://ui-avatars.com/api/?name=@(Uri.EscapeDataString(User.Identity.Name ?? "M"))&background=random&size=256" class="h-24 w-24 sm:h-28 sm:w-28 rounded-2xl object-cover ring-4 ring-background shadow-xl bg-secondary" />
            <div class="absolute inset-0 bg-black/50 rounded-2xl flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity cursor-pointer">
                <i data-lucide="camera" class="h-8 w-8 text-white"></i>
            </div>
            <div class="absolute -bottom-3 -right-3 flex h-10 w-10 items-center justify-center rounded-xl bg-primary text-sm font-bold text-primary-foreground border-4 border-background shadow-lg shadow-primary/20">
                @(ViewBag.UserLevel ?? 1)
            </div>
        </div>
        
        <div class="flex-1 text-center sm:text-left z-10">
            <h2 class="text-2xl font-black">@(User.Identity.Name ?? "Kullanici Adi")</h2>
            <p class="text-lg text-primary font-medium mt-1">@@@(User.Identity.Name?.ToLower().Replace(" ", "") ?? "kullanici")</p>
            <p class="mt-2 text-sm text-muted-foreground max-w-md mx-auto sm:mx-0 line-clamp-2">Profil detaylarinizi guncelleyin ve hesabinizin nasil gorundugunu yonetin.</p>
        </div>
        
        <div class="z-10 w-full sm:w-auto">
            <a href="/Social/Profil/me" class="w-full sm:w-auto flex items-center justify-center gap-2 rounded-xl bg-secondary px-6 py-3 text-sm font-bold transition-all hover:bg-secondary/80 text-foreground">
                <i data-lucide="external-link" class="h-4 w-4"></i> Profili Gor
            </a>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-8 mt-6 md:mt-8">
        
        <!-- Settings Sidebar Navigation -->
        <div class="md:col-span-4 lg:col-span-3">
            <div class="sticky top-24 space-y-1">
                <button onclick="switchSettingsTab('account')" id="nav-account" class="w-full flex items-center gap-3 rounded-xl px-4 py-3 text-sm font-bold transition-all bg-primary/10 text-primary">
                    <i data-lucide="user" class="h-5 w-5"></i> Hesap
                </button>
                <button onclick="switchSettingsTab('appearance')" id="nav-appearance" class="w-full flex items-center gap-3 rounded-xl px-4 py-3 text-sm font-bold transition-all text-muted-foreground hover:bg-secondary hover:text-foreground">
                    <i data-lucide="palette" class="h-5 w-5"></i> Gorunum
                </button>
                <button onclick="switchSettingsTab('notifications')" id="nav-notifications" class="w-full flex items-center gap-3 rounded-xl px-4 py-3 text-sm font-bold transition-all text-muted-foreground hover:bg-secondary hover:text-foreground">
                    <i data-lucide="bell" class="h-5 w-5"></i> Bildirimler
                </button>
                <button onclick="switchSettingsTab('privacy')" id="nav-privacy" class="w-full flex items-center gap-3 rounded-xl px-4 py-3 text-sm font-bold transition-all text-muted-foreground hover:bg-secondary hover:text-foreground">
                    <i data-lucide="shield" class="h-5 w-5"></i> Gizlilik
                </button>
                
                <div class="pt-4 mt-4 border-t border-border/50">
                    <button onclick="logout()" class="w-full flex items-center gap-3 rounded-xl px-4 py-3 text-sm font-bold text-destructive hover:bg-destructive/10 transition-colors">
                        <i data-lucide="log-out" class="h-5 w-5"></i> Cikis Yap
                    </button>
                </div>
            </div>
        </div>
        
        <!-- Settings Content Area -->
        <div class="md:col-span-8 lg:col-span-9">
            
            <!-- Account Tab -->
            <div id="tab-account" class="space-y-6 animate-in fade-in duration-300">
                <div class="rounded-2xl glass-card p-6 border-transparent">
                    <h3 class="font-bold text-lg mb-6 flex items-center gap-2">
                        <i data-lucide="user-circle" class="h-5 w-5 text-primary"></i> Temel Bilgiler
                    </h3>
                    
                    <div class="space-y-4">
                        <div>
                            <label class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-2 block">Tam Ad</label>
                            <input type="text" value="@(User.Identity.Name ?? "")" class="w-full rounded-xl bg-secondary/50 border border-border/50 px-4 py-3 text-sm outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all" />
                        </div>
                        
                        <div>
                            <label class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-2 block">Kullanici Adi</label>
                            <div class="relative">
                                <span class="absolute left-4 top-1/2 -translate-y-1/2 text-muted-foreground">@@</span>
                                <input type="text" value="@(User.Identity.Name?.ToLower().Replace(" ", "") ?? "")" class="w-full rounded-xl bg-secondary/50 border border-border/50 pl-10 pr-4 py-3 text-sm outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all" />
                            </div>
                        </div>
                        
                        <div>
                            <label class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-2 block">Biyografi</label>
                            <textarea rows="3" placeholder="Kendinden bahset..." class="w-full rounded-xl bg-secondary/50 border border-border/50 px-4 py-3 text-sm outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all resize-none"></textarea>
                        </div>
                        
                        <div class="pt-2 flex justify-end">
                            <button class="rounded-xl bg-primary px-6 py-2.5 text-sm font-bold text-primary-foreground hover:opacity-90 neon-glow transition-all">
                                Degisiklikleri Kaydet
                            </button>
                        </div>
                    </div>
                </div>
                
                <div class="rounded-2xl glass-card p-6 border-transparent">
                    <h3 class="font-bold text-lg mb-6 flex items-center gap-2">
                        <i data-lucide="mail" class="h-5 w-5 text-primary"></i> Iletisim Bilgileri
                    </h3>
                    <div class="space-y-4">
                        <div>
                            <label class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-2 block">E-posta</label>
                            <input type="email" placeholder="ornek@email.com" class="w-full rounded-xl bg-secondary/50 border border-border/50 px-4 py-3 text-sm outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Appearance Tab -->
            <div id="tab-appearance" class="space-y-6 hidden animate-in fade-in duration-300">
                <div class="rounded-2xl glass-card p-6 border-transparent">
                    <h3 class="font-bold text-lg mb-2 flex items-center gap-2">
                        <i data-lucide="palette" class="h-5 w-5 text-primary"></i> Tema Tercihi
                    </h3>
                    <p class="text-sm text-muted-foreground mb-6">Arayuzun nasil gorunecegini secin.</p>
                    
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                        <button onclick="setTheme('dark')" id="theme-dark" class="group flex flex-col items-center gap-3 rounded-2xl border-2 border-primary bg-secondary/20 p-5 transition-all text-foreground h-full relative overflow-hidden">
                            <div class="absolute inset-x-0 top-0 h-1 bg-primary"></div>
                            <div class="h-16 w-full rounded-xl bg-[#09090b] border border-white/10 flex items-center justify-center shadow-sm">
                                <div class="h-8 w-1/2 rounded bg-[#27272a] mx-2"></div>
                            </div>
                            <span class="text-sm font-bold flex items-center gap-2 mt-auto pt-2">
                                <i data-lucide="moon" class="h-4 w-4"></i> Karanlik
                            </span>
                        </button>
                        
                        <button onclick="setTheme('light')" id="theme-light" class="group flex flex-col items-center gap-3 rounded-2xl border-2 border-border/50 bg-card p-5 transition-all hover:border-border text-foreground h-full">
                            <div class="h-16 w-full rounded-xl bg-slate-50 border border-slate-200 flex items-center justify-center shadow-sm">
                                <div class="h-8 w-1/2 rounded bg-white border border-slate-200 mx-2"></div>
                            </div>
                            <span class="text-sm font-bold flex items-center gap-2 mt-auto pt-2">
                                <i data-lucide="sun" class="h-4 w-4 text-muted-foreground group-hover:text-foreground"></i> Aydinlik
                            </span>
                        </button>
                        
                        <button onclick="setTheme('system')" id="theme-system" class="group flex flex-col items-center gap-3 rounded-2xl border-2 border-border/50 bg-card p-5 transition-all hover:border-border text-foreground h-full">
                            <div class="h-16 w-full rounded-xl bg-gradient-to-r from-slate-50 to-[#09090b] border border-border flex items-center justify-center shadow-sm">
                                <div class="h-8 w-1/2 rounded bg-card/50 backdrop-blur-sm border border-border/50 mx-2"></div>
                            </div>
                            <span class="text-sm font-bold flex items-center gap-2 mt-auto pt-2">
                                <i data-lucide="monitor" class="h-4 w-4 text-muted-foreground group-hover:text-foreground"></i> Sistem
                            </span>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Notifications Tab -->
            <div id="tab-notifications" class="space-y-6 hidden animate-in fade-in duration-300">
                <div class="rounded-2xl glass-card p-6 border-transparent">
                    <h3 class="font-bold text-lg mb-6 flex items-center gap-2">
                        <i data-lucide="bell" class="h-5 w-5 text-primary"></i> Push Bildirimleri
                    </h3>
                    
                    <div class="space-y-6">
                        <div class="flex items-start justify-between">
                            <div class="flex items-start gap-4 pr-4">
                                <div class="mt-1 h-8 w-8 shrink-0 rounded-full bg-pink-500/10 flex items-center justify-center text-pink-500">
                                    <i data-lucide="heart" class="h-4 w-4"></i>
                                </div>
                                <div>
                                    <p class="font-bold">Begeniler</p>
                                    <p class="text-sm text-muted-foreground mt-1">Birisi tasarimini begendiginde bildirim alirsiniz.</p>
                                </div>
                            </div>
                            <label class="relative inline-flex items-center cursor-pointer mt-2">
                                <input type="checkbox" checked class="sr-only peer">
                                <div class="w-11 h-6 bg-secondary rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                            </label>
                        </div>
                        
                        <div class="w-full h-px bg-border/50"></div>
                        
                        <div class="flex items-start justify-between">
                            <div class="flex items-start gap-4 pr-4">
                                <div class="mt-1 h-8 w-8 shrink-0 rounded-full bg-blue-500/10 flex items-center justify-center text-blue-500">
                                    <i data-lucide="message-square" class="h-4 w-4"></i>
                                </div>
                                <div>
                                    <p class="font-bold">Yorumlar ve Yanitlar</p>
                                    <p class="text-sm text-muted-foreground mt-1">Tasarimlariniza yorum yapildiginda veya yanitlandiginda.</p>
                                </div>
                            </div>
                            <label class="relative inline-flex items-center cursor-pointer mt-2">
                                <input type="checkbox" checked class="sr-only peer">
                                <div class="w-11 h-6 bg-secondary rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                            </label>
                        </div>
                        
                        <div class="w-full h-px bg-border/50"></div>
                        
                        <div class="flex items-start justify-between">
                            <div class="flex items-start gap-4 pr-4">
                                <div class="mt-1 h-8 w-8 shrink-0 rounded-full bg-green-500/10 flex items-center justify-center text-green-500">
                                    <i data-lucide="user-plus" class="h-4 w-4"></i>
                                </div>
                                <div>
                                    <p class="font-bold">Yeni Takipciler</p>
                                    <p class="text-sm text-muted-foreground mt-1">Biri sizi takip etmeye basladiginda haber ver.</p>
                                </div>
                            </div>
                            <label class="relative inline-flex items-center cursor-pointer mt-2">
                                <input type="checkbox" checked class="sr-only peer">
                                <div class="w-11 h-6 bg-secondary rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Privacy Tab -->
            <div id="tab-privacy" class="space-y-6 hidden animate-in fade-in duration-300">
                <div class="rounded-2xl glass-card p-6 border-transparent">
                    <h3 class="font-bold text-lg mb-6 flex items-center gap-2">
                        <i data-lucide="shield" class="h-5 w-5 text-primary"></i> Gizlilik & Guvenlik
                    </h3>
                    
                    <div class="space-y-3">
                        <button class="w-full flex items-center justify-between rounded-xl p-4 bg-secondary/30 transition-all hover:bg-secondary/60 group">
                            <div class="flex items-center gap-4">
                                <div class="h-10 w-10 rounded-full bg-background flex items-center justify-center text-muted-foreground group-hover:text-primary transition-colors shadow-sm">
                                    <i data-lucide="key" class="h-5 w-5"></i>
                                </div>
                                <div class="text-left">
                                    <span class="font-bold block">Sifreyi Degistir</span>
                                    <span class="text-xs text-muted-foreground">Hesap guvenliginiz icin duzenli olarak sifrenizi yenileyin.</span>
                                </div>
                            </div>
                            <i data-lucide="chevron-right" class="h-5 w-5 text-muted-foreground"></i>
                        </button>
                        
                        <button class="w-full flex items-center justify-between rounded-xl p-4 bg-secondary/30 transition-all hover:bg-secondary/60 group">
                            <div class="flex items-center gap-4">
                                <div class="h-10 w-10 rounded-full bg-background flex items-center justify-center text-muted-foreground group-hover:text-primary transition-colors shadow-sm">
                                    <i data-lucide="smartphone" class="h-5 w-5"></i>
                                </div>
                                <div class="text-left">
                                    <span class="font-bold block flex items-center gap-2">
                                        Iki Faktörlü Doğrulama <span class="bg-accent/20 text-accent text-[10px] uppercase font-bold px-2 py-0.5 rounded-full">Onerilen</span>
                                    </span>
                                    <span class="text-xs text-muted-foreground">Hesabiniza ekstra bir guvenlik katmani ekleyin.</span>
                                </div>
                            </div>
                            <i data-lucide="chevron-right" class="h-5 w-5 text-muted-foreground"></i>
                        </button>
                        
                        <div class="pt-6 mt-2 border-t border-border/50">
                            <button class="w-full flex items-center justify-between rounded-xl p-4 bg-destructive/5 border border-destructive/20 transition-all hover:bg-destructive/10 group">
                                <div class="flex items-center gap-4">
                                    <div class="h-10 w-10 rounded-full bg-destructive/10 flex items-center justify-center text-destructive transition-colors">
                                        <i data-lucide="trash-2" class="h-5 w-5"></i>
                                    </div>
                                    <div class="text-left">
                                        <span class="font-bold text-destructive block">Hesabi Sil</span>
                                        <span class="text-xs text-muted-foreground">Hesabinizi ve tum verilerinizi kalici olarak silin.</span>
                                    </div>
                                </div>
                                <i data-lucide="chevron-right" class="h-5 w-5 text-destructive/50"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        var currentTheme = 'dark'; // From db/layout defaults
        
        function switchSettingsTab(tabName) {
            var tabs = ['account', 'appearance', 'notifications', 'privacy'];
            
            tabs.forEach(function(t) {
                var btn = document.getElementById('nav-' + t);
                var content = document.getElementById('tab-' + t);
                
                if (btn && content) {
                    if (t === tabName) {
                        btn.className = 'w-full flex items-center gap-3 rounded-xl px-4 py-3 text-sm font-bold transition-all bg-primary/10 text-primary';
                        content.classList.remove('hidden');
                        
                        var icon = btn.querySelector('i');
                        if(icon) {
                            var iconName = icon.getAttribute('data-lucide');
                            icon.outerHTML = `<i data-lucide="${iconName}" class="h-5 w-5"></i>`;
                        }
                    } else {
                        btn.className = 'w-full flex items-center gap-3 rounded-xl px-4 py-3 text-sm font-bold transition-all text-muted-foreground hover:bg-secondary hover:text-foreground';
                        content.classList.add('hidden');
                        
                        var icon = btn.querySelector('i');
                        if(icon) {
                            var iconName = icon.getAttribute('data-lucide');
                            icon.outerHTML = `<i data-lucide="${iconName}" class="h-5 w-5"></i>`;
                        }
                    }
                }
            });
            lucide.createIcons();
        }
        
        function setTheme(theme) {
            currentTheme = theme;
            var themes = ['dark', 'light', 'system'];
            
            themes.forEach(function(t) {
                var btn = document.getElementById('theme-' + t);
                if (btn) {
                    if (t === theme) {
                        btn.className = 'group flex flex-col items-center gap-3 rounded-2xl border-2 border-primary bg-secondary/20 p-5 transition-all text-foreground h-full relative overflow-hidden';
                        var activeDiv = btn.querySelector('.absolute.inset-x-0');
                        if(!activeDiv) {
                            btn.insertAdjacentHTML('afterbegin', '<div class="absolute inset-x-0 top-0 h-1 bg-primary"></div>');
                        }
                        
                        var icon = btn.querySelector('i');
                        if(icon) icon.className = icon.className.replace('text-muted-foreground', 'text-foreground');
                    } else {
                        btn.className = 'group flex flex-col items-center gap-3 rounded-2xl border-2 border-border/50 bg-card p-5 transition-all hover:border-border text-foreground h-full';
                        var activeDiv = btn.querySelector('.absolute.inset-x-0');
                        if(activeDiv) activeDiv.remove();
                        
                        var icon = btn.querySelector('i');
                        if(icon) {
                           if(!icon.className.includes('text-muted-foreground')) {
                               icon.className = icon.className.replace('text-foreground', 'text-muted-foreground group-hover:text-foreground');
                           }
                        }
                    }
                }
            });
            
            // Apply logic to HTML DOM (simulated for preview)
            if (theme === 'light') {
                document.documentElement.classList.remove('dark');
            } else if (theme === 'dark') {
                document.documentElement.classList.add('dark');
            } else {
                // system default checking
                if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
                    document.documentElement.classList.add('dark');
                } else {
                    document.documentElement.classList.remove('dark');
                }
            }
        }
        
        function logout() {
            if (confirm('Cikis yapmak istedigine emin misin?')) {
                window.location.href = '/Account/Cikis';
            }
        }
    </script>
}
