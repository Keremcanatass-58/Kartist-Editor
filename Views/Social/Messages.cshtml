@{
    Layout = "_SocialLayoutModern";
    ViewData["Title"] = "Mesajlar";
}

<div class="flex h-[calc(100vh-4rem)] md:h-screen w-full bg-background overflow-hidden relative border-t border-border/50 md:border-none">
    
    <!-- Dynamic Background Accent -->
    <div class="absolute -top-[10%] -right-[10%] h-[40%] w-[40%] rounded-full bg-primary/5 blur-[120px] pointer-events-none"></div>
    <div class="absolute -bottom-[10%] -left-[10%] h-[40%] w-[40%] rounded-full bg-accent/5 blur-[120px] pointer-events-none"></div>

    <!-- Conversations Sidebar -->
    <div class="w-full md:w-80 lg:w-96 border-r border-border/50 flex flex-col bg-card/20 backdrop-blur-sm shrink-0 transition-transform duration-300 md:translate-x-0 absolute md:relative z-20 h-full" id="conversationsContainer">
        <!-- Header -->
        <div class="p-5 border-b border-border/50 backdrop-blur-xl bg-background/40 sticky top-0 z-10 shrink-0">
            <div class="flex items-center justify-between mb-4">
                <h1 class="text-2xl font-black tracking-tight flex items-center gap-2">
                    <span class="bg-gradient-to-r from-primary to-accent bg-clip-text text-transparent">Mesajlar</span>
                </h1>
                <button class="h-9 w-9 flex items-center justify-center rounded-xl bg-secondary/50 hover:bg-secondary transition-all text-muted-foreground hover:text-foreground">
                    <i data-lucide="plus" class="h-5 w-5"></i>
                </button>
            </div>
            
            <div class="relative group">
                <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground transition-colors group-focus-within:text-primary"></i>
                <input type="text" id="searchInput" placeholder="Sohbet ara..." onkeyup="searchConversations()" class="w-full rounded-xl bg-secondary/30 py-2.5 pl-10 pr-4 text-sm outline-none placeholder:text-muted-foreground/60 focus:ring-2 focus:ring-primary/20 focus:bg-secondary/50 border border-border/30 transition-all font-medium" />
            </div>
        </div>

        <!-- Conversation List -->
        <div class="flex-1 overflow-y-auto scrollbar-hide space-y-1 p-2" id="conversationList">
            @if (ViewBag.Conversations != null)
            {
                foreach (var conv in ViewBag.Conversations)
                {
                    var isUnread = conv.UnreadCount > 0;
                    <button onclick="selectConversation(@(conv.Id))" id="conv-@(conv.Id)" class="conv-item w-full flex items-start gap-3.5 p-3 rounded-2xl text-left transition-all hover:bg-secondary/40 border border-transparent hover:border-border/30 group @(isUnread ? "bg-primary/5" : "")">
                        <div class="relative shrink-0">
                            <div class="h-12 w-12 rounded-2xl overflow-hidden ring-2 ring-transparent transition-all group-hover:ring-primary/30">
                                <img src="@(conv.Avatar ?? "https://ui-avatars.com/api/?name=" + Uri.EscapeDataString(conv.Name ?? "U") + "&background=random")" class="h-full w-full object-cover" />
                            </div>
                            @if (isUnread)
                            {
                                <span class="absolute -right-1 -top-1 flex h-5 w-5 items-center justify-center rounded-lg bg-primary text-[10px] font-black text-primary-foreground border-2 border-background shadow-lg shadow-primary/30">
                                    @(conv.UnreadCount > 99 ? "99+" : conv.UnreadCount)
                                </span>
                            } else {
                                <div class="absolute -right-0.5 -bottom-0.5 block h-3.5 w-3.5 rounded-full bg-[#10b981] ring-2 ring-card shadow-sm"></div>
                            }
                        </div>
                        
                        <div class="flex-1 min-w-0 pt-0.5">
                            <div class="flex items-center justify-between mb-0.5">
                                <span class="font-bold text-sm truncate pr-2 @(isUnread ? "text-foreground" : "text-foreground/90")">@(conv.Name)</span>
                                <span class="text-[10px] whitespace-nowrap @(isUnread ? "text-primary font-bold" : "text-muted-foreground/70 font-medium")">@(conv.LastMessageAt)</span>
                            </div>
                            <p class="text-xs truncate block w-full @(isUnread ? "text-foreground font-semibold" : "text-muted-foreground/80")">@(conv.LastMessage)</p>
                        </div>
                    </button>
                }
            }
            else
            {
                <div class="h-full flex flex-col items-center justify-center p-8 text-center text-muted-foreground/70">
                    <div class="h-16 w-16 rounded-2xl bg-secondary/30 flex items-center justify-center mb-4 border border-border/20">
                        <i data-lucide="message-square-dashed" class="h-7 w-7 text-muted-foreground/50"></i>
                    </div>
                    <p class="font-bold text-sm">Mesaj kutusu boş</p>
                    <p class="text-xs mt-1 text-muted-foreground/60 font-medium">Yeni bir sohbet başlatın</p>
                </div>
            }
        </div>
    </div>

    <!-- Chat Area Box -->
    <div class="flex-1 flex flex-col bg-background/30 backdrop-blur-[2px] relative h-full w-full" id="chatArea">
        <!-- Empty State Default -->
        <div class="h-full flex flex-col items-center justify-center p-8 text-center" id="emptyChatState">
            <div class="group relative">
                <div class="h-32 w-32 rounded-[2.5rem] bg-gradient-to-br from-primary/20 to-accent/20 flex items-center justify-center mb-8 relative transition-transform group-hover:scale-105 duration-500">
                    <i data-lucide="sparkles" class="h-14 w-14 text-primary absolute animate-pulse"></i>
                    <div class="absolute inset-0 bg-primary/30 blur-3xl rounded-full opacity-50 group-hover:opacity-80 transition-opacity"></div>
                </div>
            </div>
            <h3 class="text-3xl font-black mb-3 tracking-tight">Kartist Mesaj Merkezi</h3>
            <p class="text-muted-foreground max-w-sm text-sm sm:text-base font-medium leading-relaxed italic">"İlhâm paylaştıkça çoğalır."</p>
            <div class="mt-8 flex gap-3">
                <button class="px-5 py-2.5 rounded-xl bg-secondary/50 border border-border/50 text-xs font-bold hover:bg-secondary transition-all">Rehber</button>
                <button class="px-5 py-2.5 rounded-xl bg-primary text-primary-foreground text-xs font-bold hover:opacity-90 transition-all shadow-lg shadow-primary/20">Yeni Sohbet</button>
            </div>
        </div>
        
        <!-- Chat Content Container (Hidden by Default) -->
        <div id="activeChatContainer" class="hidden flex-col h-full w-full bg-gradient-to-b from-card/10 to-transparent">
            <!-- Active Chat Header -->
            <div class="h-18 border-b border-border/30 bg-background/60 backdrop-blur-2xl px-4 sm:px-6 flex items-center justify-between shrink-0 sticky top-0 z-10">
                <div class="flex items-center gap-3 md:gap-4 py-3">
                    <!-- Mobile Back Button -->
                    <button onclick="closeMobileChat()" class="md:hidden flex h-9 w-9 items-center justify-center rounded-xl bg-secondary/50 text-muted-foreground mr-1">
                        <i data-lucide="arrow-left" class="h-5 w-5"></i>
                    </button>
                    
                    <div class="relative group cursor-pointer">
                        <img id="activeChatAvatar" src="https://ui-avatars.com/api/?name=User&background=random" class="h-11 w-11 sm:h-12 sm:w-12 rounded-2xl object-cover ring-2 ring-primary/10 transition-transform group-hover:scale-105 shadow-md" />
                        <div class="absolute -right-1 -bottom-1 block h-4 w-4 rounded-full bg-[#10b981] ring-2 ring-background shadow-sm"></div>
                    </div>
                    
                    <div class="cursor-pointer">
                        <p id="activeChatName" class="font-black text-base leading-tight">Yükleniyor...</p>
                        <div class="flex items-center gap-1.5 mt-0.5">
                            <span class="relative flex h-1.5 w-1.5">
                                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                                <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-green-500"></span>
                            </span>
                            <p id="chatStatusText" class="text-[11px] text-green-500 font-bold uppercase tracking-wider">Çevrimiçi</p>
                        </div>
                    </div>
                </div>
                
                <div class="flex items-center gap-1.5 sm:gap-3">
                    <div class="hidden sm:flex items-center bg-secondary/30 rounded-2xl p-1 border border-border/20">
                         <button class="h-9 w-9 flex items-center justify-center rounded-xl hover:bg-background text-muted-foreground hover:text-primary transition-all">
                            <i data-lucide="phone" class="h-4 w-4"></i>
                        </button>
                        <button class="h-9 w-9 flex items-center justify-center rounded-xl hover:bg-background text-muted-foreground hover:text-accent transition-all">
                            <i data-lucide="video" class="h-4 w-4"></i>
                        </button>
                    </div>
                   
                    <button class="h-10 w-10 flex items-center justify-center rounded-2xl bg-secondary/50 hover:bg-secondary text-muted-foreground hover:text-foreground transition-all">
                        <i data-lucide="layout-grid" class="h-5 w-5"></i>
                    </button>
                </div>
            </div>

            <!-- Messages Stream -->
            <div class="flex-1 overflow-y-auto p-4 sm:p-8 space-y-6 scrollbar-hide flex flex-col scroll-smooth" id="messagesList">
                <!-- Messages will be injected here via JS -->
            </div>

            <!-- Typing Indicator (Absolute below header) -->
            <div id="typingIndicator" class="hidden absolute left-8 top-20 z-10 px-4 py-2 bg-secondary/80 backdrop-blur-md rounded-2xl border border-border/30 text-[11px] font-bold text-muted-foreground animate-in slide-in-from-top-2 duration-300">
                <span class="flex items-center gap-2">
                    <span class="flex gap-0.5">
                        <span class="h-1.5 w-1.5 rounded-full bg-primary animate-bounce delay-75"></span>
                        <span class="h-1.5 w-1.5 rounded-full bg-primary animate-bounce delay-150"></span>
                        <span class="h-1.5 w-1.5 rounded-full bg-primary animate-bounce delay-300"></span>
                    </span>
                    bir şeyler yazıyor...
                </span>
            </div>

            <!-- Input Area -->
            <div class="p-4 sm:p-6 pb-6 bg-background/50 backdrop-blur-xl shrink-0">
                <div class="max-w-4xl mx-auto">
                    <div class="bg-secondary/40 backdrop-blur-md rounded-[2rem] border border-border/40 p-1.5 flex items-end gap-2 focus-within:ring-4 focus-within:ring-primary/10 focus-within:border-primary/40 transition-all shadow-2xl shadow-black/10">
                        <div class="flex items-center px-1 mb-1">
                            <button class="h-10 w-10 flex items-center justify-center rounded-full text-muted-foreground hover:text-primary hover:bg-primary/10 transition-all">
                                <i data-lucide="plus-circle" class="h-5 w-5"></i>
                            </button>
                        </div>
                        
                        <div class="flex-1 min-w-0">
                            <textarea id="messageInput" rows="1" placeholder="Mesajinizi buraya bırakın..." onkeypress="handleEnterKeyPress(event)" oninput="autoResizeTextarea(this)" class="w-full bg-transparent px-3 py-3 text-sm sm:text-[15px] outline-none resize-none max-h-40 min-h-[44px] overflow-y-auto block font-medium placeholder:text-muted-foreground/60 transition-all"></textarea>
                        </div>
                        
                        <div class="flex items-center gap-1.5 px-1 mb-1">
                             <button class="h-10 w-10 flex items-center justify-center rounded-full text-muted-foreground hover:text-yellow-500 transition-all">
                                <i data-lucide="sticky-note" class="h-5 w-5"></i>
                            </button>
                            <button onclick="sendMessage()" class="h-10 w-10 sm:h-11 sm:w-11 flex items-center justify-center rounded-full bg-primary text-primary-foreground hover:scale-105 active:scale-95 transition-all shadow-lg shadow-primary/20">
                                <i data-lucide="send" class="h-5 w-5 ml-0.5"></i>
                            </button>
                        </div>
                    </div>
                    <p class="text-[10px] text-center mt-3 text-muted-foreground/50 font-bold uppercase tracking-widest">Kartist Güvenli Mesajlaşma</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var currentConversationId = null;
        var myUserId = 0; // Replace with actual session logic
        
        // Ensure textarea resizes dynamically
        function autoResizeTextarea(el) {
            el.style.height = 'auto';
            el.style.height = (el.scrollHeight) + 'px';
        }
        
        function handleEnterKeyPress(e) {
            if(e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendMessage();
            }
        }
        
        function searchConversations() {
            var input = document.getElementById('searchInput');
            if (!input) return;
            var filter = input.value.toLowerCase();
            var items = document.getElementsByClassName('conv-item');
            
            for (var i = 0; i < items.length; i++) {
                var nameEl = items[i].querySelector('.font-semibold');
                if (!nameEl) continue;
                var name = nameEl.textContent;
                if (name.toLowerCase().indexOf(filter) > -1) {
                    items[i].style.display = 'flex';
                } else {
                    items[i].style.display = 'none';
                }
            }
        }
        
        function selectConversation(id) {
            currentConversationId = id;
            
            // Handle Mobile View Transitions
            if (window.innerWidth < 768) { // md breakpoint
                document.getElementById('conversationsContainer').classList.add('-translate-x-full');
            }
            
            // Highlight selected in sidebar
            var items = document.getElementsByClassName('conv-item');
            for (var i = 0; i < items.length; i++) {
                items[i].classList.remove('bg-secondary/50', 'bg-secondary/40', 'border-primary/30', 'ring-2', 'ring-primary/20');
            }
            var selectedConv = document.getElementById('conv-' + id);
            
            if (selectedConv) {
                selectedConv.classList.add('bg-secondary/40', 'ring-1', 'ring-primary/20');
                
                // Remove unread indicators when clicking
                const unreadBadge = selectedConv.querySelector('.bg-primary.text-primary-foreground');
                if (unreadBadge) {
                   unreadBadge.remove(); // simple way to mark read visually
                   selectedConv.classList.remove('bg-primary/5');
                   selectedConv.querySelector('.font-bold').classList.remove('font-bold');
                   selectedConv.querySelector('.font-semibold').classList.remove('font-semibold');
                   selectedConv.querySelector('p').classList.add('text-muted-foreground/80');
                }
                
                // Setup Header text
                var nameEl = selectedConv.querySelector('.font-bold') || selectedConv.querySelector('span');
                var avatarEl = selectedConv.querySelector('img');
                
                document.getElementById('activeChatName').textContent = nameEl ? nameEl.textContent : "Kullanici " + id;
                document.getElementById('activeChatAvatar').src = avatarEl ? avatarEl.src : "https://ui-avatars.com/api/?name=U&background=random";
            }
            
            // Swap empty state with active chat
            document.getElementById('emptyChatState').style.display = 'none';
            document.getElementById('activeChatContainer').style.display = 'flex';
            document.getElementById('activeChatContainer').classList.remove('hidden');
            
            var messagesList = document.getElementById('messagesList');
            messagesList.innerHTML = '<div class="h-full flex items-center justify-center"><i data-lucide="loader-2" class="h-8 w-8 text-primary animate-spin opacity-50"></i></div>';
            lucide.createIcons();

            // Mock Typing indicator logic
            setTimeout(() => {
                document.getElementById('typingIndicator').classList.remove('hidden');
                setTimeout(() => {
                   document.getElementById('typingIndicator').classList.add('hidden');
                }, 3000);
            }, 1000);

            // Fetch actual messages (Mocking here if fails)
            fetch('/Social/GetMesajlar?hedefId=' + id)
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    myUserId = data.myId || 0;
                    renderMessages(data.success ? data.mesajlar : []);
                })
                .catch(function() {
                    // Fallback Render Data
                    var mockMessages = [
                        { GonderenId: id, mesaj: "Merhaba, nasılsın? Yeni paylaştığın tasarımı çok beğendim!", createdAt: "10:30" },
                        { GonderenId: myUserId, mesaj: "Teşekkür ederim! Üzerinde baya uğraştım.", createdAt: "10:32" },
                        { GonderenId: id, mesaj: "Oklch renk kullanımı gerçekten harika durmuş. Hangi tool'ları kullandın?", createdAt: "10:35" }
                    ];
                    renderMessages(mockMessages);
                });
        }
        
        function closeMobileChat() {
            document.getElementById('conversationsContainer').classList.remove('-translate-x-full');
        }
        
        function renderMessages(mesajlar) {
            var messagesList = document.getElementById('messagesList');
            var messagesHtml = '';
            
            // Date Divider
            messagesHtml += `
                <div class="flex justify-center my-6">
                    <span class="text-[10px] font-black uppercase tracking-widest px-4 py-1.5 bg-secondary/40 rounded-full text-muted-foreground/60 border border-border/20 backdrop-blur-sm">Sohbet Başlangıcı</span>
                </div>
            `;
            
            if (mesajlar && mesajlar.length > 0) {
                messagesHtml += mesajlar.map(function(m, index) {
                    var isMine = (m.GonderenId == myUserId);
                    var txt = (m.Mesaj || m.mesaj || '');
                    var time = m.createdAt || "12:00";
                    
                    if (isMine) {
                        return `
                            <div class="flex gap-2 justify-end animate-in slide-in-from-bottom-2 fade-in duration-500" style="animation-fill-mode: both; animation-delay: ${index * 80}ms;">
                                <div class="flex flex-col items-end gap-1.5 max-w-[85%] sm:max-w-[70%] group/msg">
                                    <div class="relative rounded-3xl rounded-tr-md bg-gradient-to-br from-primary to-primary/90 px-4 py-2.5 sm:px-5 sm:py-3 shadow-lg shadow-primary/10 text-primary-foreground border border-white/10 group-hover/msg:scale-[1.01] transition-transform">
                                        <p class="text-sm sm:text-[15px] leading-relaxed break-words font-medium">${txt}</p>
                                    </div>
                                    <span class="text-[10px] text-muted-foreground/60 font-bold flex items-center gap-1.5 px-1">
                                        ${time} <i data-lucide="check-check" class="h-3 w-3 text-primary"></i>
                                    </span>
                                </div>
                            </div>
                        `;
                    } else {
                        return `
                            <div class="flex gap-3 animate-in slide-in-from-bottom-2 fade-in duration-500" style="animation-fill-mode: both; animation-delay: ${index * 80}ms;">
                                <div class="shrink-0 mt-auto pb-5">
                                    <img src="${document.getElementById('activeChatAvatar').src}" class="h-8 w-8 sm:h-9 sm:w-9 rounded-2xl object-cover ring-2 ring-primary/5 shadow-sm" />
                                </div>
                                <div class="flex flex-col items-start gap-1.5 max-w-[85%] sm:max-w-[70%] group/msg">
                                    <div class="rounded-3xl rounded-tl-md bg-secondary/80 backdrop-blur-md px-4 py-2.5 sm:px-5 sm:py-3 shadow-md border border-border/30 group-hover/msg:scale-[1.01] transition-transform">
                                        <p class="text-sm sm:text-[15px] leading-relaxed break-words text-foreground font-medium">${txt}</p>
                                    </div>
                                    <span class="text-[10px] text-muted-foreground/60 font-bold px-1">${time}</span>
                                </div>
                            </div>
                        `;
                    }
                }).join('');
            } else {
                messagesHtml += `
                    <div class="flex flex-col items-center justify-center p-12 text-center text-muted-foreground/40 h-full">
                        <i data-lucide="sparkles" class="h-12 w-12 mb-4 opacity-20"></i>
                        <p class="text-xs font-bold uppercase tracking-widest">Henüz mesaj yok</p>
                    </div>
                `;
            }
            
            messagesList.innerHTML = messagesHtml;
            lucide.createIcons();
            
            // Scroll to bottom
            setTimeout(() => {
                messagesList.scrollTop = messagesList.scrollHeight;
            }, 100);
        }
        
        function sendMessage() {
            var input = document.getElementById('messageInput');
            var message = input ? input.value.trim() : '';
            
            if (!message || !currentConversationId) return;
            
            var messagesList = document.getElementById('messagesList');
            var timeNow = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
            
            var messageHtml = `
                <div class="flex gap-2 justify-end animate-in slide-in-from-bottom-4 fade-in duration-300">
                    <div class="flex flex-col items-end gap-1.5 max-w-[85%] sm:max-w-[70%]">
                        <div class="rounded-3xl rounded-tr-md bg-gradient-to-br from-primary to-primary/80 px-4 py-2.5 sm:px-5 sm:py-3 shadow-xl shadow-primary/20 text-primary-foreground border border-white/10">
                            <p class="text-sm sm:text-[15px] leading-relaxed break-words font-medium">${message}</p>
                        </div>
                        <span class="text-[10px] text-muted-foreground/60 font-bold flex items-center gap-1.5 px-1">
                            ${timeNow} <i data-lucide="check" class="h-3 w-3 animate-pulse"></i>
                        </span>
                    </div>
                </div>
            `;
            
            // Remove empty state if present
            var emptyState = messagesList.querySelector('.flex-col.items-center');
            if (emptyState) emptyState.remove();
            
            messagesList.insertAdjacentHTML('beforeend', messageHtml);
            lucide.createIcons();
            
            // Reset Input
            input.value = '';
            input.style.height = 'auto'; // reset textarea height
            input.focus();
            
            // Scroll to bottom smoothly
            messagesList.scrollTo({
              top: messagesList.scrollHeight,
              behavior: 'smooth'
            });
            
            // Send to Backend
            fetch('/Social/MesajGonder', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'aliciId=' + currentConversationId + '&mesaj=' + encodeURIComponent(message)
            })
            .catch(function(err) { console.log('Mesaj API hatasi:', err); });
        }
    </script>
}
    </script>
}
