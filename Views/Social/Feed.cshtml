@section Scripts {
    <script>
        function filterCategory(cat) { 
            var buttons = document.querySelectorAll('.cat-filter-btn');
            for (var i = 0; i < buttons.length; i++) {
                buttons[i].classList.remove('bg-primary', 'text-primary-foreground', 'neon-glow'); 
                buttons[i].classList.add('bg-secondary', 'text-secondary-foreground'); 
            }
            var activeBtn = document.getElementById('cat-' + cat);
            if (activeBtn) {
                activeBtn.classList.add('bg-primary', 'text-primary-foreground', 'neon-glow'); 
                activeBtn.classList.remove('bg-secondary', 'text-secondary-foreground'); 
            }
        }
    </script>
}
