@{
    Layout = "_SocialLayout";
    ViewData["Title"] = "Sosyal Akış";
    string myIdStr = User.Claims.FirstOrDefault(c => c.Type == "Id")?.Value ?? "0";
}

@section RightWidgets {
    <!-- STATS BAR -->
    <div class="widget-card">
         <div class="widget-title"><i class="fa-solid fa-bolt" style="color:var(--gold)"></i> Durum & Gelişim</div>
         <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px;">
            <div style="background:var(--bg-hover); border-radius:var(--radius-sm); padding:12px; text-align:center;">
                <div style="font-size:1.3rem; font-weight:900; color:var(--red);" id="streakVal">0</div>
                <div style="font-size:0.65rem; color:var(--text-muted); font-weight:700; letter-spacing:1px;">STREAK</div>
            </div>
            <div style="background:var(--bg-hover); border-radius:var(--radius-sm); padding:12px; text-align:center;">
                <div style="font-size:1.3rem; font-weight:900; color:var(--blue);" id="levelVal">1</div>
                <div style="font-size:0.65rem; color:var(--text-muted); font-weight:700; letter-spacing:1px;">SEVİYE</div>
            </div>
            <div style="background:var(--bg-hover); border-radius:var(--radius-sm); padding:12px; text-align:center;">
                <div style="font-size:1.3rem; font-weight:900; color:var(--accent);" id="xpVal">0</div>
                <div style="font-size:0.65rem; color:var(--text-muted); font-weight:700; letter-spacing:1px;">XP</div>
            </div>
            <div style="background:var(--bg-hover); border-radius:var(--radius-sm); padding:12px; text-align:center;">
                <div style="font-size:1.3rem; font-weight:900; color:var(--gold);" id="badgeVal">0</div>
                <div style="font-size:0.65rem; color:var(--text-muted); font-weight:700; letter-spacing:1px;">ROZET</div>
            </div>
         </div>
    </div>

    <!-- DAILY QUESTS -->
    <div class="widget-card">
        <div class="widget-title"><i class="fa-solid fa-bullseye" style="color:var(--accent)"></i> Günlük Görevler</div>
        <div id="questsList" style="display:flex; flex-direction:column; gap:10px;"></div>
    </div>
}

<!-- HEADER with Feed Tabs -->
<div class="center-header">
    <h2>Ana Akış</h2>
    <div class="feed-tabs">
        <button class="feed-tab active" id="tabAll" onclick="switchFeedTab('yeni', this)">Sana Özel</button>
        <button class="feed-tab" id="tabFollowing" onclick="switchFeedTab('takip', this)">Takip Edilenler</button>
    </div>
</div>

<!-- OMNIBOX -->
<div class="omnibox">
    <div class="avatar-wrapper">
        <div class="avatar-initial" style="width:44px;height:44px;">@(User.Identity.Name?.Substring(0, 1).ToUpper())</div>
    </div>
    <div class="omnibox-input-area">
        <textarea class="omnibox-input" id="postTextInput" placeholder="Neler oluyor?"></textarea>
        
        <!-- Image & X-Ray Previews -->
        <div style="display:flex; gap:10px; margin-top:10px;">
            <div class="post-preview" id="previewContainer" style="display:none; position:relative; flex:1; max-width:140px;">
                <img id="imagePreview" style="width:100%; border-radius:8px;">
                <button class="post-preview-remove" onclick="removePreview()"><i class="fa-solid fa-xmark"></i></button>
            </div>
            
            <div class="post-preview" id="xrayPreviewContainer" style="display:none; position:relative; flex:1; max-width:140px; border:2px dashed var(--purple); border-radius:8px; padding:2px;">
                <img id="xrayImagePreview" style="width:100%; border-radius:6px;">
                <button class="post-preview-remove" onclick="removeXrayPreview()"><i class="fa-solid fa-xmark"></i></button>
                <div style="position:absolute; bottom:-12px; left:50%; transform:translateX(-50%); background:var(--purple); color:#fff; font-size:0.6rem; padding:2px 6px; border-radius:4px; white-space:nowrap; z-index:5;"><i class="fa-solid fa-arrows-left-right"></i> X-Ray (Sonra)</div>
            </div>
        </div>

        <!-- Code Input Area -->
        <div class="code-input-area" id="snippetContainer">
            <textarea id="postKodSnippetInput" placeholder="// Kod yapıştır (C#, JS, CSS vb.)"></textarea>
        </div>

        <div class="omnibox-actions">
            <div class="omnibox-tools">
                <label for="postImageInput" class="omnibox-tool" title="Fotoğraf Yükle">
                    <i class="fa-solid fa-image"></i>
                </label>
                <input type="file" id="postImageInput" accept="image/*" style="display:none" onchange="previewImage(this)">
                
                <label for="postOnceSonraInput" class="omnibox-tool" title="X-Ray (Sonrası Görüntü)" style="color:var(--purple)">
                    <i class="fa-solid fa-arrows-left-right"></i>
                </label>
                <input type="file" id="postOnceSonraInput" accept="image/*" style="display:none" onchange="previewXray(this)">

                <button class="omnibox-tool" title="Kod Parçacığı" onclick="toggleSnippet()" style="color:var(--blue)">
                    <i class="fa-solid fa-terminal"></i>
                </button>
            </div>
            <button class="btn-post" id="shareBtn" onclick="sharePost()" disabled>Paylaş</button>
        </div>
    </div>
</div>

<!-- STORIES BAR -->
<div style="display:flex; gap:14px; padding:16px 20px; overflow-x:auto; scrollbar-width:none; border-bottom:1px solid var(--border);" id="storyContainer">
    <div style="display:flex;flex-direction:column;align-items:center;gap:6px;cursor:pointer;flex-shrink:0;" onclick="openStoryUpload()">
        <div style="width:62px;height:62px;border-radius:50%;padding:2px;background:linear-gradient(135deg,#333,#555);">
            <div style="width:100%;height:100%;border-radius:50%;background:var(--bg-surface-solid);border:3px solid var(--bg-base);display:flex;align-items:center;justify-content:center;font-size:1.2rem;color:var(--accent);">
                <i class="fa-solid fa-plus"></i>
            </div>
        </div>
        <span style="font-size:0.65rem;color:var(--text-muted);">Sen</span>
    </div>
</div>

<!-- FEED POSTS -->
<div id="feedContainer"></div>

<!-- loading indicators -->
<div id="loadingMore" style="display:none;text-align:center;padding:20px;">
    <div style="display:inline-block;width:28px;height:28px;border:3px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin 0.7s linear infinite;"></div>
</div>
<style>@@keyframes spin { to { transform: rotate(360deg); } }</style>
<div id="noMorePosts" style="display:none;text-align:center;padding:30px;color:var(--text-muted);font-size:0.82rem;">
    <i class="fa-solid fa-check-circle" style="color:var(--accent);margin-right:6px;"></i> Tüm akış yüklendi
</div>

<!-- STORY VIEWER -->
<div style="position:fixed;inset:0;background:rgba(0,0,0,0.95);z-index:10000;display:none;align-items:center;justify-content:center;" id="storyViewer">
    <div style="position:relative;max-width:420px;width:100%;max-height:90vh;">
        <div id="storyProgressBar" style="display:flex;gap:4px;padding:8px 12px;position:absolute;top:0;left:0;right:0;z-index:2;"></div>
        <div id="storyUserInfo" style="position:absolute;top:18px;left:16px;display:flex;align-items:center;gap:10px;z-index:2;"></div>
        <button onclick="closeStoryViewer()" style="position:absolute;top:20px;right:16px;background:rgba(0,0,0,0.5);border:none;color:#fff;width:36px;height:36px;border-radius:50%;cursor:pointer;font-size:1.1rem;z-index:2;display:flex;align-items:center;justify-content:center;"><i class="fa-solid fa-xmark"></i></button>
        <button onclick="prevStory()" style="position:absolute;top:50%;left:-50px;transform:translateY(-50%);background:rgba(255,255,255,0.1);border:none;color:#fff;width:40px;height:40px;border-radius:50%;cursor:pointer;"><i class="fa-solid fa-chevron-left"></i></button>
        <button onclick="nextStory()" style="position:absolute;top:50%;right:-50px;transform:translateY(-50%);background:rgba(255,255,255,0.1);border:none;color:#fff;width:40px;height:40px;border-radius:50%;cursor:pointer;"><i class="fa-solid fa-chevron-right"></i></button>
        <img id="storyViewerImg" style="width:100%;max-height:85vh;object-fit:contain;border-radius:16px;">
    </div>
</div>

<!-- Story file input -->
<input type="file" id="storyFileInput" accept="image/*" style="display:none" onchange="uploadStory(this)">

@section Scripts {
<script>
    const MY_USER_ID = parseInt('@myIdStr') || 0;
    let feedPage = 0, feedFiltre = '@(ViewBag.Filtre ?? "yeni")', hasMore = true, isLoading = false;
    
    document.querySelectorAll('.feed-tab').forEach(t => {
        t.classList.toggle('active', (feedFiltre === 'takip' ? t.id === 'tabFollowing' : t.id === 'tabAll'));
    });
    
    // --- Omnibox ---
    const textInput = document.getElementById('postTextInput');
    const shareBtn = document.getElementById('shareBtn');
    const imgInput = document.getElementById('postImageInput');

    textInput.addEventListener('input', () => {
        textInput.style.height = 'auto';
        textInput.style.height = (textInput.scrollHeight) + 'px';
        updateShareBtn();
    });

    function updateShareBtn() {
        const hasText = textInput.value.trim().length > 0;
        const hasImage = imgInput.files && imgInput.files[0];
        const hasXray = document.getElementById('postOnceSonraInput').files && document.getElementById('postOnceSonraInput').files[0];
        const hasSnippet = document.getElementById('postKodSnippetInput').value.trim().length > 0;
        shareBtn.disabled = !hasText && !hasImage && !hasSnippet && !hasXray;
    }

    function previewImage(input) {
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = (e) => {
                document.getElementById('imagePreview').src = e.target.result;
                document.getElementById('previewContainer').style.display = 'block';
                updateShareBtn();
            };
            reader.readAsDataURL(input.files[0]);
        }
    }

    function removePreview() {
        imgInput.value = '';
        document.getElementById('previewContainer').style.display = 'none';
        updateShareBtn();
    }

    function previewXray(input) {
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = (e) => {
                document.getElementById('xrayImagePreview').src = e.target.result;
                document.getElementById('xrayPreviewContainer').style.display = 'block';
                updateShareBtn();
            };
            reader.readAsDataURL(input.files[0]);
        }
    }

    function removeXrayPreview() {
        document.getElementById('postOnceSonraInput').value = '';
        document.getElementById('xrayPreviewContainer').style.display = 'none';
        updateShareBtn();
    }

    function toggleSnippet() {
        const el = document.getElementById('snippetContainer');
        el.style.display = el.style.display === 'none' || el.style.display === '' ? 'block' : 'none';
        if (el.style.display === 'block') document.getElementById('postKodSnippetInput').focus();
    }

    function switchFeedTab(filtre, btn) {
        feedFiltre = filtre;
        document.querySelectorAll('.feed-tab').forEach(t => t.classList.remove('active'));
        btn.classList.add('active');
        feedPage = 0;
        hasMore = true;
        document.getElementById('feedContainer').innerHTML = '';
        document.getElementById('noMorePosts').style.display = 'none';
        loadFeed(true);
    }

    async function sharePost() {
        if (shareBtn.disabled) return;
        shareBtn.disabled = true;
        shareBtn.textContent = '...';

        const snippetData = document.getElementById('postKodSnippetInput').value || '';
        const onceSonraFile = document.getElementById('postOnceSonraInput').files[0];

        const fd = new FormData();
        fd.append('icerik', textInput.value);
        if (imgInput.files[0]) fd.append('gorsel', imgInput.files[0]);
        if (onceSonraFile) fd.append('onceSonraGorsel', onceSonraFile);
        if (snippetData) fd.append('kodSinipet', snippetData);
        fd.append('__RequestVerificationToken', CSRF());

        const data = await secureFetch('/Social/GonderiOlustur', 'POST', fd);
        
        if (data.success) {
            textInput.value = '';
            textInput.style.height = '48px';
            document.getElementById('postKodSnippetInput').value = '';
            document.getElementById('snippetContainer').style.display = 'none';
            removeXrayPreview();
            removePreview();
            shareBtn.disabled = true;
            shareBtn.textContent = 'Paylaş';
            showNeonToast('Gönderi paylaşıldı!', 'fa-paper-plane');
            loadFeed(true);
        } else {
            Swal.fire({ title: 'Hata', text: data.message || 'Gönderilemedi.', icon: 'error', background:'#111', color:'#fff' });
            shareBtn.disabled = false;
            shareBtn.textContent = 'Paylaş';
        }
    }

    // --- Skeleton HTML ---
    function skeletonHTML() {
        return `<div class="skeleton-post">
            <div class="skel skel-circle skel-avatar"></div>
            <div class="skel-body">
                <div class="skel skel-line w40"></div>
                <div class="skel skel-line w60" style="margin-top:8px"></div>
                <div class="skel skel-line w80"></div>
                <div class="skel skel-image"></div>
            </div>
        </div>`;
    }

    // --- FEED RENDERING ---
    async function loadFeed(refresh = false) {
        const container = document.getElementById('feedContainer');
        if (refresh) { 
            feedPage = 0; 
            hasMore = true;
            container.innerHTML = skeletonHTML() + skeletonHTML() + skeletonHTML();
        }
        
        if (isLoading || !hasMore) return;
        isLoading = true;
        if (!refresh) document.getElementById('loadingMore').style.display = 'block';

        try {
            const data = await secureFetch(`/Social/GetFeed?filtre=${feedFiltre}&sayfa=${feedPage}`);
            
            document.getElementById('loadingMore').style.display = 'none';
            if(refresh) container.innerHTML = '';

            if (!data.success) {
                hasMore = false;
                const msg = data.message || 'Akış yüklenemedi. Lütfen sayfayı yenileyin.';
                container.innerHTML = `<div style="text-align:center;padding:60px 20px;color:var(--text-muted);">
                    <i class="fa-regular fa-face-frown" style="font-size:3rem;display:block;margin-bottom:16px;opacity:0.3"></i>
                    ${escapeHtml(msg)}
                </div>`;
                return;
            }

            const items = data.posts || data.gonderiler || [];
            if (items.length === 0) {
                hasMore = false;
                if(feedPage > 0) document.getElementById('noMorePosts').style.display = 'block';
                else container.innerHTML = `<div style="text-align:center;padding:60px 20px;color:var(--text-muted);">
                    <i class="fa-regular fa-face-smile" style="font-size:3rem;display:block;margin-bottom:16px;opacity:0.3"></i>
                    Henüz gönderi yok. İlk paylaşan sen ol!
                </div>`;
            } else {
                items.forEach(g => renderPost(g, container));
                feedPage++;
                hasMore = data.hasMore !== false;
            }
        } catch(e) {
            console.error('Feed error:', e);
            hasMore = false;
            container.innerHTML = `<div style="text-align:center;padding:60px 20px;color:var(--text-muted);">
                <i class="fa-regular fa-face-frown" style="font-size:3rem;display:block;margin-bottom:16px;opacity:0.3"></i>
                Bir şeyler ters gitti, lütfen sayfayı yenileyin.
            </div>`;
        }
        finally { isLoading = false; }
    }

    function getField(obj, pascal, camel) {
        if (!obj) return undefined;
        return obj[pascal] ?? obj[camel];
    }

    function renderPost(g, container) {
        const div = document.createElement('article');
        div.className = 'post-card slide-up';
        div.id = `post-${getField(g, 'Id', 'id')}`;
        
        const userName = getField(g, 'AdSoyad', 'adSoyad') || getField(g, 'KullaniciAd', 'kullaniciAd') || '?';
        const userPhoto = getField(g, 'ProfilResmi', 'profilResmi') || getField(g, 'KullaniciFoto', 'kullaniciFoto');
        const isMyPost = getField(g, 'IsMyPost', 'isMyPost') === 1 || getField(g, 'IsMyPost', 'isMyPost') === true;
        
        // Vibe badge
        const vibeHtml = getField(g, 'AiVibe', 'aiVibe') ? `<div class="vibe-badge">${getField(g, 'AiVibe', 'aiVibe')} Vibe</div>` : '';
        
        // Media
        let mediaHtml = '';
        const gorselUrl = getField(g, 'GorselUrl', 'gorselUrl');
        const onceSonraResim = getField(g, 'OnceSonraResim', 'onceSonraResim');
        const kodSinipet = getField(g, 'KodSinipet', 'kodSinipet');
        const bodyText = getField(g, 'Icerik', 'icerik') || '';
        const isLiked = getField(g, 'Begenildi', 'begeniildi') === 1 || getField(g, 'Begenildi', 'begeniildi') === true;
        const likeCount = getField(g, 'BegeniSayisi', 'begeniSayisi') || 0;
        const commentCount = getField(g, 'YorumSayisi', 'yorumSayisi') || 0;
        const isSaved = getField(g, 'Kaydedildi', 'kaydedildi') === 1 || getField(g, 'Kaydedildi', 'kaydedildi') === true;
        
        if (onceSonraResim && gorselUrl) {
            mediaHtml = `<div class="xray-container" onmousemove="xrayMove(event,this)" ontouchmove="xrayTouch(event,this)">
                <img src="${normalizeMediaUrl(gorselUrl)}" class="xray-img">
                <img src="${normalizeMediaUrl(onceSonraResim)}" class="xray-img xray-after">
                <div class="xray-handle"></div>
                <span class="xray-label before">Önce</span>
                <span class="xray-label after">Sonra</span>
            </div>`;
        } else if (gorselUrl) {
            mediaHtml = `<div class="post-image-wrap" ondblclick="doubleTapLike(${getField(g, 'Id', 'id')}, this)">
                <img src="${normalizeMediaUrl(gorselUrl)}" class="post-image" loading="lazy">
                <i class="fa-solid fa-heart double-tap-heart"></i>
            </div>`;
        }

        // Code snippet
        const codeHtml = kodSinipet ? `<div class="code-snippet"><pre><code>${escapeHtml(kodSinipet)}</code></pre></div>` : '';

        // Post body (truncate long text)
        const truncated = bodyText.length > 280;
        const bodyClass = truncated ? 'post-body truncated' : 'post-body';
        const showMoreBtn = truncated ? `<button class="show-more-btn" onclick="this.previousElementSibling.classList.remove('truncated');this.remove();">devamını gör</button>` : '';
        const postId = getField(g, 'Id', 'id');
        const authorId = getField(g, 'KullaniciId', 'kullaniciId');
        const createdAt = getField(g, 'OlusturmaTarihi', 'olusturmaTarihi');

        div.innerHTML = `
            <div class="avatar-wrapper"><a href="/Social/Profil/${authorId}">${avatarHTML(userPhoto, userName, 44)}</a></div>
            <div class="post-content">
                <div class="post-meta">
                    <a href="/Social/Profil/${authorId}" class="post-author">${userName}</a>
                    <span class="post-dot">·</span>
                    <span class="post-time">${timeAgo(createdAt)}</span>
                    <div style="flex:1"></div>
                    <button class="post-menu-btn" onclick="togglePostMenu(${postId})"><i class="fa-solid fa-ellipsis"></i></button>
                </div>
                <div id="postMenu-${postId}" class="post-dropdown">
                    ${isMyPost ? `<div class="post-dropdown-item" onclick="editPost(${postId})"><i class="fa-solid fa-pen"></i> Düzenle</div>` : ''}
                    ${isMyPost ? `<div class="post-dropdown-item danger" onclick="deletePost(${postId})"><i class="fa-solid fa-trash"></i> Sil</div>` : ''}
                    <div class="post-dropdown-item" onclick="copyPostLink(${postId})"><i class="fa-solid fa-link"></i> Bağlantıyı Kopyala</div>
                    ${!isMyPost ? `<div class="post-dropdown-item danger" onclick="reportPost(${postId})"><i class="fa-solid fa-flag"></i> Bildir</div>` : ''}
                </div>
                ${vibeHtml}
                <div class="${bodyClass}">${parseText(bodyText)}</div>
                ${showMoreBtn}
                ${codeHtml}
                ${mediaHtml}
                
                <div class="post-actions">
                    <button class="action-btn like-btn ${isLiked ? 'liked' : ''}" onclick="begen(${postId})" id="btn-like-${postId}">
                        <i class="${isLiked ? 'fa-solid' : 'fa-regular'} fa-heart"></i>
                        <span id="like-count-${postId}">${likeCount > 0 ? likeCount : ''}</span>
                        <div class="like-particles"></div>
                    </button>
                    <button class="action-btn comment-btn" onclick="toggleComments(${postId})">
                        <i class="fa-regular fa-comment"></i>
                        <span>${commentCount > 0 ? commentCount : ''}</span>
                    </button>
                    <button class="action-btn repost-btn" onclick="repost(${postId})" id="btn-repost-${postId}">
                        <i class="fa-solid fa-retweet"></i>
                    </button>
                    <button class="action-btn save-btn ${isSaved ? 'saved' : ''}" onclick="kaydet(${postId})" id="btn-save-${postId}">
                        <i class="${isSaved ? 'fa-solid' : 'fa-regular'} fa-bookmark"></i>
                    </button>
                    ${!isMyPost ? `<button class="action-btn collab-btn" onclick="sendCollabRequest(${authorId}, ${postId})" title="İş Birliği">
                        <i class="fa-solid fa-bolt"></i>
                    </button>` : ''}
                    <button class="action-btn share-btn" onclick="copyPostLink(${postId})">
                        <i class="fa-solid fa-arrow-up-from-bracket"></i>
                    </button>
                </div>
                
                <div class="comments-section" id="comments-${postId}" style="display:none;">
                    <div id="comment-list-${postId}"></div>
                    <div class="comment-input-row">
                        <input type="text" id="comment-input-${postId}" class="comment-input" placeholder="Yanıtla..." onkeydown="if(event.key==='Enter')makeComment(${postId})">
                        <button class="comment-send" onclick="makeComment(${postId})">Gönder</button>
                    </div>
                </div>
            </div>
        `;
        container.appendChild(div);
    }

    function escapeHtml(text) {
        const d = document.createElement('div');
        d.textContent = text;
        return d.innerHTML;
    }

    function parseText(txt) {
        if (!txt) return '';
        return txt
            .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
            .replace(/#(\w+)/g, '<span class="hashtag" onclick="window.location.href=\'/Social/Kesf?hashtag=$1\'">#$1</span>')
            .replace(/@@(\w+)/g, '<span class="mention">@@$1</span>');
    }

    // --- X-RAY SLIDER ---
    function xrayMove(e, container) {
        const rect = container.getBoundingClientRect();
        const x = Math.max(0, Math.min(e.clientX - rect.left, rect.width));
        const pct = (x / rect.width) * 100;
        const afterImg = container.querySelector('.xray-after');
        const handle = container.querySelector('.xray-handle');
        if (afterImg) afterImg.style.clipPath = `polygon(${pct}% 0, 100% 0, 100% 100%, ${pct}% 100%)`;
        if (handle) handle.style.left = `${pct}%`;
    }
    function xrayTouch(e, container) {
        e.preventDefault();
        const touch = e.touches[0];
        xrayMove({clientX: touch.clientX}, container);
    }

    // --- Load initial ---
    loadFeed(true);

    // Infinite Scroll
    window.addEventListener('scroll', () => {
        if ((window.innerHeight + window.scrollY) >= document.body.offsetHeight - 600) {
            loadFeed();
        }
    });

    // --- ACTIONS ---
    async function begen(id) {
        const fd = new FormData();
        fd.append('gonderiId', id);
        fd.append('__RequestVerificationToken', CSRF());
        
        const res = await secureFetch('/Social/Begen', 'POST', fd);
        if (res.success) {
            const btn = document.getElementById(`btn-like-${id}`);
            const span = document.getElementById(`like-count-${id}`);
            span.textContent = res.count > 0 ? res.count : '';
            
            if (res.liked) {
                btn.classList.add('liked');
                btn.querySelector('i').className = 'fa-solid fa-heart';
                spawnLikeParticles(btn);
            } else {
                btn.classList.remove('liked');
                btn.querySelector('i').className = 'fa-regular fa-heart';
            }
        }
    }

    function doubleTapLike(gonderiId, imageWrap) {
        begen(gonderiId);
        const heart = imageWrap.querySelector('.double-tap-heart');
        if (heart) {
            heart.classList.remove('pop');
            void heart.offsetWidth;
            heart.classList.add('pop');
        }
    }

    function toggleComments(id) {
        const div = document.getElementById(`comments-${id}`);
        if (div.style.display === 'none') {
            div.style.display = 'block';
            loadComments(id);
        } else {
            div.style.display = 'none';
        }
    }

    async function loadComments(id) {
        const res = await secureFetch(`/Social/GetYorumlar?gonderiId=${id}`);
        if (res.success) {
            const list = document.getElementById(`comment-list-${id}`);
            list.innerHTML = (res.yorumlar || []).map(y => {
                const cName = y.AdSoyad || y.KullaniciAd || '?';
                const cPhoto = y.ProfilResmi || y.KullaniciFoto;
                return `<div class="comment-item">
                    ${avatarHTML(cPhoto, cName, 28)}
                    <div class="comment-bubble">
                        <span class="comment-author">${cName}</span>
                        <span class="comment-time">${timeAgo(y.Tarih)}</span>
                        <div class="comment-text">${escapeHtml(y.Icerik || y.Metin || '')}</div>
                    </div>
                </div>`;
            }).join('');
        }
    }

    async function makeComment(id) {
        const inp = document.getElementById(`comment-input-${id}`);
        if (!inp || !inp.value.trim()) return;
        const fd = new FormData();
        fd.append('gonderiId', id);
        fd.append('icerik', inp.value);
        fd.append('__RequestVerificationToken', CSRF());
        
        const res = await secureFetch('/Social/YorumYap', 'POST', fd);
        if (res.success) {
            inp.value = '';
            loadComments(id);
            showNeonToast('Yorum yapıldı!', 'fa-comment');
        } else {
            Swal.fire({title:'Hata', text: res.message || 'Bir hata oluştu.', icon:'error', background:'#111', color:'#fff'});
        }
    }
    
    async function kaydet(id) {
        const fd = new FormData();
        fd.append('gonderiId', id);
        fd.append('__RequestVerificationToken', CSRF());
        
        const res = await secureFetch('/Social/Kaydet', 'POST', fd);
        if (res.success) {
            const btn = document.getElementById(`btn-save-${id}`);
            const icon = btn.querySelector('i');
            if (res.saved) {
                btn.classList.add('saved');
                icon.className = 'fa-solid fa-bookmark';
                showNeonToast('Kaydedildi', 'fa-bookmark');
            } else {
                btn.classList.remove('saved');
                icon.className = 'fa-regular fa-bookmark';
            }
        }
    }

    async function repost(id) {
        const fd = new FormData();
        fd.append('gonderiId', id);
        fd.append('__RequestVerificationToken', CSRF());

        const res = await secureFetch('/Social/Repost', 'POST', fd);
        if (res.success) {
            const btn = document.getElementById(`btn-repost-${id}`);
            btn.classList.add('reposted');
            showNeonToast('Yeniden paylaşıldı!', 'fa-retweet');
        } else {
            Swal.fire({title: 'Bilgi', text: res.message || '', icon: 'info', background:'#111', color:'#fff'});
        }
    }

    async function sendCollabRequest(kullaniciId, gonderiId) {
        const result = await Swal.fire({
            title: '⚡ İş Birliği Teklifi',
            text: "Bu kullanıcıya tasarım/proje üzerinde birlikte çalışma teklifi göndermek istiyor musun?",
            icon: 'question',
            background: '#111',
            color: '#fff',
            showCancelButton: true,
            confirmButtonText: 'Evet, Gönder!',
            cancelButtonText: 'İptal',
            confirmButtonColor: '#c6ff00'
        });
        if (result.isConfirmed) {
            const fd = new FormData();
            fd.append('hedefId', kullaniciId);
            fd.append('gonderiId', gonderiId);
            fd.append('__RequestVerificationToken', CSRF());
            const res = await secureFetch('/Social/CollabGonder', 'POST', fd);
            if (res.success) {
                showNeonToast('İş Birliği teklifi gönderildi!', 'fa-bolt');
            } else {
                Swal.fire('Bilgi', res.message || 'Gönderilemedi.', 'info');
            }
        }
    }

    // --- Post Menu ---
    function togglePostMenu(id) {
        const menu = document.getElementById(`postMenu-${id}`);
        document.querySelectorAll('.post-dropdown.open').forEach(m => { if(m !== menu) m.classList.remove('open'); });
        menu.classList.toggle('open');
    }
    document.addEventListener('click', (e) => {
        if (!e.target.closest('.post-menu-btn') && !e.target.closest('.post-dropdown')) {
            document.querySelectorAll('.post-dropdown.open').forEach(m => m.classList.remove('open'));
        }
    });

    async function deletePost(id) {
        const r = await Swal.fire({title:'Emin misin?',text:'Bu gönderi kalıcı olarak silinecek.',icon:'warning',background:'#111',color:'#fff',showCancelButton:true,confirmButtonText:'Sil',confirmButtonColor:'#ff4757',cancelButtonText:'İptal'});
        if (r.isConfirmed) {
            const fd = new FormData();
            fd.append('gonderiId', id);
            fd.append('__RequestVerificationToken', CSRF());
            const res = await secureFetch('/Social/GonderiSil', 'POST', fd);
            if (res.success) {
                const el = document.getElementById(`post-${id}`);
                if (el) {
                    el.style.transition = 'opacity 0.4s, transform 0.4s';
                    el.style.opacity = '0';
                    el.style.transform = 'scale(0.9)';
                    setTimeout(() => el.remove(), 400);
                }
                showNeonToast('Gönderi silindi', 'fa-trash');
            } else {
                Swal.fire({title:'Hata', text: res.message || 'Silinemedi.', icon:'error', background:'#111', color:'#fff'});
            }
        }
    }

    async function editPost(id) {
        // Mevcut post içeriğini al
        const postEl = document.getElementById(`post-${id}`);
        if (!postEl) return;
        const bodyEl = postEl.querySelector('.post-body');
        const currentText = bodyEl ? bodyEl.textContent.trim() : '';

        // Dropdown'u kapa
        document.querySelectorAll('.post-dropdown.open').forEach(m => m.classList.remove('open'));

        const { value: newText } = await Swal.fire({
            title: '<i class="fa-solid fa-pen" style="color:var(--accent);margin-right:8px;"></i> Gönderiyi Düzenle',
            html: `<textarea id="swal-edit-input" style="width:100%;min-height:120px;background:#1a1d23;color:#e6e6e6;border:1px solid #333;border-radius:10px;padding:14px;font-size:0.95rem;font-family:inherit;resize:vertical;outline:none;transition:border 0.3s;" onfocus="this.style.borderColor='#c6ff00'" onblur="this.style.borderColor='#333'">${escapeHtml(currentText)}</textarea>`,
            background: '#111',
            color: '#fff',
            showCancelButton: true,
            confirmButtonText: '<i class="fa-solid fa-check"></i> Kaydet',
            cancelButtonText: 'İptal',
            confirmButtonColor: '#c6ff00',
            cancelButtonColor: '#333',
            customClass: {
                confirmButton: 'swal-edit-confirm',
                popup: 'swal-edit-popup'
            },
            preConfirm: () => {
                const val = document.getElementById('swal-edit-input').value.trim();
                if (!val) {
                    Swal.showValidationMessage('İçerik boş olamaz!');
                    return false;
                }
                return val;
            }
        });

        if (newText) {
            const fd = new FormData();
            fd.append('gonderiId', id);
            fd.append('icerik', newText);
            fd.append('__RequestVerificationToken', CSRF());

            const res = await secureFetch('/Social/GonderiDuzenle', 'POST', fd);
            if (res.success) {
                // İçeriği yerinde güncelle
                if (bodyEl) {
                    bodyEl.innerHTML = parseText(newText);
                    bodyEl.classList.remove('truncated');
                    // Yanıtlarda "devamını gör" butonu kaldır
                    const showMore = bodyEl.nextElementSibling;
                    if (showMore && showMore.classList.contains('show-more-btn')) showMore.remove();
                }
                showNeonToast('Gönderi güncellendi!', 'fa-pen');
            } else {
                Swal.fire({title:'Hata', text: res.message || 'Düzenlenemedi.', icon:'error', background:'#111', color:'#fff'});
            }
        }
    }

    function copyPostLink(id) {
        navigator.clipboard.writeText(window.location.origin + '/Social/Feed#post-' + id);
        showNeonToast('Bağlantı kopyalandı!', 'fa-link');
    }

    function reportPost(id) {
        Swal.fire({title:'Bildir',text:'Bu gönderi bildirildi. Teşekkürler!',icon:'success',background:'#111',color:'#fff', confirmButtonColor:'#c6ff00'});
    }

    // --- STORIES ---
    function openStoryUpload() { document.getElementById('storyFileInput').click(); }

    async function uploadStory(input) {
        if (!input.files[0]) return;
        const fd = new FormData();
        fd.append('gorsel', input.files[0]);
        fd.append('__RequestVerificationToken', CSRF());

        try {
            const res = await secureFetch('/Social/HikayeOlustur', 'POST', fd);
            if (res.success) { showNeonToast('Hikaye paylaşıldı!', 'fa-circle-play'); input.value=''; loadStories(); }
            else {
                const res2 = await secureFetch('/Social/HikayeYukle', 'POST', fd);
                if (res2.success) { showNeonToast('Hikaye paylaşıldı!', 'fa-circle-play'); input.value=''; loadStories(); }
            }
        } catch(e) {}
    }

    let storyUsers = [], allStoryItems = [], currentStoryIndex = 0;

    async function loadStories() {
        const data = await secureFetch('/Social/GetHikayeler');
        if (data && data.success && data.hikayeler) {
            storyUsers = data.hikayeler;
            const container = document.getElementById('storyContainer');
            // Keep add button, append stories
            const addBtn = container.children[0].outerHTML;
            let sHtml = '';
            storyUsers.forEach(s => {
                const sName = s.AdSoyad || s.KullaniciAd || '?';
                const sPhoto = s.ProfilResmi || s.KullaniciFoto;
                sHtml += `<div style="display:flex;flex-direction:column;align-items:center;gap:6px;cursor:pointer;flex-shrink:0;" onclick="openUserStories(${s.KullaniciId||s.Id},'${sName}','${sPhoto||''}')">
                    <div style="width:62px;height:62px;border-radius:50%;padding:2px;background:linear-gradient(135deg,var(--accent),var(--red),var(--accent));background-size:200% 200%;animation:storyGrad 3s ease infinite;">
                        ${sPhoto ? `<img src="${sPhoto}" style="width:100%;height:100%;border-radius:50%;object-fit:cover;border:3px solid var(--bg-base);">` : 
                        `<div style="width:100%;height:100%;border-radius:50%;background:var(--bg-surface-solid);border:3px solid var(--bg-base);display:flex;align-items:center;justify-content:center;font-weight:900;color:var(--text-primary);">${sName[0]}</div>`}
                    </div>
                    <span style="font-size:0.65rem;color:var(--text-muted);max-width:62px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${sName.split(' ')[0]}</span>
                </div>`;
            });
            container.innerHTML = addBtn + sHtml;
        }
    }

    async function openUserStories(userId, userName, userPhoto) {
        const data = await secureFetch(`/Social/GetKullaniciHikayeleri?kullaniciId=${userId}`);
        if (data && data.success && data.hikayeler && data.hikayeler.length > 0) {
            allStoryItems = data.hikayeler.map(h => ({...h, KullaniciAd:userName, KullaniciFoto:userPhoto, MedyaUrl:h.GorselUrl||h.MedyaUrl}));
            currentStoryIndex = 0;
            viewStory(0);
        }
    }

    function viewStory(index) {
        if (index < 0 || index >= allStoryItems.length) { closeStoryViewer(); return; }
        currentStoryIndex = index;
        const s = allStoryItems[index];
        
        const viewer = document.getElementById('storyViewer');
        viewer.style.display = 'flex';
        document.getElementById('storyViewerImg').src = s.MedyaUrl;
        
        const info = document.getElementById('storyUserInfo');
        const ph = s.KullaniciFoto ? `<img src="${s.KullaniciFoto}" style="width:32px;height:32px;border-radius:50%;border:2px solid #fff;">` : '';
        info.innerHTML = `${ph}<span style="color:#fff;font-weight:700;font-size:0.85rem;text-shadow:0 1px 3px rgba(0,0,0,0.5);">${s.KullaniciAd}</span>`;
        
        const bar = document.getElementById('storyProgressBar');
        bar.innerHTML = '<div style="background:var(--accent);height:3px;width:0%;animation:storyProg 5s linear forwards;border-radius:2px;flex:1;"></div>';
        
        clearTimeout(window.storyTimeout);
        window.storyTimeout = setTimeout(() => nextStory(), 5000);
    }
    function nextStory() { viewStory(currentStoryIndex + 1); }
    function prevStory() { viewStory(currentStoryIndex - 1); }
    function closeStoryViewer() { clearTimeout(window.storyTimeout); document.getElementById('storyViewer').style.display = 'none'; }

    // --- Stats & Quests ---
    async function loadStats() {
        try {
            const data = await secureFetch('/Social/GetMyStats');
            if (data.success && data.stats) {
                document.getElementById('streakVal').textContent = data.stats.Streak || 0;
                document.getElementById('levelVal').textContent = data.stats.Seviye || 1;
                document.getElementById('xpVal').textContent = data.stats.ToplamXP || 0;
                document.getElementById('badgeVal').textContent = data.stats.RozetSayisi || 0;
            }
        } catch(e) {}
    }

    async function loadQuests() {
        try {
            const data = await secureFetch('/Social/GetGunlukGorevler');
            const list = document.getElementById('questsList');
            if (!data.success || !data.gorevler) return;
            const labels = { begeni:'5 Beğeni', yorum:'3 Yorum', gonderi:'1 Gönderi', hikaye:'1 Hikaye', takip:'2 Takip' };
            list.innerHTML = data.gorevler.map(g => {
                const pct = Math.min(100, (g.MevcutSayi / g.HedefSayi) * 100);
                const done = g.Tamamlandi == 1;
                return `<div>
                    <div style="display:flex; justify-content:space-between; font-size:0.78rem; margin-bottom:4px; font-weight:700;">
                        <span style="color:${done ? 'var(--accent)' : 'var(--text-secondary)'}">${done ? '✅' : '⬜'} ${labels[g.GorevTipi] || g.GorevTipi}</span>
                        <span style="color:var(--accent)">+${g.XPOdulu} XP</span>
                    </div>
                    <div style="height:5px; background:var(--bg-hover); border-radius:3px; overflow:hidden;">
                        <div style="width:${pct}%; background:var(--accent); height:100%; transition:width 0.5s; border-radius:3px;"></div>
                    </div>
                </div>`;
            }).join('');
        } catch(e) {}
    }
    
    loadStats();
    loadQuests();
    loadStories();
</script>
<style>
    @@keyframes storyGrad { 0%{background-position:0% 50%} 50%{background-position:100% 50%} 100%{background-position:0% 50%} }
    @@keyframes storyProg { to { width: 100%; } }
</style>
}
