@{
    Layout = "_SocialLayoutModern";
    ViewData["Title"] = "Keşfet";
}

@{
    var posts = Model as List<dynamic>;
    var categories = new[] { "Tumu", "UI/UX", "Branding", "3D", "Mobile", "Web", "Typography", "Illustration", "Motion" };
}

<!-- Header -->
<header class="sticky top-0 z-30 flex h-14 md:h-16 items-center justify-between border-b border-border bg-background/95 px-3 md:px-6 backdrop-blur">
    <!-- Search Bar -->
    <div class="flex flex-1 items-center gap-4">
        <h1 class="text-lg md:text-xl font-bold">Kesfet</h1>
        <div class="relative hidden max-w-md flex-1 md:block">
            <i data-lucide="search" class="absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-muted-foreground"></i>
            <input type="text" placeholder="Tasarim, tasarimci veya etiket ara..." class="h-10 w-full rounded-full border border-white/10 bg-black/20 pl-10 pr-4 text-sm text-white placeholder:text-white/50 backdrop-blur-md focus:border-primary focus:bg-black/40 focus:outline-none focus:ring-1 focus:ring-primary transition-all" />
        </div>
    </div>

    <!-- Right Actions -->
    <div class="flex items-center gap-4">
        <div class="hidden items-center gap-2 rounded-full border border-border bg-secondary/50 px-4 py-1.5 md:flex">
            <i data-lucide="flame" class="h-4 w-4 text-orange-500"></i>
            <span class="text-sm font-medium">12 Gun</span>
        </div>

        <!-- Mode Toggle -->
        <a href="/Social/Swipe" class="flex h-10 w-10 items-center justify-center rounded-full border border-border bg-secondary/50 transition-colors hover:bg-secondary relative group" title="Swipe Modu">
            <i data-lucide="monitor-play" class="h-4 w-4"></i>
            <div class="absolute -bottom-8 hidden whitespace-nowrap rounded bg-popover px-2 py-1 text-xs text-popover-foreground group-hover:block border border-border">Swipe Modu</div>
        </a>

        <!-- Notifications -->
        <div class="relative">
            <button id="notifBtn" onclick="toggleDropdown('notifDropdown')" class="relative flex h-10 w-10 items-center justify-center rounded-full border border-border bg-secondary/50 transition-colors hover:bg-secondary">
                <i data-lucide="bell" class="h-4 w-4"></i>
                <span class="absolute right-2 top-2 h-2 w-2 rounded-full bg-primary neon-glow"></span>
            </button>
            <div id="notifDropdown" class="absolute right-0 top-full mt-2 hidden w-80 rounded-2xl border border-border bg-popover p-4 shadow-xl">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="font-bold">Bildirimler</h3>
                    <button class="text-xs text-primary hover:underline">Tumunu okundu isaretle</button>
                </div>
                <div class="space-y-4">
                    <!-- Sample Notif -->
                    <div class="flex items-start gap-3">
                        <img src="https://ui-avatars.com/api/?name=Ali&background=random" class="h-8 w-8 rounded-full" />
                        <div>
                            <p class="text-sm"><span class="font-semibold">Ali</span> tasarimini begendi.</p>
                            <span class="text-xs text-muted-foreground">5 dk once</span>
                        </div>
                    </div>
                </div>
                <a href="/Social/Notifications" class="mt-4 block text-center text-sm text-primary hover:underline">Tumunu Gor</a>
            </div>
        </div>

        <!-- Messages -->
        <div class="relative">
            <button id="msgBtn" onclick="toggleDropdown('msgDropdown')" class="relative flex h-10 w-10 items-center justify-center rounded-full border border-border bg-secondary/50 transition-colors hover:bg-secondary">
                <i data-lucide="message-square" class="h-4 w-4"></i>
                <span class="absolute right-2 top-2 h-2 w-2 rounded-full bg-primary neon-glow"></span>
            </button>
            <div id="msgDropdown" class="absolute right-0 top-full mt-2 hidden w-80 rounded-2xl border border-border bg-popover p-4 shadow-xl">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="font-bold">Mesajlar</h3>
                    <a href="/Social/Mesajlar" class="text-xs text-primary hover:underline">Tumunu Gor</a>
                </div>
                <div class="space-y-4">
                    <!-- Sample Message -->
                    <div class="flex items-start gap-3">
                        <div class="relative">
                            <img src="https://ui-avatars.com/api/?name=Ayse&background=random" class="h-8 w-8 rounded-full" />
                            <div class="absolute -bottom-0.5 -right-0.5 h-2.5 w-2.5 rounded-full border-2 border-popover bg-green-500"></div>
                        </div>
                        <div class="flex-1 overflow-hidden">
                            <div class="flex items-center justify-between">
                                <span class="text-sm font-semibold">Ayse</span>
                                <span class="text-xs text-primary">12:30</span>
                            </div>
                            <p class="truncate text-sm text-muted-foreground">Harika bir is cikarmissin!</p>
                        </div>
                    </div>
                </div>
                <a href="/Social/Mesajlar" class="mt-4 block w-full rounded-xl bg-secondary py-2 text-center text-sm font-medium hover:bg-secondary/80">Yeni Mesaj</a>
            </div>
        </div>
    </div>
</header>

<div class="flex">
    <!-- Main Feed Section -->
    <div class="flex-1 p-3 md:p-6 z-10 w-0">
        <!-- Category Filter -->
        <div class="flex gap-2 overflow-x-auto pb-3 md:pb-4 hide-scrollbar -mx-1 px-1">
            @foreach (var cat in categories)
            {
                <button onclick="filterCategory('@cat')" id="cat-@cat" 
                        class="cat-filter-btn flex-shrink-0 rounded-xl px-3 md:px-5 py-2 md:py-2.5 text-xs md:text-sm font-medium transition-all @(cat == "Tumu" ? "bg-primary text-primary-foreground neon-glow" : "bg-secondary text-secondary-foreground hover:bg-secondary/80")">
                    @cat
                </button>
            }
        </div>

        <!-- Custom My Designs Section -->
        @{
            var currentUserId = (int)(ViewBag.CurrentUserId ?? 0);
            var myPosts = posts?.Where(p => (int)(p.KullaniciId ?? 0) == currentUserId).ToList() ?? new List<dynamic>();
            var otherPosts = posts?.Where(p => (int)(p.KullaniciId ?? 0) != currentUserId).ToList() ?? new List<dynamic>();
        }

        @if (myPosts.Any())
        {
            <section class="mt-2 mb-8">
                <div class="flex items-center gap-2 mb-4">
                    <i data-lucide="user-circle" class="h-5 w-5 text-accent"></i>
                    <h2 class="text-lg font-bold">Senin Paylasimlarin</h2>
                </div>
                <div class="flex gap-3 md:gap-4 overflow-x-auto pb-4 hide-scrollbar -mx-1 px-1">
                    @foreach (var card in myPosts.Take(5))
                    {
                        <a href="/Social/Design/@card.Id" class="group block relative w-48 md:w-56 flex-shrink-0 overflow-hidden rounded-2xl border border-transparent transition-all hover:border-primary/50 hover:shadow-lg">
                            <div class="aspect-video w-full overflow-hidden bg-gradient-to-br from-secondary to-background relative">
                                <i data-lucide="image" class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 h-8 w-8 text-white/20"></i>
                                <img src="@(string.IsNullOrEmpty(card.ImageUrl) ? "https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?w=800&q=80" : card.ImageUrl)" 
                                     onerror="this.src='https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?w=800&q=80'; this.onerror=null;"
                                     alt="@card.Title" class="relative z-10 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
                            </div>
                            <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/80 to-transparent p-3 md:p-4 text-white">
                                <h3 class="truncate text-sm font-bold">@(card.Title ?? "Tasarim")</h3>
                                <div class="mt-1 flex items-center gap-3 text-xs text-white/80">
                                    <span class="flex items-center gap-1"><i data-lucide="heart" class="h-3 w-3"></i> @(card.Likes ?? 0)</span>
                                    <span class="flex items-center gap-1"><i data-lucide="message-square" class="h-3 w-3"></i> @(card.Comments ?? 0)</span>
                                </div>
                            </div>
                        </a>
                    }
                </div>
            </section>
        }

        <!-- Featured Designs -->
        <section class="mt-4">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                    <i data-lucide="sparkles" class="h-5 w-5 text-primary"></i>
                    <h2 class="text-lg font-bold">One Cikanlar</h2>
                </div>
                <a href="/Social/Trending" class="flex items-center gap-1 text-sm text-muted-foreground transition-colors hover:text-foreground">
                    Tumu <i data-lucide="chevron-right" class="h-4 w-4"></i>
                </a>
            </div>

            <!-- Enhanced Design Grid -->
            <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
                @if (otherPosts != null && otherPosts.Count > 0)
                {
                    foreach (var card in otherPosts.Take(2))
                    {
                        <div class="group relative overflow-hidden rounded-2xl glass-card transition-all hover:border-primary/50">
                            <div class="relative overflow-hidden aspect-video bg-gradient-to-br from-secondary to-background">
                                <i data-lucide="image" class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 h-10 w-10 text-white/20"></i>
                                <img src="@(string.IsNullOrEmpty(card.ImageUrl) ? "https://images.unsplash.com/photo-1634017839464-5c3399be3d0d?w=800&q=80" : card.ImageUrl)" 
                                     onerror="this.src='https://images.unsplash.com/photo-1634017839464-5c3399be3d0d?w=800&q=80'; this.onerror=null;"
                                     alt="@card.Title" class="relative z-10 h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" />
                                <div class="absolute inset-0 z-20 bg-gradient-to-t from-black/90 via-black/20 to-transparent opacity-80 transition-opacity duration-300 group-hover:opacity-100"></div>
                                
                                <!-- Category Badge -->
                                <div class="absolute left-4 top-4">
                                    <span class="rounded-full bg-black/40 px-3 py-1.5 text-xs font-medium text-white backdrop-blur-md">UI/UX</span>
                                </div>
                                
                                <!-- Tags & Content Overlay -->
                                <div class="absolute bottom-0 left-0 right-0 p-4 md:p-5 translate-y-2 opacity-90 transition-all duration-300 group-hover:translate-y-0 group-hover:opacity-100 z-30">
                                    <h3 class="text-base md:text-lg font-bold text-white line-clamp-2 leading-tight">@(card.Title ?? "Tasarim")</h3>
                                    <div class="mt-2.5 flex items-center gap-2">
                                        <span class="rounded-md bg-white/10 px-2 py-1 text-[10px] font-medium text-white backdrop-blur-md border border-white/10 hover:bg-white/20 transition-colors cursor-pointer">#design</span>
                                        <span class="rounded-md bg-white/10 px-2 py-1 text-[10px] font-medium text-white backdrop-blur-md border border-white/10 hover:bg-white/20 transition-colors cursor-pointer">#creative</span>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Right Actions (Always partially visible but more prominent on hover) -->
                            <div class="absolute right-4 top-4 flex flex-col gap-3 translate-x-4 opacity-0 transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100 z-10">
                                <button onclick="likePost('@card.Id')" class="like-btn-@card.Id group/btn flex h-10 w-10 flex-col items-center justify-center rounded-full bg-black/40 text-white backdrop-blur-md transition-all hover:bg-accent/20">
                                    <i data-lucide="heart" class="h-4 w-4 transition-transform group-hover/btn:scale-110"></i>
                                </button>
                                <button onclick="savePost('@card.Id')" class="save-btn-@card.Id group/btn flex h-10 w-10 flex-col items-center justify-center rounded-full bg-black/40 text-white backdrop-blur-md transition-all hover:bg-primary/20">
                                    <i data-lucide="bookmark" class="h-4 w-4 transition-transform group-hover/btn:scale-110"></i>
                                </button>
                                <button onclick="navigator.clipboard.writeText(window.location.origin + '/Social/Design/@card.Id'); alert('Bağlantı kopyalandı!')" class="group/btn flex h-10 w-10 flex-col items-center justify-center rounded-full bg-black/40 text-white backdrop-blur-md transition-all hover:bg-white/20">
                                    <i data-lucide="share-2" class="h-4 w-4 transition-transform group-hover/btn:scale-110"></i>
                                </button>
                            </div>
                            
                            <!-- Card Footer Info -->
                            <div class="p-3 md:p-4 bg-card border-t border-border/50">
                                <div class="flex items-center justify-between">
                                    <!-- User Info -->
                                    <a href="/Social/ProfilModern" class="flex items-center gap-3 group/user">
                                        <div class="relative h-10 w-10 overflow-hidden rounded-full ring-2 ring-transparent transition-all group-hover/user:ring-primary">
                                            <img src="@(string.IsNullOrEmpty(card.UserAvatar) ? ("https://ui-avatars.com/api/?name=" + Uri.EscapeDataString(card.UserName ?? "U") + "&background=random") : card.UserAvatar)" 
                                                 onerror="this.src='/img/default-user.png'; this.onerror=null;"
                                                 class="h-full w-full object-cover" />
                                        </div>
                                        <div>
                                            <p class="text-sm font-semibold group-hover/user:text-primary transition-colors">@(card.UserName ?? "Kullanici")</p>
                                            <p class="text-xs text-muted-foreground">@@@(card.UserHandle ?? "kullanici")</p>
                                        </div>
                                    </a>
                                    
                                    <!-- Stats -->
                                    <div class="flex items-center gap-4 text-muted-foreground text-sm">
                                        <div class="flex items-center gap-1.5 hover:text-accent transition-colors cursor-pointer">
                                            <i data-lucide="heart" class="h-4 w-4"></i>
                                            <span class="like-count-@card.Id">@(card.Likes ?? 0)</span>
                                        </div>
                                        <a href="/Social/Design/@card.Id" class="flex items-center gap-1.5 hover:text-primary transition-colors cursor-pointer">
                                            <i data-lucide="message-square" class="h-4 w-4"></i>
                                            <span>12</span>
                                        </a>
                                        <div class="flex items-center gap-1.5 cursor-help" title="Goruntulenme">
                                            <i data-lucide="eye" class="h-4 w-4"></i>
                                            <span>@(card.Views ?? 0)</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </section>
        
        <!-- Canli Yayinlar -->
        <section class="mt-10">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                    <i data-lucide="radio" class="h-5 w-5 text-destructive"></i>
                    <h2 class="text-lg font-bold">Canli Yayinlar</h2>
                    <span class="rounded-full bg-destructive/10 px-2 py-0.5 text-xs font-semibold text-destructive">@(ViewBag.LiveCount ?? 2) Canli</span>
                </div>
                <a href="/Social/Live" class="flex items-center gap-1 text-sm text-muted-foreground transition-colors hover:text-foreground">
                    Tumu <i data-lucide="chevron-right" class="h-4 w-4"></i>
                </a>
            </div>
            
            <div class="mt-4 grid grid-cols-1 lg:grid-cols-3 gap-4">
                @if (ViewBag.LiveRooms != null)
                {
                    foreach (var room in ViewBag.LiveRooms)
                    {
                        var isLive = room.IsLive == true;
                        <div class="group relative overflow-hidden rounded-2xl glass-card transition-all hover:border-@(isLive ? "destructive" : "primary")/50">
                            <div class="relative overflow-hidden aspect-video">
                                <img src="@room.Thumbnail" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
                                <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/30 to-transparent"></div>
                                
                                <div class="absolute left-3 top-3">
                                    @if(isLive) {
                                        <div class="flex items-center gap-1.5 rounded-full bg-destructive px-2.5 py-1 text-xs font-bold text-destructive-foreground">
                                            <span class="relative flex h-2 w-2">
                                                <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-white opacity-75"></span>
                                                <span class="relative inline-flex h-2 w-2 rounded-full bg-white"></span>
                                            </span>
                                            CANLI
                                        </div>
                                    } else {
                                        <div class="flex items-center gap-1.5 rounded-full bg-secondary/80 backdrop-blur-sm px-2.5 py-1 text-xs font-semibold">
                                            <i data-lucide="calendar" class="h-3 w-3"></i>
                                            YARIN 20:00
                                        </div>
                                    }
                                </div>
                                
                                <div class="absolute bottom-3 left-3 right-3">
                                    <h3 class="font-bold text-white text-sm line-clamp-1">@room.Title</h3>
                                    <div class="mt-2 flex items-center justify-between">
                                        <div class="flex items-center gap-2">
                                            <img src="https://ui-avatars.com/api/?name=@(Uri.EscapeDataString(room.HostName))&background=random" class="h-6 w-6 rounded-full" />
                                            <span class="text-xs font-medium text-white/90">@room.HostName</span>
                                        </div>
                                        @if(isLive) {
                                            <div class="flex items-center gap-1 text-xs text-white/80">
                                                <i data-lucide="users" class="h-3 w-3"></i>
                                                <span>1.2k</span>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </section>

        <!-- Son Tasarimlar -->
        <section class="mt-10">
            <div class="flex items-center justify-between">
                <h2 class="text-lg font-bold">Kesfetmeye Devam Et</h2>
            </div>
            <div class="mt-4 grid grid-cols-2 lg:grid-cols-3 xl:grid-cols-2 2xl:grid-cols-3 gap-4 md:gap-6">
                @if (otherPosts != null && otherPosts.Count > 2)
                {
                    foreach (var card in otherPosts.Skip(2))
                    {
                        <div class="group border border-transparent hover:border-border cursor-pointer relative overflow-hidden rounded-2xl bg-card transition-all hover:shadow-lg">
                            <a href="/Social/Design/@card.Id" class="block">
                                <div class="relative overflow-hidden aspect-video">
                                    <img src="@(card.ImageUrl ?? "https://images.unsplash.com/photo-1634017839464-5c3399be3d0d?w=800")" class="h-full w-full object-cover group-hover:scale-105 transition-transform duration-500" />
                                </div>
                                <div class="px-4 py-3 bg-card flex items-center justify-between group-hover:bg-secondary/20 transition-colors">
                                    <div class="flex items-center gap-2 min-w-0">
                                        <img src="https://ui-avatars.com/api/?name=@(Uri.EscapeDataString(card.UserName ?? "U"))&background=random" class="h-6 w-6 rounded-full" />
                                        <span class="text-sm font-medium truncate">@card.UserName</span>
                                    </div>
                                    <span class="text-xs text-muted-foreground flex items-center gap-1"><i data-lucide="heart" class="h-3 w-3"></i> @card.Likes</span>
                                </div>
                            </a>
                        </div>
                    }
                }
            </div>
        </section>
        
        <!-- Yarisma Banner / Call to Action -->
        <div class="mt-10 relative overflow-hidden rounded-2xl border border-primary/20 bg-card p-8">
            <div class="absolute inset-0 bg-gradient-to-br from-primary/10 via-background to-background"></div>
            <div class="relative z-10 flex flex-col items-center text-center">
                <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-primary neon-glow mb-4">
                    <i data-lucide="trophy" class="h-8 w-8 text-primary-foreground"></i>
                </div>
                <h2 class="text-2xl font-bold">UI/UX Yarisma Haftasi!</h2>
                <p class="mt-2 max-w-lg text-muted-foreground">Kendi tasarimini yukle, oylamaya katil ve buyuk odulu kazanma sansini yakala. Bu hafta premium uye olma sansi!</p>
                <div class="mt-6 flex flex-wrap gap-4 justify-center">
                    <a href="/Social/Competitions" class="rounded-xl bg-primary px-6 py-3 font-semibold text-primary-foreground transition-all hover:opacity-90 neon-glow">
                        Yarismaya Katil
                    </a>
                    <button onclick="openCreateModal()" class="rounded-xl bg-secondary px-6 py-3 font-semibold text-secondary-foreground transition-all hover:bg-secondary/80">
                        Hemen Paylas
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Sidebar -->
    <aside class="hidden xl:flex w-72 2xl:w-80 flex-col border-l border-border bg-card/30 p-4 2xl:p-6 min-h-[calc(100vh-64px)] overflow-y-auto hide-scrollbar z-10">
        <!-- Weekly Designers -->
        <div class="flex items-center gap-2 mb-4">
            <i data-lucide="trending-up" class="h-5 w-5 text-orange-500"></i>
            <h2 class="text-base 2xl:text-lg font-bold">Trend Tasarimcilar</h2>
        </div>
        
        <div class="space-y-3">
            @if (ViewBag.TrendingDesigners != null)
            {
                foreach (var d in ViewBag.TrendingDesigners)
                {
                    <div class="group flex items-center justify-between rounded-xl border border-transparent p-2 transition-all hover:border-border hover:bg-secondary/50">
                        <div class="flex items-center gap-3 min-w-0">
                            <div class="relative h-10 w-10 flex-shrink-0">
                                <img src="https://ui-avatars.com/api/?name=@(Uri.EscapeDataString(d.Name ?? "U"))&background=random" class="h-full w-full rounded-full object-cover" />
                                @if(d.Rank <= 3) {
                                    <div class="absolute -top-1 -right-1 flex h-4 w-4 items-center justify-center rounded-full bg-primary text-[8px] font-bold text-primary-foreground border-2 border-background">
                                        @d.Rank
                                    </div>
                                }
                            </div>
                            <div class="min-w-0 flex-1">
                                <p class="truncate text-sm font-semibold hover:text-primary cursor-pointer transition-colors">@d.Name</p>
                                <p class="text-xs text-muted-foreground truncate">@@@d.Username</p>
                            </div>
                        </div>
                        <button onclick="followDesigner(@d.Id)" class="follow-btn-@d.Id shrink-0 rounded-lg px-3 py-1.5 text-xs font-semibold transition-all bg-primary/10 text-primary hover:bg-primary hover:text-primary-foreground">
                            Takip Et
                        </button>
                    </div>
                }
            }
        </div>

        <!-- Weekly XP Leaderboard -->
        <div class="mt-8 relative overflow-hidden rounded-2xl bg-gradient-to-br from-primary/10 via-card to-card p-5 border border-primary/20">
            <div class="flex items-start justify-between">
                <div>
                    <h3 class="font-bold flex items-center gap-2">
                        <i data-lucide="zap" class="h-4 w-4 text-primary"></i> Liderlik Tablosu
                    </h3>
                    <p class="text-xs text-muted-foreground mt-1">Haftalik XP siralamasi</p>
                </div>
            </div>
            
            <div class="mt-4 space-y-4">
                @if (ViewBag.XPLeaderboard != null)
                {
                    foreach (var e in ViewBag.XPLeaderboard)
                    {
                        var isFirst = e.Rank == 1;
                        <div class="flex items-center gap-3">
                            <span class="flex h-6 w-6 items-center justify-center rounded bg-secondary text-xs font-bold @(isFirst ? "bg-primary text-primary-foreground" : "text-muted-foreground")">@e.Rank</span>
                            <img src="https://ui-avatars.com/api/?name=@(Uri.EscapeDataString(e.Name ?? "U"))&background=random" class="h-8 w-8 rounded-full" />
                            <div class="flex-1 min-w-0">
                                <p class="truncate text-sm font-semibold">@e.Name</p>
                            </div>
                            <span class="text-sm font-bold @(isFirst ? "text-primary" : "text-muted-foreground")">@e.XP XP</span>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Links -->
