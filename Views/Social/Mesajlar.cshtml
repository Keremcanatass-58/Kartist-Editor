@{
    Layout = "_SocialLayoutModern";
    ViewData["Title"] = "Mesajlar";
}

@section Styles {
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
}

<style>
    :root {
        --ig-primary: #0095f6;
        --ig-secondary: #262626;
        --ig-bg: #121212;
        --ig-bubble-sent: #3797f0;
        --ig-bubble-received: #262626;
    }

    .dm-layout { 
        display: grid; 
        grid-template-columns: 350px 1fr; 
        height: calc(100vh - 64px);
        background: var(--ig-bg);
        overflow: hidden;
    }

    /* ===== SIDEBAR ===== */
    .dm-sidebar { 
        border-right: 1px solid var(--border); 
        display: flex; 
        flex-direction: column; 
        background: rgba(18, 18, 18, 0.8);
        backdrop-filter: blur(20px);
    }
    .dm-sidebar-header {
        padding: 24px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .dm-sidebar-header h1 {
        font-size: 1.5rem;
        font-weight: 800;
        margin: 0;
        letter-spacing: -0.5px;
    }
    .dm-new-chat-btn {
        width: 40px;
        height: 40px;
        border-radius: 12px;
        background: rgba(255,255,255,0.05);
        border: 1px solid var(--border);
        color: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }
    .dm-new-chat-btn:hover { background: rgba(255,255,255,0.1); transform: scale(1.05); }
    
    .dm-search { padding: 0 16px 20px; }
    .dm-search-container {
        position: relative;
        width: 100%;
    }
    .dm-search-container i {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
        font-size: 0.9rem;
    }
    .dm-search input {
        width: 100%;
        background: #262626;
        border: none;
        border-radius: 10px;
        padding: 10px 16px 10px 40px;
        color: #fff;
        outline: none;
        font-size: 0.9rem;
        transition: all 0.2s;
    }
    .dm-search input:focus { background: #363636; }
    
    .dm-tabs {
        display: flex;
        padding: 0 16px;
        gap: 20px;
        border-bottom: 1px solid var(--border);
        margin-bottom: 10px;
    }
    .dm-tab {
        padding: 10px 0;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--text-muted);
        cursor: pointer;
        position: relative;
        transition: all 0.2s;
    }
    .dm-tab.active { color: #fff; }
    .dm-tab.active::after {
        content: '';
        position: absolute;
        bottom: -1px;
        left: 0;
        right: 0;
        height: 2px;
        background: #fff;
    }

    .dm-chat-list { flex: 1; overflow-y: auto; }
    .dm-section-title {
        padding: 16px 20px 8px;
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .dm-chat-item {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 12px 20px;
        cursor: pointer;
        transition: all 0.2s;
    }
    .dm-chat-item:hover { background: rgba(255,255,255,0.03); }
    .dm-chat-item.active { background: rgba(255,255,255,0.05); }
    
    .dm-avatar-container {
        position: relative;
        flex-shrink: 0;
    }
    .dm-chat-avatar {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid transparent;
    }
    .dm-chat-item.unread .dm-chat-avatar { border-color: var(--ig-primary); }
    .status-dot {
        position: absolute;
        bottom: 2px;
        right: 2px;
        width: 14px;
        height: 14px;
        background: #4ade80;
        border: 3px solid var(--ig-bg);
        border-radius: 50%;
    }

    .dm-chat-info { flex: 1; min-width: 0; }
    .dm-chat-name { font-weight: 600; font-size: 0.95rem; color: #fff; display: flex; align-items: center; justify-content: space-between; }
    .dm-chat-preview { 
        color: var(--text-muted); 
        font-size: 0.85rem; 
        overflow: hidden; 
        text-overflow: ellipsis; 
        white-space: nowrap; 
        margin-top: 2px;
    }
    .dm-chat-item.unread .dm-chat-preview { color: #fff; font-weight: 600; }
    
    /* ===== CHAT AREA ===== */
    .dm-chat-area { 
        display: flex; 
        flex-direction: column; 
        background: var(--ig-bg); 
    }
    .dm-chat-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 24px;
        border-bottom: 1px solid var(--border);
    }
    .dm-header-user { display: flex; align-items: center; gap: 12px; cursor: pointer; }
    .dm-header-user img { width: 32px; height: 32px; border-radius: 50%; object-fit: cover; }
    .dm-header-user .name { font-weight: 700; font-size: 1rem; }
    
    .dm-header-actions { display: flex; gap: 20px; font-size: 1.2rem; color: #fff; }
    .dm-header-actions i { cursor: pointer; transition: opacity 0.2s; }
    .dm-header-actions i:hover { opacity: 0.7; }

    .dm-messages { 
        flex: 1; 
        overflow-y: auto; 
        padding: 24px; 
        display: flex; 
        flex-direction: column; 
        gap: 8px; 
    }
    
    .dm-msg-wrapper { display: flex; flex-direction: column; width: 100%; }
    .dm-msg-wrapper.sent { align-items: flex-end; }
    .dm-msg-wrapper.received { align-items: flex-start; }

    .dm-msg {
        max-width: 60%;
        padding: 12px 16px;
        border-radius: 22px;
        font-size: 0.95rem;
        line-height: 1.4;
    }
    .dm-msg.sent {
        background: var(--ig-bubble-sent);
        color: #fff;
        border-bottom-right-radius: 4px;
    }
    .dm-msg.received {
        background: var(--ig-bubble-received);
        color: #fff;
        border-bottom-left-radius: 4px;
    }

    .dm-input-container {
        padding: 20px 24px;
    }
    .dm-input-wrapper {
        background: transparent;
        border: 1px solid var(--border);
        border-radius: 30px;
        display: flex;
        align-items: center;
        padding: 4px 16px;
        gap: 12px;
    }
    .dm-input {
        flex: 1;
        background: transparent;
        border: none;
        color: #fff;
        padding: 10px 0;
        outline: none;
        font-size: 0.95rem;
    }
    .dm-send-btn {
        color: var(--ig-primary);
        font-weight: 700;
        background: none;
        border: none;
        cursor: pointer;
        font-size: 0.95rem;
        padding: 8px 4px;
        transition: opacity 0.2s;
    }
    .dm-send-btn:disabled { opacity: 0.3; cursor: default; }

    @@media (max-width: 768px) {
        .dm-layout { grid-template-columns: 1fr; height: calc(100vh - 60px); }
        .dm-sidebar { width: 100%; }
        .dm-chat-area { position: fixed; inset: 0; z-index: 100; display: none; }
        .dm-layout.chat-open .dm-chat-area { display: flex; }
        .dm-back-btn { display: block; margin-right: 12px; cursor: pointer; }
        .dm-msg { max-width: 85%; }
    }
</style>

<div class="dm-layout" id="dmLayout">
    <!-- SIDEBAR -->
    <div class="dm-sidebar">
        <div class="dm-sidebar-header">
            <h1>Mesajlar</h1>
            <button class="dm-new-chat-btn" onclick="openNewChatModal()" title="Yeni Sohbet"><i class="fa-solid fa-plus"></i></button>
        </div>
        
        <div class="dm-search">
            <div class="dm-search-container">
                <i class="fa-solid fa-search"></i>
                <input placeholder="Ara..." id="dmSearchInput" oninput="searchChats(this.value)">
            </div>
        </div>

        <div class="dm-tabs">
            <div class="dm-tab active" onclick="switchTab('all')">Hepsi</div>
            <div class="dm-tab" onclick="switchTab('unread')">Okunmamış</div>
        </div>

        <div class="dm-chat-list" id="chatList">
            <!-- Loader -->
            <div style="padding:40px;text-align:center;opacity:0.5;">
                <i class="fa-solid fa-circle-notch fa-spin"></i>
            </div>
        </div>
    </div>

    <!-- CHAT AREA -->
    <div class="dm-chat-area" id="chatArea">
        <div class="dm-empty" id="chatEmpty">
            <div style="width:100px;height:100px;border-radius:50%;border:2px solid #fff;display:flex;align-items:center;justify-content:center;margin-bottom:20px;">
                <i class="fa-regular fa-paper-plane" style="font-size:40px;opacity:1;margin-top:5px;margin-right:5px;"></i>
            </div>
            <h2 style="margin:0;font-weight:800;color:#fff;">Mesajların</h2>
            <p style="font-size:0.95rem;color:var(--text-muted);max-width:250px;text-align:center;">Bir arkadaşına mesaj göndererek sohbete başla.</p>
            <button class="btn-primary" style="margin-top:10px;border-radius:10px;padding:10px 20px;font-weight:700;" onclick="openNewChatModal()">Mesaj Gönder</button>
        </div>
    </div>
</div>

<!-- New Chat Modal -->
<div class="new-chat-overlay" id="newChatOverlay" onclick="closeNewChatModal()">
    <div class="new-chat-modal" onclick="event.stopPropagation()">
        <div style="display:flex;align-items:center;justify-content:between;margin-bottom:20px;">
            <h3 style="margin:0;font-weight:800;flex:1;">Yeni Sohbet</h3>
            <i class="fa-solid fa-xmark" onclick="closeNewChatModal()" style="cursor:pointer;opacity:0.5;"></i>
        </div>
        <div class="dm-search-container">
            <i class="fa-solid fa-search"></i>
            <input class="new-chat-search" id="newChatSearch" placeholder="Kullanıcı ara..." oninput="searchNewChat(this.value)">
        </div>
        <div id="newChatResults" style="max-height:300px;overflow-y:auto;margin-top:10px;"></div>
    </div>
</div>

@section Scripts {
<script>
    // Helper functions (previously in old global layout JS)
    function avatarHTML(src, name, size) {
        if (src) return `<img src="${src}" style="width:${size}px;height:${size}px;border-radius:50%;object-fit:cover;">`;
        const letter = (name || '?')[0].toUpperCase();
        return `<div style="width:${size}px;height:${size}px;border-radius:50%;background:linear-gradient(135deg,#c6ff00,#7ab800);color:#000;display:flex;align-items:center;justify-content:center;font-weight:900;font-size:${size/2.5}px;">${letter}</div>`;
    }
    function CSRF() {
        const el = document.querySelector('input[name=__RequestVerificationToken]');
        return el ? el.value : '';
    }
    async function secureFetch(url, method, body) {
        const opts = { method: method || 'GET' };
        if (body) opts.body = body;
        try {
            const res = await fetch(url, opts);
            return await res.json();
        } catch(e) { console.error('fetch error:', e); return null; }
    }

    let activeChatId = null;
    let chatPollTimer = null;

    const params = new URLSearchParams(window.location.search);
    const hedefParam = params.get('hedef');

    function timeShort(dateStr) {
        const d = new Date(dateStr);
        const now = new Date();
        const diff = Math.floor((now - d) / 1000);
        if (diff < 3600) return Math.floor(diff / 60) + 'dk';
        if (diff < 86400) return Math.floor(diff / 3600) + 'sa';
        return d.toLocaleDateString('tr-TR', { day: '2-digit', month: '2-digit' });
    }

    async function loadChats() {
        const data = await secureFetch('/Social/GetSohbetler');
        if (!data || !data.success) return;

        const list = document.getElementById('chatList');
        list.innerHTML = '';

        if (data.sohbetler.length === 0 && hedefParam) {
            openChat(parseInt(hedefParam));
            return;
        }

        // Separate chats into 'Recent' and 'Discover'
        const recent = data.sohbetler.filter(s => s.SonMesaj);
        const discover = data.sohbetler.filter(s => !s.SonMesaj);

        if (recent.length > 0) {
            const title = document.createElement('div');
            title.className = 'dm-section-title';
            title.textContent = 'Sohbetler';
            list.appendChild(title);

            recent.forEach(s => list.appendChild(createChatItem(s)));
        }

        if (discover.length > 0) {
            const title = document.createElement('div');
            title.className = 'dm-section-title';
            title.textContent = 'Keşfet';
            list.appendChild(title);

            discover.forEach(s => list.appendChild(createChatItem(s)));
        }

        if (hedefParam && !activeChatId) openChat(parseInt(hedefParam));
    }

    function createChatItem(s) {
        const div = document.createElement('div');
        div.className = `dm-chat-item ${activeChatId === s.Id ? 'active' : ''} ${s.OkunmamisSayi > 0 ? 'unread' : ''}`;
        div.id = `chat-item-${s.Id}`;
        div.onclick = () => openChat(s.Id);
        div.innerHTML = `
            <div class="dm-avatar-container">
                <img src="${s.ProfilResmi || 'https://ui-avatars.com/api/?name=' + encodeURIComponent(s.AdSoyad) + '&background=random'}" class="dm-chat-avatar">
                ${Math.random() > 0.7 ? '<div class="status-dot"></div>' : ''}
            </div>
            <div class="dm-chat-info">
                <div class="dm-chat-name">
                    <span>${s.AdSoyad}</span>
                    ${s.SonTarih ? `<span style="font-size:0.7rem;font-weight:400;opacity:0.5;">${timeShort(s.SonTarih)}</span>` : ''}
                </div>
                <div style="font-size:0.75rem;opacity:0.5;margin-bottom:2px;">@@${s.Handle || 'kartist'}</div>
                <div class="dm-chat-preview">${s.SonMesaj || 'Sohbeti başlat...'}</div>
            </div>
            ${s.OkunmamisSayi > 0 ? `<div style="width:8px;height:8px;border-radius:50%;background:var(--ig-primary);margin-left:10px;"></div>` : ''}
        `;
        return div;
    }

    function switchTab(tab) {
        document.querySelectorAll('.dm-tab').forEach(t => t.classList.remove('active'));
        event.target.classList.add('active');
        // Simple filtering for demo
        const items = document.querySelectorAll('.dm-chat-item');
        items.forEach(item => {
            if (tab === 'unread') {
                item.style.display = item.classList.contains('unread') ? 'flex' : 'none';
            } else {
                item.style.display = 'flex';
            }
        });
    }

    async function openChat(hedefId) {
        if (chatPollTimer) clearInterval(chatPollTimer);
        activeChatId = parseInt(hedefId);

        // Mobile layout switch
        document.getElementById('dmLayout').classList.add('chat-open');

        const area = document.getElementById('chatArea');
        area.innerHTML = `
            <div class="dm-chat-header">
                <div class="dm-header-user">
                    <i class="fa-solid fa-chevron-left dm-back-btn" onclick="closeChat()"></i>
                    <img src="" id="chatHeaderAvatar" style="width:32px;height:32px;border-radius:50%;object-fit:cover;">
                    <div>
                        <div class="name" id="chatHeaderName">Yükleniyor...</div>
                        <div style="font-size:0.75rem;opacity:0.5;display:flex;align-items:center;gap:4px;">
                            <div style="width:6px;height:6px;border-radius:50%;background:#4ade80;"></div> Aktif
                        </div>
                    </div>
                </div>
                <div class="dm-header-actions">
                    <i class="fa-solid fa-phone"></i>
                    <i class="fa-solid fa-video"></i>
                    <i class="fa-solid fa-circle-info" onclick="window.location.href='/Social/Profil/${hedefId}'"></i>
                </div>
            </div>
            <div class="dm-messages" id="msgContainer">
                <div style="padding:40px;text-align:center;opacity:0.5;"><i class="fa-solid fa-circle-notch fa-spin"></i></div>
            </div>
            <div class="dm-input-container">
                <div class="dm-input-wrapper">
                    <i class="fa-regular fa-face-smile" style="font-size:1.2rem;cursor:pointer;"></i>
                    <input class="dm-input" id="dmInput" placeholder="Mesaj yaz..." onkeydown="if(event.key==='Enter') sendDM()">
                    <button class="dm-send-btn" id="sendBtn" onclick="sendDM()">Gönder</button>
                </div>
            </div>
        `;

        const data = await secureFetch(`/Social/GetMesajlar?hedefId=${hedefId}`);
        if (!data || !data.success) return;

        document.getElementById('chatHeaderName').textContent = data.hedef.AdSoyad;
        document.getElementById('chatHeaderAvatar').src = data.hedef.ProfilResmi || `https://ui-avatars.com/api/?name=${encodeURIComponent(data.hedef.AdSoyad)}&background=random`;
        
        renderMessages(data.mesajlar, data.myId);
        
        chatPollTimer = setInterval(() => refreshMessages(hedefId), 3000);
    }

    function closeChat() {
        activeChatId = null;
        if (chatPollTimer) clearInterval(chatPollTimer);
        document.getElementById('dmLayout').classList.remove('chat-open');
    }

    function renderMessages(mesajlar, myId) {
        const container = document.getElementById('msgContainer');
        if (!container) return;
        
        container.innerHTML = '';
        
        if (mesajlar.length === 0) {
            container.innerHTML = `
                <div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40px;color:var(--text-muted);text-align:center;">
                    <div style="width:60px;height:60px;border-radius:50%;background:rgba(255,255,255,0.05);display:flex;align-items:center;justify-content:center;margin-bottom:15px;">
                        <i class="fa-regular fa-comment-dots" style="font-size:24px;"></i>
                    </div>
                    <p style="font-size:0.9rem;">Henüz mesaj yok. <br>Sohbeti başlatan ilk kişi sen ol!</p>
                </div>`;
            return;
        }

        mesajlar.forEach(m => {
            const isMine = m.GonderenId === myId;
            const isCollab = m.Tip === 'Collab';
            let msgClass = isMine ? 'sent' : 'received';
            
            const collabInfo = isCollab ? `<div style="display:flex;align-items:center;gap:6px;margin-bottom:6px;font-weight:800;color:#eab308;font-size:0.75rem;"><i class="fa-solid fa-bolt"></i> İş Birliği Teklifi</div>` : '';
            
            container.innerHTML += `
                <div class="dm-msg-wrapper ${msgClass}">
                    <div class="dm-msg ${msgClass}">
                        ${collabInfo}
                        ${m.Mesaj}
                        <div style="font-size:0.65rem;opacity:0.5;margin-top:4px;text-align:${isMine ? 'right' : 'left'}">
                            ${timeShort(m.Tarih)} ${isMine ? '<i class="fa-solid fa-check-double" style="margin-left:2px;color:#38bdf8;"></i>' : ''}
                        </div>
                    </div>
                </div>`;
        });
        container.scrollTop = container.scrollHeight;
    }

    async function refreshMessages(hedefId) {
        if (activeChatId !== hedefId) return;
        const data = await secureFetch(`/Social/GetMesajlar?hedefId=${hedefId}`);
        if (data && data.success) renderMessages(data.mesajlar, data.myId);
    }

    async function sendDM() {
        const input = document.getElementById('dmInput');
        if (!input?.value.trim() || !activeChatId) return;

        const fd = new FormData();
        fd.append('aliciId', activeChatId);
        fd.append('mesaj', input.value);
        fd.append('__RequestVerificationToken', CSRF());

        const msg = input.value;
        input.value = '';

        const res = await secureFetch('/Social/MesajGonder', 'POST', fd);
        if (res && res.success) {
            refreshMessages(activeChatId);
        }
    }

    function searchChats(q) {
        document.querySelectorAll('.dm-chat-item').forEach(item => {
            const name = item.querySelector('.dm-chat-name')?.textContent?.toLowerCase() || '';
            item.style.display = name.includes(q.toLowerCase()) ? '' : 'none';
        });
    }

    // New Chat Modal
    function openNewChatModal() {
        document.getElementById('newChatOverlay').classList.add('open');
        document.getElementById('newChatSearch').focus();
    }
    function closeNewChatModal() {
        document.getElementById('newChatOverlay').classList.remove('open');
        document.getElementById('newChatResults').innerHTML = '';
        document.getElementById('newChatSearch').value = '';
    }

    let newChatTimer;
    async function searchNewChat(q) {
        clearTimeout(newChatTimer);
        if (q.length < 2) { document.getElementById('newChatResults').innerHTML = ''; return; }
        
        newChatTimer = setTimeout(async () => {
            const data = await secureFetch(`/Social/Ara?q=${encodeURIComponent(q)}`);
            const container = document.getElementById('newChatResults');
            if (!data || !data.success) return;
            
            if (data.sonuclar.length === 0) {
                container.innerHTML = '<div style="padding:20px;text-align:center;color:var(--text-muted);font-size:0.85rem;">Kullanıcı bulunamadı</div>';
                return;
            }
            
            container.innerHTML = data.sonuclar.map(u => `
                <div style="display:flex;align-items:center;gap:12px;padding:12px;cursor:pointer;border-radius:var(--radius-sm);transition:0.2s;" onmouseover="this.style.background='var(--bg-hover)'" onmouseout="this.style.background=''" onclick="closeNewChatModal();openChat(${u.Id})">
                    ${avatarHTML(u.ProfilResmi, u.AdSoyad, 40)}
                    <div>
                        <div style="font-weight:700;font-size:0.9rem;">${u.AdSoyad}</div>
                        <div style="font-size:0.75rem;color:var(--text-muted);">${u.Biyografi || ''}</div>
                    </div>
                </div>
            `).join('');
        }, 250);
    }

    loadChats();
</script>
}

