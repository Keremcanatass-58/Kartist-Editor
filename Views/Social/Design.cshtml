@{
    Layout = "_SocialLayoutModern";
    ViewData["Title"] = Model.Title + " - Tasarim Detay";
}

<div class="flex min-h-screen bg-background">
    <aside class="fixed left-0 top-0 z-40 flex h-screen w-64 flex-col border-r border-border bg-card">
        <div class="flex h-16 items-center gap-2 border-b border-border px-6">
            <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-primary neon-glow">
                <svg class="h-5 w-5 text-primary-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>
            </div>
            <span class="text-xl font-bold tracking-tight">Kartist</span>
        </div>
        <nav class="mt-6 flex-1 px-3">
            <ul class="space-y-1">
                <li><a href="/Social/Feed" class="flex items-center gap-3 rounded-xl px-4 py-3 text-sm font-medium transition-all text-muted-foreground hover:bg-secondary hover:text-foreground"><svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" /></svg>Kesfet</a></li>
                <li><a href="/Social/Trending" class="flex items-center gap-3 rounded-xl px-4 py-3 text-sm font-medium transition-all text-muted-foreground hover:bg-secondary hover:text-foreground"><svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z" /></svg>Trendler</a></li>
                <li><a href="/Social/Duels" class="flex items-center gap-3 rounded-xl px-4 py-3 text-sm font-medium transition-all text-muted-foreground hover:bg-secondary hover:text-foreground"><svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" /></svg>Duellolar</a></li>
            </ul>
        </nav>
        <div class="border-t border-border px-3 py-4">
            <ul class="space-y-1">
                <li><a href="/Social/Profil/me" class="flex items-center gap-3 rounded-xl px-4 py-3 text-sm font-medium transition-all text-muted-foreground hover:bg-secondary hover:text-foreground"><svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>Profil</a></li>
                <li><a href="/Social/Settings" class="flex items-center gap-3 rounded-xl px-4 py-3 text-sm font-medium transition-all text-muted-foreground hover:bg-secondary hover:text-foreground"><svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>Ayarlar</a></li>
            </ul>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="ml-64 flex-1">
        <!-- Header -->
        <header class="sticky top-0 z-50 flex items-center justify-between border-b border-border bg-card/80 px-6 py-4 backdrop-blur-xl">
            <a href="/Social/Trending" class="flex items-center gap-2 text-muted-foreground transition-colors hover:text-foreground">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                <span>Geri</span>
            </a>
            
            <div class="flex items-center gap-3">
                <button onclick="shareDesign()" class="flex h-10 w-10 items-center justify-center rounded-full bg-secondary transition-colors hover:bg-secondary/80">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
                    </svg>
                </button>
                <button onclick="moreOptions()" class="flex h-10 w-10 items-center justify-center rounded-full bg-secondary transition-colors hover:bg-secondary/80">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h.01M12 12h.01M19 12h.01M6 12a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0z" />
                    </svg>
                </button>
            </div>
        </header>

        <div class="mx-auto max-w-7xl px-6 py-8">
            <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">
                <!-- Main Content -->
                <div class="lg:col-span-2">
                    <!-- Image -->
                    <div class="overflow-hidden rounded-2xl bg-card">
                        <img src="@(Model.ImageUrl ?? "https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?w=800")" 
                             alt="@Model.Title" 
                             class="w-full object-cover" />
                    </div>

                    <!-- Actions -->
                    <div class="mt-6 flex items-center justify-between">
                        <div class="flex items-center gap-4">
                            <button onclick="handleLike()" id="likeBtn" 
                                    class="flex items-center gap-2 rounded-xl px-4 py-2.5 font-medium transition-all bg-secondary text-foreground hover:bg-secondary/80">
                                <svg id="likeIcon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                                </svg>
                                <span id="likeCount">@Model.Likes</span>
                            </button>
                            <button class="flex items-center gap-2 rounded-xl bg-secondary px-4 py-2.5 font-medium transition-colors hover:bg-secondary/80">
                                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                </svg>
                                @Model.Views
                            </button>
                            <button onclick="handleSave()" id="saveBtn"
                                    class="flex items-center gap-2 rounded-xl px-4 py-2.5 font-medium transition-all bg-secondary text-foreground hover:bg-secondary/80">
                                <svg id="saveIcon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
                                </svg>
                                Kaydet
                            </button>
                        </div>
                        
                        <div class="flex items-center gap-2">
                            <button onclick="downloadDesign()" class="flex items-center gap-2 rounded-xl bg-secondary px-4 py-2.5 font-medium transition-colors hover:bg-secondary/80">
                                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                                </svg>
                            </button>
                            <button onclick="reportDesign()" class="flex items-center gap-2 rounded-xl bg-secondary px-4 py-2.5 font-medium transition-colors hover:bg-secondary/80">
                                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                                </svg>
                            </button>
                        </div>
                    </div>

                    <!-- Title & Description -->
                    <div class="mt-8">
                        <h1 class="text-3xl font-bold">@Model.Title</h1>
                        <p class="mt-4 text-lg text-muted-foreground">@(Model.Description ?? "Bu tasarim hakkinda detayli bilgi bulunmuyor.")</p>
                        
                        <!-- Tags -->
                        <div class="mt-6 flex flex-wrap gap-2">
                            <span class="rounded-lg bg-secondary px-3 py-1.5 text-sm font-medium">UI/UX</span>
                            <span class="rounded-lg bg-secondary px-3 py-1.5 text-sm font-medium">Tasarim</span>
                            <span class="rounded-lg bg-secondary px-3 py-1.5 text-sm font-medium">Modern</span>
                        </div>
                    </div>

                    <!-- Comments Section -->
                    <div class="mt-10">
                        <h2 class="text-xl font-bold">Yorumlar (@ViewBag.Comments.Count)</h2>
                        
                        <!-- Comment Input -->
                        <div class="mt-6 flex items-start gap-4">
                            <img src="https://ui-avatars.com/api/?name=Me&background=random&size=128" class="h-10 w-10 rounded-full" />
                            <div class="flex-1">
                                <textarea id="commentInput"
                                    class="h-24 w-full resize-none rounded-xl border border-border bg-card p-4 text-sm focus:border-primary focus:outline-none"
                                    placeholder="Yorumunu yaz..."></textarea>
                                <div class="mt-2 flex justify-end">
                                    <button onclick="addComment()"
                                        class="flex items-center gap-2 rounded-xl bg-primary px-4 py-2 font-semibold text-primary-foreground transition-opacity hover:opacity-90">
                                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                                        </svg>
                                        Gonder
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Comments List -->
                        <div id="commentsList" class="mt-6 space-y-4">
                            @foreach (var comment in ViewBag.Comments)
                            {
                                <div class="rounded-xl bg-card p-4">
                                    <div class="flex items-start gap-3">
                                        <img src="@comment.UserAvatar" class="h-10 w-10 rounded-full" />
                                        <div class="flex-1">
                                            <div class="flex items-center gap-2">
                                                <span class="font-semibold">@comment.UserName</span>
                                                <span class="text-xs text-muted-foreground">@comment.Time</span>
                                            </div>
                                            <p class="mt-1 text-muted-foreground">@comment.Text</p>
                                            <div class="mt-2 flex items-center gap-4">
                                                <button onclick="likeComment(@comment.Id)" class="flex items-center gap-1 text-sm text-muted-foreground hover:text-foreground">
                                                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                                                    </svg>
                                                    @comment.Likes
                                                </button>
                                                <button class="text-sm text-muted-foreground hover:text-foreground">Yanitla</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Sidebar -->
                <div class="lg:col-span-1">
                    <!-- Designer Card -->
                    <div class="rounded-2xl bg-card p-6">
                        <div class="flex items-center gap-4">
                            <div class="relative">
                                <img src="@(Model.DesignerAvatar ?? "https://ui-avatars.com/api/?name=" + Model.DesignerName + "&background=random&size=128")"
                                     alt="@Model.DesignerName"
                                     class="h-16 w-16 rounded-full object-cover ring-2 ring-primary" />
                                <div class="absolute -bottom-1 -right-1 flex h-6 w-6 items-center justify-center rounded-full bg-primary text-xs font-bold text-primary-foreground">
                                    @Model.DesignerLevel
                                </div>
                            </div>
                            <div class="flex-1">
                                <h3 class="text-lg font-bold">@Model.DesignerName</h3>
                                <p class="text-sm text-muted-foreground">@@@Model.DesignerUsername</p>
                            </div>
                        </div>
                        
                        <button onclick="followDesigner(@Model.DesignerId)" class="mt-4 flex w-full items-center justify-center gap-2 rounded-xl bg-primary py-3 font-semibold text-primary-foreground transition-opacity hover:opacity-90">
                            Takip Et
                        </button>

                        <div class="mt-4 grid grid-cols-3 gap-4 border-t border-border pt-4 text-center">
                            <div>
                                <p class="text-lg font-bold">@ViewBag.DesignerStats.Designs</p>
                                <p class="text-xs text-muted-foreground">Tasarim</p>
                            </div>
                            <div>
                                <p class="text-lg font-bold">@(((int)ViewBag.DesignerStats.Followers / 1000).ToString() + "K")</p>
                                <p class="text-xs text-muted-foreground">Takipci</p>
                            </div>
                            <div>
                                <p class="text-lg font-bold">@ViewBag.DesignerStats.Following</p>
                                <p class="text-xs text-muted-foreground">Takip</p>
                            </div>
                        </div>
                    </div>

                    <!-- Related Designs -->
                    <div class="mt-6">
                        <h3 class="text-lg font-bold">Benzer Tasarimlar</h3>
                        <div class="mt-4 space-y-4">
                            @foreach (var related in ViewBag.RelatedDesigns)
                            {
                                <a href="/Social/Design/@related.Id" class="group flex gap-4 rounded-xl bg-card p-3 transition-colors hover:bg-secondary">
                                    <img src="@related.ImageUrl" alt="@related.Title" class="h-20 w-28 rounded-lg object-cover" />
                                    <div class="flex-1 min-w-0">
                                        <h4 class="truncate font-semibold group-hover:text-primary">@related.Title</h4>
                                        <p class="mt-1 text-sm text-muted-foreground">@Model.DesignerName</p>
                                        <div class="mt-2 flex items-center gap-3 text-xs text-muted-foreground">
                                            <span class="flex items-center gap-1">
                                                <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                                                </svg>
                                                @related.Likes
                                            </span>
                                        </div>
                                    </div>
                                </a>
                            }
                        </div>
                    </div>

                    <!-- Color Palette -->
                    <div class="mt-6 rounded-2xl bg-card p-6">
                        <h3 class="font-bold">Renk Paleti</h3>
                        <div class="mt-4 grid grid-cols-5 gap-2">
                            @foreach (var color in ViewBag.ColorPalette)
                            {
                                <button onclick="copyColor('@color')" 
                                        class="aspect-square rounded-lg transition-transform hover:scale-110"
                                        style="background-color: @color"
                                        title="@color"></button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<script>
    var isLiked = false;
    var isSaved = false;
    var designId = @Model.Id;
    var likesCount = @Model.Likes;

    function handleLike() {
        isLiked = !isLiked;
        var btn = document.getElementById('likeBtn');
        var icon = document.getElementById('likeIcon');
        var count = document.getElementById('likeCount');
        
        if (isLiked) {
            btn.classList.remove('bg-secondary', 'text-foreground');
            btn.classList.add('bg-accent/10', 'text-accent');
            icon.setAttribute('fill', 'currentColor');
            likesCount++;
        } else {
            btn.classList.add('bg-secondary', 'text-foreground');
            btn.classList.remove('bg-accent/10', 'text-accent');
            icon.setAttribute('fill', 'none');
            likesCount--;
        }
        
        if (count) count.textContent = likesCount;
        
        // Backend cagrisi
        fetch('/Social/Begen?gonderiId=' + designId, { method: 'POST' })
            .then(r => r.json())
            .then(data => { if(data.xp) console.log('XP kazanildi:', data.xp); })
            .catch(err => console.error('Like error:', err));
    }

    function handleSave() {
        var btn = document.getElementById('saveBtn');
        var icon = document.getElementById('saveIcon');
        
        fetch('/Social/Kaydet?gonderiId=' + designId, { method: 'POST' })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.success) {
                    isSaved = data.saved;
                    if (isSaved) {
                        btn.classList.remove('bg-secondary', 'text-foreground');
                        btn.classList.add('bg-primary/10', 'text-primary');
                        icon.setAttribute('fill', 'currentColor');
                    } else {
                        btn.classList.add('bg-secondary', 'text-foreground');
                        btn.classList.remove('bg-primary/10', 'text-primary');
                        icon.setAttribute('fill', 'none');
                    }
                }
            })
            .catch(function(err) { console.error('Save error:', err); });
    }

    function addComment() {
        var input = document.getElementById('commentInput');
        if (!input || !input.value.trim()) return;
        
        var text = input.value.trim();
        var commentsList = document.getElementById('commentsList');
        
        // Yeni yorum ekle (frontend)
        var newComment = document.createElement('div');
        newComment.className = 'rounded-xl bg-card p-4';
        newComment.innerHTML = `
            <div class="flex items-start gap-3">
                <img src="https://ui-avatars.com/api/?name=Me&background=random&size=128" class="h-10 w-10 rounded-full" />
                <div class="flex-1">
                    <div class="flex items-center gap-2">
                        <span class="font-semibold">Ben</span>
                        <span class="text-xs text-muted-foreground">Simdi</span>
                    </div>
                    <p class="mt-1 text-muted-foreground">${text}</p>
                    <div class="mt-2 flex items-center gap-4">
                        <button class="flex items-center gap-1 text-sm text-muted-foreground hover:text-foreground">
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                            </svg>
                            0
                        </button>
                        <button class="text-sm text-muted-foreground hover:text-foreground">Yanitla</button>
                    </div>
                </div>
            </div>
        `;
        
        if (commentsList) {
            commentsList.insertBefore(newComment, commentsList.firstChild);
        }
        
        input.value = '';
        
        // Backend cagrisi
        fetch('/Social/YorumYap', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'gonderiId=' + designId + '&icerik=' + encodeURIComponent(text)
        }).then(r => r.json())
          .then(data => { if(data.xp) console.log('XP kazanildi:', data.xp); })
          .catch(err => console.error('Comment error:', err));
    }

    function likeComment(id) {
        console.log('Comment liked:', id);
    }

    function copyColor(color) {
        navigator.clipboard.writeText(color).then(function() {
            alert('Renk kodu kopyalandi: ' + color);
        }).catch(function() {
            console.log('Renk:', color);
        });
    }

    function shareDesign() {
        var url = window.location.href;
        navigator.clipboard.writeText(url).then(function() {
            alert('Baglanti kopyalandi!');
        });
    }

    function downloadDesign() {
        alert('Indirme ozelligi yakinda geliyor!');
    }

    function reportDesign() {
        alert('Sikayet iletildi.');
    }

    function moreOptions() {
        alert('Daha fazla secenek yakinda!');
    }
</script>

@Html.AntiForgeryToken()
