@model List<Kartist.Models.Sablon>
@{
    Layout = null;
    var bekleyenler = ViewBag.Bekleyenler as List<Kartist.Models.Sablon>;
    var sonUyeler = ViewBag.SonUyeler as List<dynamic>;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kartist Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;500;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.js"></script>

    <style>
        body {
            background: #0a0a0f;
            color: #ddd;
            font-family: 'Space Grotesk', sans-serif;
            overflow-x: hidden;
        }

        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            width: 250px;
            background: rgba(20, 20, 25, 0.95);
            border-right: 1px solid rgba(255,255,255,0.1);
            padding: 30px 20px;
            z-index: 100;
        }

        .brand {
            font-size: 1.5rem;
            font-weight: 800;
            color: white;
            margin-bottom: 50px;
            display: block;
            text-align: center;
            text-decoration: none;
        }

            .brand span {
                color: #c6ff00;
            }

        .nav-link {
            color: #888;
            padding: 15px;
            border-radius: 10px;
            margin-bottom: 10px;
            transition: 0.3s;
            text-decoration: none;
            display: block;
            font-weight: 600;
        }

            .nav-link:hover, .nav-link.active {
                background: rgba(198, 255, 0, 0.1);
                color: #c6ff00;
            }

            .nav-link i {
                width: 25px;
            }

        .main-content {
            margin-left: 250px;
            padding: 40px;
        }

        .stat-card {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.05);
            border-radius: 20px;
            padding: 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: 0.3s;
        }

            .stat-card:hover {
                transform: translateY(-5px);
                border-color: rgba(198, 255, 0, 0.3);
            }

        .stat-info h3 {
            font-size: 2rem;
            font-weight: 800;
            margin: 0;
            color: white;
        }

        .stat-info p {
            margin: 0;
            color: #888;
            font-size: 0.9rem;
        }

        .stat-icon {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: rgba(255,255,255,0.05);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: #c6ff00;
        }

        .card-custom {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.05);
            border-radius: 20px;
            padding: 25px;
            margin-bottom: 30px;
        }

        .table-dark-custom {
            --bs-table-bg: transparent;
            color: #ccc;
        }

            .table-dark-custom th {
                border-bottom: 1px solid #333;
                color: #666;
                font-weight: 600;
                font-size: 0.8rem;
                text-transform: uppercase;
            }

            .table-dark-custom td {
                border-bottom: 1px solid rgba(255,255,255,0.05);
                vertical-align: middle;
                padding: 15px 0;
            }

        .form-control {
            background: #111;
            border: 1px solid #333;
            color: white;
        }

            .form-control:focus {
                background: #151515;
                border-color: #c6ff00;
                color: white;
                box-shadow: none;
            }

        .btn-neon {
            background: #c6ff00;
            color: black;
            font-weight: bold;
            border: none;
        }

        .admin-actions {
            display: flex;
            gap: 5px;
            align-items: center;
        }

        .mini-input {
            background: #111;
            border: 1px solid #333;
            color: white;
            width: 70px;
            border-radius: 4px;
            padding: 4px 8px;
            font-size: 0.85rem;
            text-align: center;
        }

        .mini-select {
            background: #111;
            border: 1px solid #333;
            color: white;
            border-radius: 4px;
            padding: 4px;
            font-size: 0.85rem;
            cursor: pointer;
        }

        .mini-btn {
            border: none;
            background: #333;
            color: #aaa;
            border-radius: 4px;
            padding: 5px 10px;
            font-size: 0.9rem;
            transition: 0.2s;
            cursor: pointer;
        }

            .mini-btn:hover {
                background: #c6ff00;
                color: black;
            }

        /* ============================================
           RESPONSIVE TASARIM - TÜM CİHAZLAR İÇİN
           ============================================ */

        /* Tablet ve küçük ekranlar (992px ve altı) */
        @@media (max-width: 992px) {
            .sidebar {
                width: 200px;
                padding: 20px 15px;
            }

            .main-content {
                margin-left: 200px;
                padding: 30px 20px;
            }

            .stat-card {
                padding: 20px;
            }

            .stat-info h3 {
                font-size: 1.5rem;
            }

            .stat-icon {
                width: 50px;
                height: 50px;
                font-size: 1.2rem;
            }
        }

        /* Mobil cihazlar (768px ve altı) */
        @@media (max-width: 768px) {
            .sidebar {
                width: 100%;
                height: auto;
                position: relative;
                border-right: none;
                border-bottom: 1px solid rgba(255,255,255,0.1);
                padding: 15px;
                display: flex;
                flex-wrap: wrap;
                gap: 10px;
                justify-content: center;
            }

            .brand {
                font-size: 1.2rem;
                margin-bottom: 15px;
                width: 100%;
                text-align: center;
            }

            .nav-link {
                padding: 10px 15px;
                font-size: 0.85rem;
                margin-bottom: 5px;
                flex: 1;
                min-width: 120px;
                text-align: center;
            }

            .nav-link i {
                width: 20px;
            }

            .main-content {
                margin-left: 0;
                padding: 20px 15px;
            }

            .stat-card {
                flex-direction: column;
                text-align: center;
                padding: 20px 15px;
                margin-bottom: 15px;
            }

            .stat-info {
                margin-bottom: 15px;
            }

            .stat-info h3 {
                font-size: 1.8rem;
            }

            .stat-info p {
                font-size: 0.85rem;
            }

            .stat-icon {
                width: 50px;
                height: 50px;
                font-size: 1.3rem;
            }

            .card-custom {
                padding: 20px 15px;
                margin-bottom: 20px;
            }

            .table-dark-custom {
                font-size: 0.85rem;
            }

            .table-dark-custom th {
                font-size: 0.75rem;
                padding: 10px 5px;
            }

            .table-dark-custom td {
                padding: 10px 5px;
            }

            .table-dark-custom img {
                width: 40px !important;
                height: 30px !important;
            }

            .admin-actions {
                flex-direction: column;
                gap: 8px;
                width: 100%;
            }

            .mini-input,
            .mini-select {
                width: 100%;
                margin-bottom: 5px;
            }

            .mini-btn {
                width: 100%;
                padding: 8px;
            }

            .row {
                margin: 0;
            }

            .row > [class*="col-"] {
                padding: 0;
                margin-bottom: 20px;
            }
        }

        /* Küçük telefonlar (480px ve altı) */
        @@media (max-width: 480px) {
            .sidebar {
                padding: 12px 10px;
                gap: 8px;
            }

            .brand {
                font-size: 1.1rem;
                margin-bottom: 12px;
            }

            .nav-link {
                padding: 8px 10px;
                font-size: 0.8rem;
                min-width: 100px;
            }

            .main-content {
                padding: 15px 10px;
            }

            .stat-card {
                padding: 15px 10px;
            }

            .stat-info h3 {
                font-size: 1.5rem;
            }

            .stat-icon {
                width: 45px;
                height: 45px;
                font-size: 1.1rem;
            }

            .card-custom {
                padding: 15px 10px;
            }

            .card-custom h5 {
                font-size: 1rem;
            }

            .table-dark-custom {
                font-size: 0.75rem;
            }

            .table-dark-custom th {
                font-size: 0.7rem;
                padding: 8px 3px;
            }

            .table-dark-custom td {
                padding: 8px 3px;
            }

            .table-dark-custom img {
                width: 35px !important;
                height: 25px !important;
            }

            .btn-sm {
                padding: 4px 8px;
                font-size: 0.75rem;
            }

            .form-control {
                font-size: 0.85rem;
                padding: 8px;
            }

            .badge {
                font-size: 0.7rem;
            }

            .d-flex.flex-column {
                padding: 10px;
            }

            .d-flex.flex-column > div:first-child {
                margin-bottom: 10px;
            }

            .bg-dark.p-2.rounded {
                padding: 10px !important;
            }

            .admin-actions {
                gap: 10px;
            }

            .admin-actions > div {
                width: 100%;
            }

            .mini-input,
            .mini-select,
            .mini-btn {
                font-size: 0.8rem;
            }
        }

        /* Çok küçük telefonlar (360px ve altı) */
        @@media (max-width: 360px) {
            .sidebar {
                padding: 10px 8px;
            }

            .nav-link {
                padding: 6px 8px;
                font-size: 0.75rem;
                min-width: 90px;
            }

            .main-content {
                padding: 12px 8px;
            }

            .stat-info h3 {
                font-size: 1.3rem;
            }

            .stat-icon {
                width: 40px;
                height: 40px;
                font-size: 1rem;
            }

            .table-dark-custom {
                font-size: 0.7rem;
            }

            .table-dark-custom th,
            .table-dark-custom td {
                padding: 6px 2px;
            }
        }

        /* Yatay mod (landscape) mobil */
        @@media (max-width: 900px) and (orientation: landscape) {
            .sidebar {
                height: auto;
                position: relative;
            }

            .main-content {
                margin-left: 0;
            }
        }

        /* Tablo responsive wrapper */
        @@media (max-width: 768px) {
            .table-responsive {
                overflow-x: auto;
                -webkit-overflow-scrolling: touch;
            }

            .table-dark-custom {
                min-width: 600px;
            }
        }

        /* Grafik container responsive */
        @@media (max-width: 768px) {
            canvas {
                max-width: 100%;
                height: auto !important;
            }
        }

        /* Touch friendly butonlar mobilde */
        @@media (max-width: 768px) {
            .btn,
            .nav-link,
            .mini-btn {
                min-height: 44px; /* iOS touch target */
                touch-action: manipulation;
            }
        }

        /* Scroll bar özelleştirme */
        .table-responsive {
            scrollbar-width: thin;
            scrollbar-color: #c6ff00 #222;
        }

        .table-responsive::-webkit-scrollbar {
            height: 6px;
        }

        .table-responsive::-webkit-scrollbar-thumb {
            background: #c6ff00;
            border-radius: 3px;
        }

        .table-responsive::-webkit-scrollbar-track {
            background: #222;
        }
    </style>
</head>
<body>

    <div class="sidebar">
        <a href="/" class="brand">KART<span>IST</span></a>
        <a href="#" class="nav-link active"><i class="fa-solid fa-chart-pie"></i> Dashboard</a>
        <a href="#bekleyenler" class="nav-link"><i class="fa-solid fa-clock"></i> Onay Bekleyenler</a>
        <a href="#urunler" class="nav-link"><i class="fa-solid fa-layer-group"></i> Ürünler</a>
        <a href="#uyeler" class="nav-link"><i class="fa-solid fa-users"></i> Üyeler</a>
        <a href="/Admin/Cikis" class="nav-link text-danger" style="margin-top: auto;"><i class="fa-solid fa-right-from-bracket"></i> Çıkış</a>
    </div>

    <div class="main-content">

        <div class="row g-4 mb-5">
            <div class="col-md-3 col-sm-6 col-12"><div class="stat-card"><div class="stat-info"><h3>@ViewBag.ToplamUye</h3><p>Toplam Üye</p></div><div class="stat-icon"><i class="fa-solid fa-users"></i></div></div></div>
            <div class="col-md-3 col-sm-6 col-12"><div class="stat-card"><div class="stat-info"><h3>@ViewBag.ToplamTasarim</h3><p>Toplam Tasarım</p></div><div class="stat-icon"><i class="fa-solid fa-image"></i></div></div></div>
            <div class="col-md-3 col-sm-6 col-12"><div class="stat-card"><div class="stat-info"><h3>@ViewBag.ToplamCiro ₺</h3><p>Tahmini Değer</p></div><div class="stat-icon"><i class="fa-solid fa-sack-dollar"></i></div></div></div>
            <div class="col-md-3 col-sm-6 col-12"><div class="stat-card" style="border-color: #ffc107;"><div class="stat-info"><h3 class="text-warning">@ViewBag.BekleyenSayisi</h3><p>Onay Bekleyen</p></div><div class="stat-icon" style="color:#ffc107"><i class="fa-solid fa-bell"></i></div></div></div>
        </div>

        <div class="row mb-5">
            <div class="col-md-8 col-12 mb-4 mb-md-0"><div class="card-custom"><h5 class="mb-4">Haftalık Satış Analizi</h5><canvas id="satisGrafigi" height="120"></canvas></div></div>
            <div class="col-md-4 col-12"><div class="card-custom"><h5 class="mb-4">Kategori Dağılımı</h5><canvas id="kategoriGrafigi" height="260"></canvas></div></div>
        </div>

        @if (bekleyenler != null && bekleyenler.Count > 0)
        {
            <div class="card-custom" id="bekleyenler" style="border: 1px solid #ffc107; background: rgba(255, 193, 7, 0.02);">
                <h5 class="text-warning mb-3"><i class="fa-solid fa-circle-exclamation me-2"></i> Onay Bekleyen İşlemler</h5>
                <div class="table-responsive">
                    <table class="table table-dark-custom">
                        <thead><tr><th>Tasarım</th><th>Başlık</th><th>Fiyat</th><th>İşlem</th></tr></thead>
                        <tbody>
                            @foreach (var item in bekleyenler)
                            {
                                <tr>
                                    <td><img src="@item.ResimUrl" width="50" height="40" style="border-radius:5px;"></td>
                                    <td>@item.Baslik</td>
                                    <td class="text-warning">@item.Fiyat ₺</td>
                                    <td>
                                        <div class="d-flex gap-1 flex-wrap">
                                            <a href="/Home/Tasarim/@item.Id" target="_blank" class="btn btn-sm btn-outline-light"><i class="fa-solid fa-eye"></i></a>
                                            <a href="/Admin/Onayla/@item.Id" class="btn btn-sm btn-success fw-bold">ONAYLA</a>
                                            <a href="/Admin/Reddet/@item.Id" class="btn btn-sm btn-danger">RED</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <div class="row">
            <div class="col-md-8 col-12 mb-4 mb-md-0" id="urunler">
                <div class="card-custom">
                    <h5 class="mb-4">Vitrin Ürünleri</h5>
                    <div class="table-responsive">
                        <table class="table table-dark-custom">
                            <thead><tr><th>Görsel</th><th>Başlık</th><th>Kategori</th><th>Fiyat</th><th>İşlem</th></tr></thead>
                            <tbody>
                                @foreach (var item in Model.Take(10))
                                {
                                    <tr>
                                        <td><img src="@item.ResimUrl" width="40" height="30" style="border-radius:4px;"></td>
                                        <td>@item.Baslik</td>
                                        <td><span class="badge bg-secondary">@item.Kategori</span></td>
                                        <td style="color:#c6ff00">@item.Fiyat ₺</td>
                                        <td><a href="/Admin/Sil/@item.Id" onclick="return confirm('Sil?')" class="text-danger"><i class="fa-solid fa-trash"></i></a></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-md-4 col-12" id="uyeler">
                <div class="card-custom">
                    <h5>Üye Yönetimi</h5>
                    <div class="mt-3">
                        @if (sonUyeler != null)
                        {
                            foreach (var uye in sonUyeler)
                            {
                                <div class="d-flex flex-column mb-4 pb-3 border-bottom border-secondary">
                                    <div class="d-flex align-items-center mb-2">
                                        <div style="width:40px; height:40px; background:#222; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:bold; color:#c6ff00;">
                                            @uye.AdSoyad.Substring(0, 1).ToUpper()
                                        </div>
                                        <div class="ms-3">
                                            <div class="fw-bold">@uye.AdSoyad</div>
                                            <div class="small text-muted">@uye.Email</div>
                                        </div>
                                        <div class="ms-auto">
                                            @if (uye.UyelikTipi == "Pro")
                                            {
                                                <span class="badge bg-warning text-dark" id="badge-@uye.Id">PRO</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary" id="badge-@uye.Id">USER</span>
                                            }
                                        </div>
                                    </div>

                                    <div class="d-flex justify-content-between align-items-center bg-dark p-2 rounded">
                                        <span class="small text-white">Kredi: <strong style="color:#c6ff00" id="kredi-text-@uye.Id">@uye.KalanKredi</strong></span>

                                        <div class="admin-actions">
                                            <div class="d-flex gap-1">
                                                <input type="number" id="kredi-@uye.Id" class="mini-input" placeholder="+/-">
                                                <button onclick="krediGuncelle(@uye.Id)" class="mini-btn" title="Kredi Yükle"><i class="fa-solid fa-coins"></i></button>
                                            </div>

                                            <div class="d-flex gap-1 ms-2">
                                                <select id="tip-@uye.Id" class="mini-select">
                                                    <option value="Normal" selected="@(uye.UyelikTipi == "Normal")">Normal</option>
                                                    <option value="Pro" selected="@(uye.UyelikTipi == "Pro")">Pro</option>
                                                </select>
                                                <button onclick="uyelikDegistir(@uye.Id)" class="mini-btn" title="Kaydet">
                                                    <i class="fa-solid fa-save"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>

                <div class="card-custom">
                    <h5>Hızlı Ürün Ekle</h5>
                    <form action="/Admin/Ekle" method="post" class="mt-3">
                        @Html.AntiForgeryToken()
                        <input type="text" name="baslik" class="form-control mb-2" placeholder="Başlık" required>
                        <input type="text" name="kategori" class="form-control mb-2" placeholder="Kategori">
                        <input type="text" name="fiyat" class="form-control mb-2" placeholder="Fiyat">
                        <input type="text" name="resimUrl" class="form-control mb-2" placeholder="Resim URL">
                        <button class="btn btn-neon w-100">EKLE</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/adminHub")
            .build();

        connection.on("VeriDegisti", function () {
            const Toast = Swal.mixin({
                toast: true, position: 'top-end', showConfirmButton: false, timer: 3000,
                didOpen: (toast) => { toast.addEventListener('mouseenter', Swal.stopTimer); toast.addEventListener('mouseleave', Swal.resumeTimer); }
            });
            Toast.fire({ icon: 'info', title: 'Yeni bir işlem yapıldı! Sayfa yenileniyor...' });

            setTimeout(() => { location.reload(); }, 1500);
        });

        connection.start().catch(err => console.error(err.toString()));
        new Chart(document.getElementById('satisGrafigi'), { type: 'line', data: { labels: ['Pzt', 'Sal', 'Çar', 'Per', 'Cum', 'Cmt', 'Paz'], datasets: [{ label: 'Satışlar (₺)', data: [150, 230, 180, 320, 290, 450, 600], borderColor: '#c6ff00', backgroundColor: 'rgba(198, 255, 0, 0.1)', tension: 0.4, fill: true }] }, options: { plugins: { legend: { display: false } }, scales: { x: { grid: { display: false } }, y: { grid: { color: '#333' } } } } });
        new Chart(document.getElementById('kategoriGrafigi'), { type: 'doughnut', data: { labels: ['Doğum Günü', 'Düğün', 'Parti', 'Kurumsal'], datasets: [{ data: [30, 20, 40, 10], backgroundColor: ['#ff6384', '#36a2eb', '#c6ff00', '#ffce56'], borderWidth: 0 }] }, options: { plugins: { legend: { position: 'bottom', labels: { color: '#aaa' } } } } });

        function krediGuncelle(id) {
            var miktar = $('#kredi-' + id).val();

            if (!miktar) {
                Swal.fire("Miktar giriniz!", "", "warning");
                return;
            }

            $.post('/Admin/KrediYukle', { id: id, miktar: miktar }, function () {
                Swal.fire({ icon: 'success', title: 'Kredi Güncellendi!', timer: 1500, showConfirmButton: false })
                .then(() => location.reload());
            }).fail(function() {
                Swal.fire({ icon: 'error', title: 'Hata!', text: 'İşlem başarısız.' });
            });
        }

        function uyelikDegistir(id) {
            var tip = $('#tip-' + id).val();

            $.post('/Admin/UyelikDegistir', { id: id, tip: tip }, function () {
                Swal.fire({ icon: 'success', title: 'Üyelik Değiştirildi!', timer: 1500, showConfirmButton: false })
                .then(() => location.reload());
            }).fail(function() {
                Swal.fire({ icon: 'error', title: 'Hata!', text: 'İşlem başarısız.' });
            });
        }


    </script>

</body>
</html>