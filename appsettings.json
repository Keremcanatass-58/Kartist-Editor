{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": "https://localhost",
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER;Database=YOUR_DB;User Id=YOUR_USER;Password=YOUR_PASSWORD;MultipleActiveResultSets=true;TrustServerCertificate=True;Connect Timeout=5"
  },
  "EmailSettings": {
    "Mail": "your-email@gmail.com",
    "Password": "YOUR_APP_PASSWORD",
    "Host": "smtp.gmail.com",
    "Port": 587,
    "ContactInbox": "your-email@gmail.com"
  },
  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": "587",
    "User": "your-email@gmail.com",
    "Pass": "YOUR_APP_PASSWORD",
    "From": "your-email@gmail.com",
    "FromName": "Kartist",
    "EnableSsl": "true"
  },
  "Authentication": {
    "Google": {
      "ClientId": "YOUR_GOOGLE_CLIENT_ID",
      "ClientSecret": "YOUR_GOOGLE_CLIENT_SECRET"
    }
  },
  "Groq": {
    "ApiKey": "YOUR_GROQ_API_KEY",
    "Endpoint": "https://api.groq.com/openai/v1/chat/completions",
    "Model": "llama-3.3-70b-versatile"
  },
  "OpenAI": {
    "ApiKey": "YOUR_OPENAI_API_KEY",
    "Endpoint": "https://api.openai.com/v1/chat/completions",
    "Model": "gpt-4o-mini"
  },
  "Ai": {
    "ImageProvider": "Pollinations",
    "PromptProvider": "Groq",
    "TimeoutSeconds": 25,
    "MaxImageBytes": 5242880,
    "PollinationsEndpoint": "https://image.pollinations.ai/prompt",
    "PollinationsModel": "flux",
    "GroqEndpoint": "https://api.groq.com/openai/v1/chat/completions",
    "GroqModel": "llama-3.3-70b-versatile",
    "OpenAiChatEndpoint": "https://api.openai.com/v1/chat/completions",
    "OpenAiChatModel": "gpt-4o-mini",
    "OpenAiImageEndpoint": "https://api.openai.com/v1/images/generations",
    "OpenAiImageModel": "gpt-image-1"
  },
  "Deployment": {
    "Secret": "YOUR_DEPLOY_SECRET",
    "SignatureToleranceSeconds": 300
  },
  "Database": {
    "AutoSchema": false
  },
  "Razor": {
    "RuntimeCompilation": false
  },
  "Security": {
    "RateLimitMaxRequests": 100,
    "RateLimitTimeWindowSeconds": 60,
    "MaxFileSizeMB": 200,
    "MaxRequestSizeMB": 200
  }
}
